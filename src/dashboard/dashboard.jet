{{extends "layout"}}

{{block title()}}League Client{{end}}

{{block styles()}}
<style>
:root {
  --bg:          #0a0f1e;
  --surface:     #111827;
  --card:        #162032;
  --border:      #1e2d3d;
  --text:        #e2e8f0;
  --text-muted:  #64748b;
  --accent:      #c89b3c;
  --gold:        #c89b3c;
  --green:       #22c55e;
  --yellow:      #f59e0b;
  --red:         #ef4444;
  --blue:        #3b82f6;
  --purple:      #a855f7;
  --font:        system-ui, -apple-system, sans-serif;
  --font-mono:   'SF Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
}

header {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo { font-size: 15px; font-weight: 600; color: var(--text); letter-spacing: -0.01em; }
.logo span { color: var(--gold); }

.header-right { display: flex; align-items: center; gap: 16px; }

.status { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-muted); }
.dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted); transition: background 0.3s; }
.dot.connected { background: var(--green); }
.dot.disconnected { background: var(--red); }
.dot.reconnecting { background: var(--yellow); animation: pulse 1s infinite; }

@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

main { padding: 24px; max-width: 1200px; margin: 0 auto; }

/* Server Status Banner */
.server-status-banner {
  background: rgba(239, 68, 68, 0.08);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: 8px;
  padding: 10px 16px;
  margin-bottom: 16px;
  font-size: 13px;
  color: var(--red);
  display: none;
}
.server-status-banner.visible { display: block; }
.server-status-banner .ssb-title { font-weight: 700; margin-bottom: 4px; }

/* Search */
.search-bar { display: flex; gap: 8px; margin-bottom: 24px; }
.search-bar input {
  flex: 1; background: var(--surface); border: 1px solid var(--border);
  color: var(--text); padding: 10px 16px; border-radius: 8px;
  font-size: 14px; font-family: var(--font); outline: none;
}
.search-bar input:focus { border-color: var(--gold); }
.search-bar input::placeholder { color: var(--text-muted); }
.search-bar button {
  background: var(--gold); color: #000; border: none; padding: 10px 20px;
  border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: var(--font);
}
.search-bar button:hover { opacity: 0.9; }
.search-bar button:disabled { opacity: 0.5; cursor: not-allowed; }

/* Recent Searches */
.recent-searches { margin-bottom: 24px; }
.recent-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; }
.recent-card {
  background: var(--card); border: 1px solid var(--border); border-radius: 8px;
  padding: 14px 16px; cursor: pointer; transition: border-color 0.15s, background 0.15s;
}
.recent-card:hover { border-color: var(--gold); background: rgba(200, 155, 60, 0.04); }
.recent-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.recent-name .tag { color: var(--text-muted); font-weight: 400; }
.recent-rank { font-size: 12px; color: var(--gold); margin-top: 4px; }
.recent-wr { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

/* Champion Rotation */
.rotation-section { margin-bottom: 24px; }
.rotation-grid {
  display: flex; flex-wrap: wrap; gap: 8px;
}
.rotation-champ { display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 64px; }
.rotation-champ img { width: 48px; height: 48px; border-radius: 8px; border: 2px solid var(--border); transition: border-color 0.15s; }
.rotation-champ:hover img { border-color: var(--gold); }
.rotation-champ-name { font-size: 10px; color: var(--text-muted); text-align: center; max-width: 64px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Profile Card */
.profile-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
  padding: 24px; margin-bottom: 24px; display: none;
}
.profile-card.visible { display: block; }
.profile-header { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
.profile-icon { width: 80px; height: 80px; border-radius: 50%; border: 3px solid var(--gold); }
.profile-info { flex: 1; }
.profile-info h2 { font-size: 22px; font-weight: 700; color: var(--text); }
.profile-info h2 span { color: var(--text-muted); font-weight: 400; font-size: 16px; }
.profile-info .level { font-size: 13px; color: var(--text-muted); }

.challenge-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--card); border: 1px solid var(--border); border-radius: 6px;
  padding: 4px 10px; font-size: 12px; color: var(--text-muted); margin-top: 6px;
}
.challenge-badge .cl-level { font-weight: 700; text-transform: uppercase; font-size: 11px; }
.challenge-badge .cl-level.IRON { color: #8B8B8B; }
.challenge-badge .cl-level.BRONZE { color: #CD7F32; }
.challenge-badge .cl-level.SILVER { color: #C0C0C0; }
.challenge-badge .cl-level.GOLD { color: var(--gold); }
.challenge-badge .cl-level.PLATINUM { color: #1FACC5; }
.challenge-badge .cl-level.DIAMOND { color: #A855F7; }
.challenge-badge .cl-level.MASTER { color: #F472B6; }
.challenge-badge .cl-level.GRANDMASTER { color: #EF4444; }
.challenge-badge .cl-level.CHALLENGER { color: #F59E0B; }

/* Ranked Cards */
.ranked-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; margin-bottom: 24px; }
.ranked-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 16px 20px; }
.ranked-card .queue { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
.ranked-card .tier { font-size: 20px; font-weight: 700; color: var(--gold); }
.ranked-card .lp { font-size: 14px; color: var(--text); margin-top: 4px; }
.ranked-card .winrate { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
.ranked-card .ranked-badges { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
.ranked-badge-item { font-size: 10px; padding: 2px 6px; border-radius: 3px; font-weight: 600; }
.ranked-badge-item.hot { background: rgba(239,68,68,0.15); color: var(--red); }
.ranked-badge-item.fresh { background: rgba(34,197,94,0.15); color: var(--green); }
.ranked-badge-item.vet { background: rgba(168,85,247,0.15); color: var(--purple); }
.wr-bar { height: 4px; border-radius: 2px; background: var(--red); margin-top: 8px; overflow: hidden; }
.wr-bar-fill { height: 100%; background: var(--green); border-radius: 2px; }

/* Champion Mastery */
.mastery-section { margin-bottom: 24px; }
.mastery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 10px; }
.mastery-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; display: flex; align-items: center; gap: 12px; }
.mastery-champ-icon { width: 48px; height: 48px; border-radius: 8px; border: 2px solid var(--border); flex-shrink: 0; }
.mastery-details { flex: 1; min-width: 0; }
.mastery-champ-name { font-size: 14px; font-weight: 600; color: var(--text); }
.mastery-champ-title { font-size: 11px; color: var(--text-muted); font-style: italic; }
.mastery-stats { display: flex; gap: 12px; margin-top: 4px; flex-wrap: wrap; }
.mastery-stat { font-size: 11px; color: var(--text-muted); }
.mastery-stat strong { color: var(--gold); font-weight: 600; }
.mastery-level-badge { background: var(--surface); border: 1px solid var(--gold); border-radius: 6px; padding: 4px 8px; font-size: 12px; font-weight: 700; color: var(--gold); text-align: center; flex-shrink: 0; }
.mastery-progress { height: 3px; border-radius: 2px; background: var(--border); margin-top: 6px; overflow: hidden; }
.mastery-progress-fill { height: 100%; background: var(--gold); border-radius: 2px; }

/* Live Game Banner */
.live-game-banner { background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(239,68,68,0.03)); border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; padding: 16px 20px; margin-bottom: 24px; display: none; }
.live-game-banner.visible { display: block; }
.live-game-title { font-size: 13px; font-weight: 700; color: var(--red); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); animation: pulse 1s infinite; }
.live-teams { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.live-team-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
.live-team-blue .live-team-label { color: var(--blue); }
.live-team-red .live-team-label { color: var(--red); }
.live-player { display: flex; align-items: center; gap: 6px; padding: 3px 0; font-size: 12px; }
.live-player img { width: 22px; height: 22px; border-radius: 3px; }
.live-player-spells { display: flex; gap: 1px; }
.live-player-spells img { width: 14px; height: 14px; border-radius: 2px; }

/* Performance Stats — Tabbed */
.stats-section { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 24px; display: none; overflow: hidden; }
.stats-section.visible { display: block; }
.stats-tabs { display: flex; border-bottom: 1px solid var(--border); }
.stats-tab { flex: 1; background: transparent; border: none; color: var(--text-muted); padding: 12px 16px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: var(--font); text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.15s; border-bottom: 2px solid transparent; }
.stats-tab:hover { color: var(--text); }
.stats-tab.active { color: var(--gold); border-bottom-color: var(--gold); }
.stats-panel { display: none; padding: 20px; }
.stats-panel.active { display: block; }
.so-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px 20px; }
.so-item { }
.so-label { font-size: 11px; color: var(--text-muted); }
.so-value { font-size: 18px; font-weight: 700; font-family: var(--font-mono); }
.so-value.green { color: var(--green); }
.so-value.red { color: var(--red); }
.so-value.gold { color: var(--gold); }
.so-streak { display: inline-flex; align-items: center; gap: 4px; margin-top: 12px; padding: 3px 10px; border-radius: 4px; font-size: 12px; font-weight: 700; font-family: var(--font-mono); }
.so-streak.win-streak { background: rgba(34,197,94,0.1); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }
.so-streak.loss-streak { background: rgba(239,68,68,0.1); color: var(--red); border: 1px solid rgba(239,68,68,0.2); }

/* Donut chart for roles */
.donut-wrap { display: flex; align-items: center; gap: 24px; }
.donut-svg { width: 140px; height: 140px; flex-shrink: 0; }
.donut-legend { display: flex; flex-direction: column; gap: 6px; }
.donut-legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; }
.donut-legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
.donut-legend-name { font-weight: 600; min-width: 56px; }
.donut-legend-pct { font-family: var(--font-mono); color: var(--text-muted); }
.donut-legend-games { font-size: 11px; color: var(--text-muted); }

/* Expanded champion cards */
.champ-expanded-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 12px; }
.ce-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 14px; transition: border-color 0.15s; }
.ce-card:hover { border-color: rgba(200,155,60,0.3); }
.ce-header { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.ce-icon { width: 48px; height: 48px; border-radius: 8px; border: 2px solid var(--border); flex-shrink: 0; }
.ce-name { font-size: 15px; font-weight: 700; }
.ce-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.ce-badges { display: flex; gap: 4px; margin-top: 4px; flex-wrap: wrap; }
.ce-badge { font-size: 9px; font-weight: 600; padding: 1px 6px; border-radius: 3px; }
.ce-wr-bar { height: 6px; border-radius: 3px; background: var(--red); overflow: hidden; margin-bottom: 8px; }
.ce-wr-fill { height: 100%; background: var(--green); border-radius: 3px; }
.ce-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
.ce-stat { text-align: center; }
.ce-stat-val { font-size: 14px; font-weight: 700; font-family: var(--font-mono); }
.ce-stat-label { font-size: 9px; color: var(--text-muted); text-transform: uppercase; }

/* Multi-kill badges */
.multikill-badges { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
.mk-badge { font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 3px; }
.mk-penta { background: rgba(200,155,60,0.2); color: var(--gold); }
.mk-quadra { background: rgba(168,85,247,0.15); color: var(--purple); }
.mk-triple { background: rgba(59,130,246,0.15); color: var(--blue); }

/* Damage breakdown bar */
.dmg-breakdown { display: flex; height: 6px; border-radius: 3px; overflow: hidden; margin-top: 8px; }
.dmg-phys { background: #ef4444; }
.dmg-magic { background: #3b82f6; }
.dmg-true { background: #f5f5f5; }
.dmg-legend { display: flex; gap: 12px; margin-top: 4px; font-size: 10px; color: var(--text-muted); }
.dmg-legend span::before { content: ''; display: inline-block; width: 8px; height: 8px; border-radius: 2px; margin-right: 4px; vertical-align: middle; }
.dmg-legend .dl-phys::before { background: #ef4444; }
.dmg-legend .dl-magic::before { background: #3b82f6; }
.dmg-legend .dl-true::before { background: #f5f5f5; }

/* Top Champions */
.top-champ-row { display: flex; align-items: center; gap: 8px; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
.top-champ-row:last-child { border-bottom: none; }
.top-champ-icon { width: 28px; height: 28px; border-radius: 4px; }
.top-champ-info { flex: 1; min-width: 0; }
.top-champ-name { font-size: 13px; font-weight: 600; }
.top-champ-wr { font-size: 11px; color: var(--text-muted); }
.top-champ-games { font-size: 12px; color: var(--text-muted); font-family: var(--font-mono); flex-shrink: 0; }
.top-champ-kda { font-size: 11px; color: var(--text-muted); font-family: var(--font-mono); flex-shrink: 0; min-width: 40px; text-align: right; }

/* Role Distribution */
.role-row { display: flex; align-items: center; gap: 10px; padding: 5px 0; }
.role-name { font-size: 12px; font-weight: 600; min-width: 60px; }
.role-bar-wrap { flex: 1; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
.role-bar-fill { height: 100%; border-radius: 3px; background: var(--gold); }
.role-pct { font-size: 12px; font-family: var(--font-mono); color: var(--text-muted); min-width: 32px; text-align: right; }

/* Extended Stats (Duo partners, WR chart, LP chart) */
.extended-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; display: none; }
.extended-stats.visible { display: grid; }
.ext-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 16px 20px; }
.ext-title { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }
/* LP Velocity */
.vel-row { display: flex; align-items: center; gap: 12px; margin-bottom: 6px; }
.vel-value { font-size: 22px; font-weight: 700; }
.vel-trend { font-size: 13px; text-transform: capitalize; }
.vel-predict { font-size: 12px; color: var(--text-muted); }
/* Personal Enemies */
.enemy-row { display: flex; align-items: center; gap: 8px; padding: 5px 0; border-bottom: 1px solid var(--border); }
.enemy-row:last-child { border-bottom: none; }
.enemy-champ { flex: 1; font-size: 13px; font-weight: 500; }
.enemy-games { font-size: 12px; }
.enemy-wr { font-size: 13px; font-weight: 700; min-width: 50px; text-align: right; }

.cb-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 12px; }
.cb-row:last-child { border-bottom: none; }
.cb-label { font-weight: 500; }
.cb-value { font-size: 15px; font-weight: 700; }
.cb-sub { font-size: 10px; color: var(--text-muted); text-align: right; }

/* Duo partner rows */
.duo-row { display: flex; align-items: center; gap: 8px; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 12px; }
.duo-row:last-child { border-bottom: none; }
.duo-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600; }
.duo-games { color: var(--text-muted); font-family: var(--font-mono); }
.duo-wr { font-family: var(--font-mono); min-width: 40px; text-align: right; }

/* WR Chart (simple CSS bars) */
.wr-chart { display: flex; align-items: flex-end; gap: 2px; height: 80px; }
.wr-chart-bar { flex: 1; min-width: 4px; border-radius: 2px 2px 0 0; position: relative; }
.wr-chart-bar.win { background: var(--green); }
.wr-chart-bar.loss { background: var(--red); }
.wr-chart-bar.mixed { background: var(--yellow); }
.wr-chart-labels { display: flex; justify-content: space-between; margin-top: 4px; font-size: 9px; color: var(--text-muted); }

/* LP Chart */
.lp-chart { display: flex; align-items: flex-end; gap: 1px; height: 60px; }
.lp-chart-bar { flex: 1; min-width: 3px; background: var(--gold); border-radius: 1px 1px 0 0; }

/* Rune icons */
.rune-icons { display: flex; gap: 2px; align-items: center; }
.rune-keystone { width: 22px; height: 22px; border-radius: 50%; }
.rune-tree { width: 14px; height: 14px; border-radius: 50%; opacity: 0.7; }

/* Match multi-kill indicator */
.match-mk { display: inline-block; font-size: 9px; font-weight: 700; padding: 1px 4px; border-radius: 2px; margin-left: 4px; }
.match-mk.penta { background: rgba(200,155,60,0.3); color: var(--gold); }
.match-mk.quadra { background: rgba(168,85,247,0.2); color: var(--purple); }
.match-mk.triple { background: rgba(59,130,246,0.2); color: var(--blue); }

/* Item tooltip */
.item-tooltip { position: relative; display: inline-block; }
.item-tooltip .tt-content {
  display: none; position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%);
  background: var(--surface); border: 1px solid var(--border); border-radius: 6px;
  padding: 6px 10px; font-size: 11px; white-space: nowrap; z-index: 50;
  pointer-events: none; margin-bottom: 4px;
}
.item-tooltip:hover .tt-content { display: block; }
.tt-name { font-weight: 600; color: var(--text); }
.tt-gold { color: var(--gold); font-family: var(--font-mono); }

/* Matches Section */
.section-title { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }
.table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
.table-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 10px; }
.table-title { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
.queue-tabs { display: flex; gap: 4px; flex-wrap: wrap; }
.match-filters { display: flex; gap: 6px; align-items: center; }
.match-filter-select { background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 4px 8px; border-radius: 4px; font-size: 11px; font-family: var(--font); cursor: pointer; outline: none; }
.match-filter-select:focus { border-color: var(--gold); }

/* Champion card enhancements */
.ce-dmg-bar { display: flex; height: 4px; border-radius: 2px; overflow: hidden; margin-top: 6px; }
.ce-dmg-bar .phys { background: #ef4444; }
.ce-dmg-bar .magic { background: #3b82f6; }
.ce-dmg-bar .true-d { background: #e2e8f0; }
.ce-dmg-legend { display: flex; gap: 8px; margin-top: 3px; font-size: 9px; color: var(--text-muted); }
.ce-runes { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 6px; }
.ce-rune-tag { display: inline-flex; align-items: center; gap: 3px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 4px; padding: 2px 6px; font-size: 9px; font-family: var(--font-mono); }
.ce-rune-tag img { width: 12px; height: 12px; border-radius: 50%; }

/* Pool depth badge */
.pool-badge { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 700; font-family: var(--font-mono); }
.pool-badge.one-trick { background: rgba(239,68,68,0.1); color: var(--red); }
.pool-badge.specialist { background: rgba(245,158,11,0.1); color: var(--yellow); }
.pool-badge.versatile { background: rgba(34,197,94,0.1); color: var(--green); }

/* Game length pref */
.pref-badge { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 700; font-family: var(--font-mono); background: rgba(59,130,246,0.1); color: var(--blue); }
.gl-bars { display: flex; gap: 12px; margin-top: 6px; }
.gl-bar { flex: 1; text-align: center; }
.gl-bar-label { font-size: 10px; color: var(--text-muted); margin-bottom: 3px; }
.gl-bar-val { font-size: 16px; font-weight: 700; font-family: var(--font-mono); }
.gl-bar-sub { font-size: 9px; color: var(--text-muted); }
.queue-tab { background: transparent; border: 1px solid var(--border); color: var(--text-muted); padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: 600; cursor: pointer; font-family: var(--font); transition: all 0.15s; }
.queue-tab:hover { border-color: var(--gold); color: var(--text); }
.queue-tab.active { background: var(--gold); color: #000; border-color: var(--gold); }

table { width: 100%; border-collapse: collapse; }
th { text-align: left; padding: 9px 12px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); white-space: nowrap; }
td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; font-size: 13px; }
tr:last-child td { border-bottom: none; }

.badge { display: inline-block; border-radius: 4px; padding: 2px 8px; font-family: var(--font-mono); font-size: 12px; border: 1px solid; font-weight: 600; }
.badge-win { background: rgba(34,197,94,0.08); color: var(--green); border-color: rgba(34,197,94,0.2); }
.badge-loss { background: rgba(239,68,68,0.08); color: var(--red); border-color: rgba(239,68,68,0.2); }
.badge-ff { font-size: 9px; color: var(--text-muted); margin-left: 2px; }

.kda { font-family: var(--font-mono); font-size: 13px; white-space: nowrap; }
.kda-perfect { color: var(--gold); }
.kda-good { color: var(--green); }
.kda-ok { color: var(--text); }
.kda-bad { color: var(--red); }

.muted { color: var(--text-muted); }
.col-champ { font-weight: 500; white-space: nowrap; }
.col-champ-wrap { display: flex; align-items: center; gap: 8px; }
.col-champ-icon { width: 28px; height: 28px; border-radius: 4px; }
.col-pos { font-size: 12px; color: var(--text-muted); text-transform: capitalize; }
.col-dmg { font-family: var(--font-mono); font-size: 12px; }
.col-gold { font-family: var(--font-mono); font-size: 12px; color: var(--gold); }
.col-cs { font-family: var(--font-mono); font-size: 12px; }
.col-vision { font-size: 12px; color: var(--text-muted); }
.col-duration { font-size: 12px; color: var(--text-muted); font-family: var(--font-mono); }

.item-row { display: flex; gap: 2px; flex-wrap: nowrap; }
.item-icon { width: 22px; height: 22px; border-radius: 3px; border: 1px solid var(--border); }
.item-empty { width: 22px; height: 22px; border-radius: 3px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); }

.spell-row { display: flex; gap: 2px; flex-direction: column; }
.spell-icon { width: 18px; height: 18px; border-radius: 2px; }

/* Match detail row */
.match-row { cursor: pointer; }
.match-row:hover td { background: rgba(200,155,60,0.05); }
.match-detail-row td { padding: 0 !important; border-bottom: 1px solid var(--border); background: transparent !important; }
.match-detail-row.hidden { display: none; }
.match-detail { padding: 16px 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; background: rgba(0,0,0,0.15); }
.team-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; padding-bottom: 4px; border-bottom: 1px solid var(--border); }
.team-label.ally { color: var(--blue); }
.team-label.enemy { color: var(--red); }
.team-player { display: flex; align-items: center; gap: 6px; padding: 5px 0; font-size: 12px; border-bottom: 1px solid rgba(255,255,255,0.03); }
.team-player:last-child { border-bottom: none; }
.team-player.is-me { font-weight: 600; color: var(--gold); }
.team-player-champ { display: flex; align-items: center; gap: 6px; min-width: 0; flex: 1; }
.team-player-icon { width: 24px; height: 24px; border-radius: 4px; flex-shrink: 0; }
.team-player-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
.team-player-spells { display: flex; gap: 1px; flex-shrink: 0; }
.team-player-spells img { width: 16px; height: 16px; border-radius: 2px; }
.team-player-items { display: flex; gap: 1px; flex-shrink: 0; }
.team-player-items img { width: 18px; height: 18px; border-radius: 2px; }
.team-player-items .item-empty-sm { width: 18px; height: 18px; border-radius: 2px; background: rgba(255,255,255,0.03); }
.team-player-stats { display: flex; gap: 10px; flex-shrink: 0; font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
.team-player-stats .stat-kda { min-width: 60px; }
.team-player-stats .stat-dmg { min-width: 42px; text-align: right; }
.team-player-stats .stat-cs { min-width: 30px; text-align: right; }
.team-player-stats .stat-gold { min-width: 42px; text-align: right; color: var(--gold); }

/* Damage bar in team view */
.team-dmg-bar { height: 3px; border-radius: 1px; overflow: hidden; display: flex; margin-top: 2px; }
.team-dmg-bar .phys { background: #ef4444; }
.team-dmg-bar .magic { background: #3b82f6; }
.team-dmg-bar .true-d { background: #f5f5f5; }

/* Tilt Detector Banner */
.tilt-banner {
  background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(239,68,68,0.04));
  border: 1px solid rgba(239,68,68,0.3);
  border-radius: 8px; padding: 14px 20px; margin-bottom: 16px; display: none;
}
.tilt-banner.visible { display: block; }
.tilt-title { font-size: 13px; font-weight: 700; color: var(--red); margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
.tilt-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.tilt-col { font-size: 12px; }
.tilt-col-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 4px; }
.tilt-stat { display: flex; justify-content: space-between; padding: 2px 0; }
.tilt-stat-name { color: var(--text-muted); }
.tilt-stat-val { font-family: var(--font-mono); font-weight: 600; }

/* Performance Score badge */
.perf-score { display: inline-block; font-size: 11px; font-weight: 700; font-family: var(--font-mono); padding: 2px 6px; border-radius: 4px; min-width: 32px; text-align: center; }
.perf-score.s-legendary { background: rgba(200,155,60,0.2); color: var(--gold); }
.perf-score.s-great { background: rgba(34,197,94,0.12); color: var(--green); }
.perf-score.s-good { background: rgba(59,130,246,0.12); color: var(--blue); }
.perf-score.s-ok { background: rgba(245,158,11,0.12); color: var(--yellow); }
.perf-score.s-bad { background: rgba(239,68,68,0.1); color: var(--red); }

/* Streak Timeline */
.streak-timeline { display: flex; gap: 1px; align-items: center; height: 20px; margin-top: 8px; }
.streak-block { height: 100%; min-width: 8px; flex: 1; border-radius: 2px; transition: opacity 0.15s; }
.streak-block:hover { opacity: 0.7; }
.streak-block.w { background: var(--green); }
.streak-block.l { background: var(--red); }

/* Day-of-Week WR */
.dow-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
.dow-cell { text-align: center; padding: 6px 2px; border-radius: 4px; background: var(--surface); }
.dow-cell-day { font-size: 9px; color: var(--text-muted); font-weight: 600; }
.dow-cell-wr { font-size: 13px; font-weight: 700; font-family: var(--font-mono); }
.dow-cell-games { font-size: 9px; color: var(--text-muted); }

/* Gold Efficiency indicator */
.gold-eff { font-size: 10px; color: var(--text-muted); }
.gold-eff-high { color: var(--green); }
.gold-eff-low { color: var(--red); }

/* Comeback badge */
.badge-comeback { font-size: 9px; font-weight: 700; padding: 1px 4px; border-radius: 2px; background: rgba(168,85,247,0.15); color: var(--purple); margin-left: 3px; }

/* Meta tag */
.meta-tag { font-size: 9px; padding: 1px 4px; border-radius: 2px; margin-left: 3px; font-weight: 600; }
.meta-tag.meta-std { background: rgba(34,197,94,0.1); color: var(--green); }
.meta-tag.meta-off { background: rgba(245,158,11,0.12); color: var(--yellow); }

/* Theme toggle */
.theme-toggle {
  background: transparent; border: 1px solid var(--border); color: var(--text-muted);
  width: 32px; height: 32px; border-radius: 6px; cursor: pointer; font-size: 16px;
  display: flex; align-items: center; justify-content: center; transition: border-color 0.15s;
}
.theme-toggle:hover { border-color: var(--gold); }

/* Light theme overrides */
body.light-theme {
  --bg: #f0f2f5;
  --surface: #ffffff;
  --card: #f8f9fb;
  --border: #e2e8f0;
  --text: #1a202c;
  --text-muted: #718096;
}
body.light-theme .toast { box-shadow: 0 4px 16px rgba(0,0,0,0.1); }
body.light-theme .dmg-true, body.light-theme .team-dmg-bar .true-d { background: #888; }

/* Radar chart */
.radar-wrap { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; }
.radar-svg { width: 200px; height: 200px; flex-shrink: 0; }
.radar-legend { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 16px; font-size: 11px; }
.radar-legend-item { display: flex; align-items: center; gap: 6px; }
.radar-legend-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
.radar-legend-name { color: var(--text-muted); }
.radar-legend-val { font-family: var(--font-mono); font-weight: 600; }

/* Win/Loss comparison */
.wl-compare { display: grid; grid-template-columns: 1fr auto 1fr; gap: 0; margin-top: 12px; }
.wl-col { }
.wl-header { text-align: center; font-size: 12px; font-weight: 700; padding: 8px; border-radius: 6px 6px 0 0; }
.wl-header.win { background: rgba(34,197,94,0.1); color: var(--green); }
.wl-header.loss { background: rgba(239,68,68,0.1); color: var(--red); }
.wl-divider { width: 1px; background: var(--border); }
.wl-row { display: flex; justify-content: space-between; padding: 5px 10px; font-size: 11px; border-bottom: 1px solid rgba(255,255,255,0.03); }
.wl-label { color: var(--text-muted); }
.wl-val { font-family: var(--font-mono); font-weight: 600; }

/* Matchup table */
.matchup-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 6px; }
.mu-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; display: flex; align-items: center; gap: 8px; }
.mu-icon { width: 28px; height: 28px; border-radius: 4px; flex-shrink: 0; }
.mu-info { flex: 1; min-width: 0; }
.mu-name { font-size: 11px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mu-wr { font-size: 10px; font-family: var(--font-mono); }
.mu-games { font-size: 9px; color: var(--text-muted); }

/* Advanced stat cards */
.adv-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; margin-bottom: 16px; }
.adv-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px; text-align: center; }
.adv-val { font-size: 18px; font-weight: 700; font-family: var(--font-mono); }
.adv-label { font-size: 10px; color: var(--text-muted); margin-top: 2px; }

/* Spell combo row */
.spell-combo-row { display: flex; align-items: center; gap: 8px; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 12px; }
.spell-combo-row:last-child { border-bottom: none; }
.spell-combo-icons { display: flex; gap: 2px; }
.spell-combo-icons img { width: 22px; height: 22px; border-radius: 3px; }
.spell-combo-games { color: var(--text-muted); font-family: var(--font-mono); }
.spell-combo-wr { font-family: var(--font-mono); font-weight: 600; min-width: 36px; text-align: right; }

/* Recent Form */
.recent-form { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; }
.rf-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.rf-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }
.rf-trend { font-size: 14px; font-weight: 700; }
.rf-trend.up { color: var(--green); }
.rf-trend.down { color: var(--red); }
.rf-trend.neutral { color: var(--text-muted); }
.rf-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 6px; }
.rf-stat { text-align: center; }
.rf-stat-val { font-family: var(--font-mono); font-weight: 600; font-size: 14px; }
.rf-stat-label { font-size: 9px; color: var(--text-muted); }
.rf-sparkline { margin-top: 8px; }
.rf-sparkline svg { width: 100%; height: 40px; }

/* Objectives Grid */
.obj-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 8px; margin-bottom: 12px; }
.obj-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 10px; text-align: center; }
.obj-icon { font-size: 18px; margin-bottom: 2px; }
.obj-val { font-size: 16px; font-weight: 700; font-family: var(--font-mono); }
.obj-label { font-size: 9px; color: var(--text-muted); margin-top: 1px; }
.obj-total { font-size: 9px; color: var(--text-muted); }

/* Early Game Section */
.early-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 8px; margin-bottom: 12px; }
.early-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 10px; text-align: center; }
.early-val { font-size: 18px; font-weight: 700; font-family: var(--font-mono); }
.early-label { font-size: 9px; color: var(--text-muted); margin-top: 1px; }

/* Snowball Meter */
.snowball-wrap { margin: 12px 0; }
.snowball-bar { height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.snowball-fill { height: 100%; border-radius: 4px; transition: width 0.3s; }
.snowball-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--text-muted); margin-top: 3px; }

/* Lane Matchups */
.lane-mu-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; display: flex; align-items: center; gap: 8px; }
.lane-mu-vs { display: flex; align-items: center; gap: 4px; font-size: 10px; color: var(--text-muted); margin-top: 2px; }
.lane-mu-vs .you { color: var(--blue); }
.lane-mu-vs .opp { color: var(--red); }

/* Synergy Cards */
.sy-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; display: flex; align-items: center; gap: 8px; }
.sy-icon { width: 28px; height: 28px; border-radius: 4px; flex-shrink: 0; }
.sy-info { flex: 1; min-width: 0; }
.sy-name { font-size: 11px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sy-wr { font-size: 10px; font-family: var(--font-mono); }
.sy-games { font-size: 9px; color: var(--text-muted); }

/* Common Items */
.items-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 6px; }
.item-stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 6px 8px; display: flex; align-items: center; gap: 8px; }
.item-stat-card img { width: 28px; height: 28px; border-radius: 4px; }
.item-stat-info { flex: 1; min-width: 0; }
.item-stat-name { font-size: 11px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.item-stat-sub { font-size: 10px; color: var(--text-muted); font-family: var(--font-mono); }

/* Section divider */
.stats-section-title { font-size: 12px; font-weight: 700; margin: 16px 0 8px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

/* Head-to-Head Comparison */
.h2h-section { margin-bottom: 24px; display: none; }
.h2h-section.visible { display: block; }
.h2h-search { display: flex; gap: 8px; margin-bottom: 16px; }
.h2h-search input { flex: 1; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 8px 14px; border-radius: 6px; font-size: 13px; font-family: var(--font); outline: none; }
.h2h-search input:focus { border-color: var(--gold); }
.h2h-search button { background: var(--blue); color: #fff; border: none; padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: var(--font); }
.h2h-search button:disabled { opacity: 0.5; cursor: not-allowed; }
.h2h-grid { display: grid; grid-template-columns: 1fr auto 1fr; gap: 12px; }
.h2h-col { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }
.h2h-vs { display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; color: var(--text-muted); }
.h2h-player-name { font-size: 16px; font-weight: 700; margin-bottom: 12px; text-align: center; }
.h2h-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 12px; border-bottom: 1px solid rgba(255,255,255,0.03); }
.h2h-row:last-child { border-bottom: none; }
.h2h-label { color: var(--text-muted); }
.h2h-val { font-family: var(--font-mono); font-weight: 600; }
.h2h-val.better { color: var(--green); }
.h2h-val.worse { color: var(--red); }

/* Enhanced Live Game */
.live-bans { display: flex; gap: 4px; margin-top: 8px; align-items: center; }
.live-bans-label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; margin-right: 4px; }
.live-ban-icon { width: 22px; height: 22px; border-radius: 3px; border: 1px solid var(--red); opacity: 0.6; }
.live-player-rank { font-size: 10px; color: var(--text-muted); margin-left: auto; font-family: var(--font-mono); }
.live-player-runes { display: flex; gap: 1px; margin-left: 2px; }
.live-player-runes img { width: 14px; height: 14px; border-radius: 50%; }
.live-queue-badge { font-size: 10px; padding: 2px 8px; border-radius: 3px; background: rgba(59,130,246,0.1); color: var(--blue); font-weight: 600; margin-left: 8px; }

/* Match Timeline */
.tl-container { padding: 16px 0; }
.tl-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
.tl-btn { background: var(--card); border: 1px solid var(--border); color: var(--text-muted); padding: 4px 12px; border-radius: 4px; font-size: 11px; cursor: pointer; font-family: var(--font); transition: all 0.15s; }
.tl-btn:hover { border-color: var(--gold); color: var(--text); }
.tl-btn.active { background: var(--gold); color: #000; border-color: var(--gold); }
.tl-events { max-height: 300px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
.tl-event { display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 11px; border-bottom: 1px solid rgba(255,255,255,0.03); }
.tl-event:last-child { border-bottom: none; }
.tl-time { min-width: 40px; font-family: var(--font-mono); color: var(--text-muted); font-size: 10px; }
.tl-icon { font-size: 14px; min-width: 18px; text-align: center; }
.tl-desc { flex: 1; }
.tl-kill { color: var(--red); }
.tl-objective { color: var(--gold); }
.tl-building { color: var(--blue); }
.tl-loading { text-align: center; color: var(--text-muted); font-size: 12px; padding: 16px 0; }
.tl-tabs { display: flex; gap: 4px; margin-bottom: 12px; }
.tl-tab { background: var(--card); border: 1px solid var(--border); color: var(--text-muted); padding: 3px 10px; border-radius: 4px; font-size: 10px; cursor: pointer; font-family: var(--font); }
.tl-tab.active { background: var(--gold); color: #000; border-color: var(--gold); }
.tl-panel { display: none; }
.tl-panel.active { display: block; }

/* Kill Map */
.kill-map-wrap { position: relative; width: 100%; max-width: 400px; margin: 0 auto; }
.kill-map-wrap svg { width: 100%; height: auto; }
.km-legend { display: flex; gap: 12px; justify-content: center; margin-top: 8px; font-size: 10px; color: var(--text-muted); }
.km-legend span { display: flex; align-items: center; gap: 4px; }
.km-legend .dot-kill { width: 8px; height: 8px; border-radius: 50%; background: var(--green); }
.km-legend .dot-death { width: 8px; height: 8px; border-radius: 50%; background: var(--red); }
.km-legend .dot-assist { width: 8px; height: 8px; border-radius: 50%; background: var(--blue); opacity: 0.5; }

/* Gold Difference Graph */
.gold-graph-wrap { width: 100%; max-width: 600px; margin: 8px auto; }
.gold-graph-wrap svg { width: 100%; height: auto; }
.gg-legend { display: flex; gap: 12px; justify-content: center; margin-top: 6px; font-size: 10px; color: var(--text-muted); }

/* LP Line Chart */
.lp-line-chart { position: relative; }
.lp-line-chart svg { width: 100%; height: auto; }
.lp-line-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--text-muted); margin-top: 4px; }

/* Team Comp Analysis */
.team-comp-analysis { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border); }
.tca-team { background: var(--card); border-radius: 6px; padding: 10px; }
.tca-title { font-size: 11px; font-weight: 600; margin-bottom: 8px; }
.tca-bar-wrap { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; font-size: 10px; }
.tca-bar-label { min-width: 50px; color: var(--text-muted); }
.tca-bar { flex: 1; height: 12px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; display: flex; }
.tca-bar .phys { background: #ef4444; }
.tca-bar .magic { background: #3b82f6; }
.tca-bar .true-d { background: #f5f5f5; }
.tca-pct { min-width: 30px; text-align: right; font-family: var(--font-mono); }
.tca-roles { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 6px; }
.tca-role-tag { font-size: 9px; padding: 1px 6px; border-radius: 3px; background: rgba(255,255,255,0.06); color: var(--text-muted); }

/* Activity Heatmap */
.heatmap-grid { display: grid; grid-template-columns: 32px repeat(24, 1fr); gap: 2px; }
.heatmap-cell { aspect-ratio: 1; border-radius: 2px; min-width: 0; min-height: 12px; }
.heatmap-day { font-size: 9px; color: var(--text-muted); display: flex; align-items: center; justify-content: flex-end; padding-right: 4px; }
.heatmap-hours { display: contents; }
.heatmap-hour-label { font-size: 8px; color: var(--text-muted); text-align: center; }

/* Loading */
.loading { text-align: center; padding: 40px; color: var(--text-muted); }
.loading.hidden { display: none; }

/* Error */
.error-msg { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); color: var(--red); padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; display: none; font-size: 13px; }
.error-msg.visible { display: block; }

/* Toast */
#toast-container { position: fixed; bottom: 24px; right: 24px; display: flex; flex-direction: column; gap: 8px; z-index: 1000; }
.toast { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 11px 15px; font-size: 13px; max-width: 380px; box-shadow: 0 4px 16px rgba(0,0,0,0.4); animation: slideIn 0.2s ease-out; transition: opacity 0.35s; }
.toast.fade-out { opacity: 0; }
.toast-success { border-left: 3px solid var(--green); }
.toast-info    { border-left: 3px solid var(--blue); }
.toast-error   { border-left: 3px solid var(--red); }
.toast-gold    { border-left: 3px solid var(--gold); }

@keyframes slideIn { from { transform: translateX(110%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
@keyframes flashGold { 0% { background: rgba(200,155,60,0.12); } 100% { background: transparent; } }
tr.highlight td { animation: flashGold 2.5s ease-out forwards; }

/* Region Selector (#17) */
.region-select { background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 10px 8px; border-radius: 8px; font-size: 13px; font-family: var(--font); outline: none; min-width: 80px; }
.region-select:focus { border-color: var(--gold); }

/* Favorites (#18) */
.fav-btn { background: none; border: none; cursor: pointer; font-size: 20px; padding: 2px 6px; line-height: 1; transition: transform 0.15s; }
.fav-btn:hover { transform: scale(1.2); }
.fav-btn.active { color: var(--gold); }
/* recent-select inline style defined inline */
.fav-section { margin-bottom: 24px; }
.fav-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
.fav-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; cursor: pointer; transition: border-color 0.15s; position: relative; }
.fav-card:hover { border-color: var(--gold); }
.fav-card .fav-name { font-weight: 600; font-size: 13px; }
.fav-card .fav-rank { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.fav-card .fav-remove { position: absolute; top: 6px; right: 8px; background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 14px; }
.fav-card .fav-remove:hover { color: var(--red); }

/* Goals (#26) */
.goals-section { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 14px; margin-bottom: 16px; }
.goals-section .section-title { margin-bottom: 10px; }
.goal-list { display: flex; flex-direction: column; gap: 6px; }
.goal-item { display: flex; align-items: center; gap: 8px; padding: 6px 8px; background: rgba(255,255,255,0.03); border-radius: 4px; font-size: 12px; }
.goal-item.completed { opacity: 0.5; text-decoration: line-through; }
.goal-type { font-weight: 600; min-width: 60px; color: var(--gold); font-size: 10px; text-transform: uppercase; }
.goal-target { flex: 1; }
.goal-progress { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
.goal-actions { display: flex; gap: 4px; }
.goal-actions button { background: none; border: none; cursor: pointer; font-size: 12px; color: var(--text-muted); padding: 2px 4px; }
.goal-actions button:hover { color: var(--text); }
.goal-add { display: flex; gap: 6px; margin-top: 8px; }
.goal-add select, .goal-add input { background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 4px 8px; border-radius: 4px; font-size: 12px; font-family: var(--font); }
.goal-add select { min-width: 80px; }
.goal-add input { flex: 1; }
.goal-add button { background: var(--gold); color: #000; border: none; padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 600; cursor: pointer; }

/* Match Notes (#27) */
.match-note { margin-top: 8px; padding: 6px 8px; background: rgba(200,155,60,0.06); border-left: 2px solid var(--gold); border-radius: 0 4px 4px 0; font-size: 11px; color: var(--text-muted); }
.match-note-input { width: 100%; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 4px 8px; border-radius: 4px; font-size: 11px; font-family: var(--font); margin-top: 4px; }

/* Build Recommendations (#20) */
.build-recs { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; }
.build-rec-card { background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 10px; }
.build-rec-champ { font-weight: 600; font-size: 12px; margin-bottom: 6px; }
.build-rec-items { display: flex; gap: 3px; margin-bottom: 4px; }
.build-rec-items img { width: 28px; height: 28px; border-radius: 4px; }
.build-rec-stats { font-size: 10px; color: var(--text-muted); }

/* Rank Percentile (#21) */
.rank-pct { font-size: 11px; color: var(--text-muted); margin-top: 4px; }
.rank-pct-bar { height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; margin-top: 3px; overflow: hidden; }
.rank-pct-fill { height: 100%; background: var(--gold); border-radius: 2px; transition: width 0.5s; }

/* Patch Impact (#25) */
.patch-impact { display: flex; flex-wrap: wrap; gap: 8px; }
.patch-card { background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 8px 12px; font-size: 12px; display: flex; align-items: center; gap: 8px; }
.patch-diff { font-weight: 700; font-family: var(--font-mono); }
.patch-diff.up { color: var(--green); }
.patch-diff.down { color: var(--red); }

/* Champion Recommendations (#29) */
.champ-recs { display: flex; flex-direction: column; gap: 6px; }
.champ-rec { display: flex; align-items: center; gap: 8px; padding: 6px 8px; background: rgba(255,255,255,0.03); border-radius: 4px; }
.champ-rec img { width: 28px; height: 28px; border-radius: 6px; }
.champ-rec-name { font-weight: 600; font-size: 12px; }
.champ-rec-reason { font-size: 10px; color: var(--text-muted); }

/* Compare Mode (#19) */
.compare-section { margin-bottom: 20px; }
.compare-bar { display: flex; gap: 6px; margin-bottom: 12px; }
.compare-bar input { flex: 1; background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 6px 12px; border-radius: 6px; font-size: 13px; font-family: var(--font); }
.compare-bar button { background: var(--gold); color: #000; border: none; padding: 6px 16px; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 13px; }
.compare-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.compare-table th { text-align: center; padding: 8px; background: var(--surface); border: 1px solid var(--border); font-size: 11px; }
.compare-table td { text-align: center; padding: 6px 8px; border: 1px solid var(--border); }
.compare-table td.best { background: rgba(34,197,94,0.08); color: var(--green); font-weight: 600; }
.compare-table .compare-name { font-weight: 600; }

/* Export (#24) */
.export-btn { background: var(--card); border: 1px solid var(--border); color: var(--text-muted); padding: 4px 12px; border-radius: 4px; font-size: 11px; cursor: pointer; font-family: var(--font); transition: all 0.15s; }
.export-btn:hover { border-color: var(--gold); color: var(--text); }

/* Push Notifications (#22) */
.notif-toggle { background: none; border: 1px solid var(--border); color: var(--text-muted); padding: 3px 10px; border-radius: 4px; font-size: 10px; cursor: pointer; }
.notif-toggle.active { background: var(--gold); color: #000; border-color: var(--gold); }

/* Mobile Layout (#23) - Enhanced */
@media (max-width: 768px) {
  main { padding: 12px; }
  header { padding: 0 12px; height: 48px; }
  .search-bar { flex-wrap: wrap; }
  .search-bar input { min-width: 0; }
  .region-select { width: 100%; }
  .recent-grid { grid-template-columns: 1fr; }
  .fav-grid { grid-template-columns: 1fr; }
  .ranked-grid { grid-template-columns: 1fr; }
  .mastery-grid { grid-template-columns: 1fr; }
  .so-grid { grid-template-columns: 1fr 1fr; }
  .donut-wrap { flex-direction: column; align-items: center; }
  .champ-expanded-grid { grid-template-columns: 1fr; }
  .ce-stats { grid-template-columns: repeat(3, 1fr); }
  .extended-stats.visible { grid-template-columns: 1fr; }
  .live-teams { grid-template-columns: 1fr; }
  table { font-size: 11px; }
  th, td { padding: 6px 4px; }
  .col-cs, .col-gold, .col-vision, .col-pos { display: none; }
  .match-detail { grid-template-columns: 1fr; }
  .team-comp-analysis { grid-template-columns: 1fr; }
  .team-player-items { display: none; }
  .team-player-spells { display: none; }
  .queue-tabs { flex-wrap: wrap; }
  .stats-tabs { flex-wrap: wrap; }
  .stats-tab { font-size: 11px; padding: 4px 8px; }
  .rotation-champ img { width: 36px; height: 36px; }
  .rotation-champ { min-width: 48px; }
  .h2h-grid { grid-template-columns: 1fr; }
  .h2h-vs { padding: 8px 0; }
  .item-row { gap: 1px; }
  .item-icon { width: 20px; height: 20px; }
  .build-recs { grid-template-columns: 1fr; }
  .compare-bar { flex-wrap: wrap; }
  .compare-bar input { min-width: 100%; }
  .goals-section { padding: 10px; }
  .goal-add { flex-wrap: wrap; }
  .kill-map-wrap { max-width: 100%; }
  .gold-graph-wrap { max-width: 100%; }
}

@media (max-width: 480px) {
  .search-bar { gap: 4px; }
  header { height: 44px; }
  .logo { font-size: 13px; }
  .col-dmg { display: none; }
  .match-filters { flex-direction: column; }
  .match-filter-select { width: 100%; }
  .rune-icons { display: none; }
  /* Match rows as cards on very small screens (#19) */
  .matches-table thead { display: none; }
  .matches-table tr { display: flex; flex-direction: column; margin-bottom: 8px; border: 1px solid var(--border); border-radius: 6px; padding: 8px; }
  .matches-table td { display: flex; justify-content: space-between; padding: 2px 0; border: none; }
  .matches-table td::before { content: attr(data-label); font-weight: 600; color: var(--text-muted); margin-right: 8px; }
  .profile-card { padding: 12px; }
  .so-grid { grid-template-columns: 1fr; }
  .section-tabs { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .section-tab { white-space: nowrap; }
}

/* Quick Win: Autocomplete dropdown */
.ac-dropdown {
  position: absolute; top: 100%; left: 0; right: 0; z-index: 200;
  background: var(--surface); border: 1px solid var(--border); border-radius: 0 0 8px 8px;
  max-height: 280px; overflow-y: auto; display: none;
}
.ac-dropdown.visible { display: block; }
.ac-item {
  padding: 8px 16px; cursor: pointer; font-size: 13px; display: flex; justify-content: space-between; align-items: center;
}
.ac-item:hover, .ac-item.active { background: rgba(200,155,60,0.1); }
.ac-item .ac-name { font-weight: 600; }
.ac-item .ac-meta { font-size: 11px; color: var(--text-muted); }
.search-bar { position: relative; }

/* Quick Win: My Dashboard button */
.my-dash-btn {
  background: var(--card); border: 1px solid var(--border); color: var(--text-muted);
  padding: 10px 14px; border-radius: 8px; font-size: 12px; cursor: pointer; font-family: var(--font); white-space: nowrap;
}
.my-dash-btn:hover { border-color: var(--gold); color: var(--text); }
.my-dash-btn.saved { border-color: var(--gold); color: var(--gold); }

/* Quick Win: Win Condition Tags */
.wc-tag {
  display: inline-block; font-size: 9px; padding: 1px 5px; border-radius: 3px; font-weight: 600; margin-left: 4px; vertical-align: middle;
}
.wc-snowball { background: rgba(59,130,246,0.15); color: var(--blue); }
.wc-comeback { background: rgba(168,85,247,0.15); color: var(--purple); }
.wc-vision-carry { background: rgba(34,197,94,0.15); color: var(--green); }
.wc-kda-player { background: rgba(200,155,60,0.15); color: var(--gold); }
.wc-stomp { background: rgba(239,68,68,0.15); color: var(--red); }
.wc-team-fight { background: rgba(34,197,94,0.15); color: var(--green); }

/* Quick Win: Playstyle badge */
.playstyle-badge {
  display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px;
  background: rgba(200,155,60,0.08); border: 1px solid rgba(200,155,60,0.2);
  border-radius: 8px; font-size: 12px;
}
.playstyle-icon { font-size: 16px; }
.playstyle-name { font-weight: 700; color: var(--gold); }
.playstyle-desc { font-size: 10px; color: var(--text-muted); }

/* Quick Win: Tilt meter */
.tilt-meter { margin-top: 8px; }
.tilt-bar { height: 8px; border-radius: 4px; background: rgba(255,255,255,0.05); overflow: hidden; }
.tilt-bar-fill { height: 100%; border-radius: 4px; transition: width 0.5s; }
.tilt-label { display: flex; justify-content: space-between; font-size: 10px; margin-top: 2px; }

/* Quick Win: Compact match cards */
.match-cards-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px;
}
.match-card-compact {
  background: var(--card); border: 1px solid var(--border); border-radius: 8px;
  padding: 10px; cursor: pointer; transition: border-color 0.15s;
}
.match-card-compact:hover { border-color: var(--gold); }
.match-card-compact.win { border-left: 3px solid var(--green); }
.match-card-compact.loss { border-left: 3px solid var(--red); }
.mcc-top { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.mcc-champ { width: 32px; height: 32px; border-radius: 6px; }
.mcc-kda { font-size: 12px; font-weight: 600; }
.mcc-meta { font-size: 10px; color: var(--text-muted); }

/* Quick Win: Post-game actions */
.post-game-actions { display: flex; gap: 6px; padding: 8px 20px; border-top: 1px solid var(--border); }
.pg-btn {
  background: var(--card); border: 1px solid var(--border); color: var(--text-muted);
  padding: 4px 10px; border-radius: 4px; font-size: 10px; cursor: pointer; font-family: var(--font);
}
.pg-btn:hover { border-color: var(--gold); color: var(--text); }

/* Quick Win: View toggle */
.view-toggle { display: flex; gap: 2px; }
.view-toggle-btn {
  background: var(--card); border: 1px solid var(--border); color: var(--text-muted);
  padding: 4px 8px; font-size: 11px; cursor: pointer;
}
.view-toggle-btn:first-child { border-radius: 4px 0 0 4px; }
.view-toggle-btn:last-child { border-radius: 0 4px 4px 0; }
.view-toggle-btn.active { background: var(--gold); color: #000; border-color: var(--gold); }
</style>
{{end}}

{{block body()}}
<header>
  <div class="logo">League <span>Client</span></div>
  <div class="header-right">
    <button class="theme-toggle" id="theme-toggle" title="Toggle theme">&#9790;</button>
    <div class="status">
      <div class="dot" id="status-dot"></div>
      <span id="status-text">Connecting...</span>
    </div>
  </div>
</header>

<main>
  <!-- Server Status -->
  <div class="server-status-banner" id="server-status"></div>

  <div id="multi-search-container" style="display:none;margin-bottom:16px;">
    <div class="ext-title">Multi-Search (Lobby)</div>
    <textarea id="multi-search-input" placeholder="Paste lobby names, one per line (Name#Tag)" rows="5" style="width:100%;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:10px;border-radius:8px;font-family:var(--font);font-size:13px;resize:vertical;"></textarea>
    <button onclick="doMultiSearch()" style="margin-top:8px;background:var(--blue);color:#fff;border:none;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:13px;">Scout Lobby</button>
    <div id="multi-search-results" style="margin-top:12px;"></div>
  </div>

  <div class="search-bar">
    <select class="region-select" id="region-select">
      <option value="RU">RU</option>
      <option value="EUW1">EUW</option>
      <option value="EUN1">EUNE</option>
      <option value="NA1">NA</option>
      <option value="KR">KR</option>
      <option value="JP1">JP</option>
      <option value="BR1">BR</option>
      <option value="LA1">LAN</option>
      <option value="LA2">LAS</option>
      <option value="OC1">OCE</option>
      <option value="TR1">TR</option>
      <option value="PH2">PH</option>
      <option value="SG2">SG</option>
      <option value="TH2">TH</option>
      <option value="TW2">TW</option>
      <option value="VN2">VN</option>
    </select>
    <select id="recent-select" style="display:none;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:10px 8px;border-radius:8px;font-size:13px;font-family:var(--font);outline:none;min-width:160px;max-width:220px;">
      <option value="">Recent searches...</option>
    </select>
    <input type="text" id="search-input" placeholder="Search player... (e.g. Faker#KR1)" autocomplete="off" />
    <button id="btn-search">Search</button>
    <button class="my-dash-btn" id="my-dash-btn" title="Set as My Dashboard">My</button>
    <div class="ac-dropdown" id="ac-dropdown"></div>
  </div>

  <div class="error-msg" id="error-msg"></div>
  <div class="loading hidden" id="loading">Searching...</div>

  <div class="fav-section" id="fav-section" style="display:none;">
    <div class="section-title">Favorites</div>
    <div class="fav-grid" id="fav-grid"></div>
  </div>

  <div class="profile-card" id="profile-card">
    <div class="profile-header">
      <img class="profile-icon" id="profile-icon" src="" alt="icon" />
      <div class="profile-info">
        <h2 id="profile-name">Name <span id="profile-tag">#TAG</span></h2>
        <div class="level" id="profile-level">Level —</div>
        <div id="profile-rank-pct"></div>
        <div id="profile-challenges"></div>
      </div>
      <div style="margin-left:auto;display:flex;gap:6px;align-items:flex-start;">
        <button class="fav-btn" id="fav-toggle" title="Add to favorites">&#9734;</button>
        <button class="export-btn" id="export-btn" title="Export profile as text">Export</button>
        <button class="export-btn" id="export-csv-btn" title="Export matches as CSV">CSV</button>
        <button class="notif-toggle" id="notif-toggle" title="Browser notifications">&#128276; Notify</button>
      </div>
    </div>
    <div class="ranked-grid" id="ranked-grid"></div>
    <div class="mastery-section">
      <div class="section-title">Champion Mastery</div>
      <div class="mastery-grid" id="mastery-grid"></div>
    </div>
  </div>

  <div class="live-game-banner" id="live-game-banner">
    <div class="live-game-title"><div class="live-dot"></div> <span id="live-game-mode">IN GAME</span></div>
    <div class="live-teams" id="live-teams"></div>
  </div>

  <div class="stats-section" id="stats-section">
    <div class="stats-tabs" id="stats-tabs">
      <button class="stats-tab active" data-panel="panel-overview">Overview</button>
      <button class="stats-tab" data-panel="panel-champions">Champions</button>
      <button class="stats-tab" data-panel="panel-roles">Roles</button>
      <button class="stats-tab" data-panel="panel-advanced">Advanced</button>
      <button class="stats-tab" data-panel="panel-matchups">Matchups</button>
      <button class="stats-tab" data-panel="panel-items">Items</button>
      <button class="stats-tab" data-panel="panel-synergy">Synergy</button>
      <button class="stats-tab" data-panel="panel-builds">Builds</button>
      <button class="stats-tab" data-panel="panel-insights">Insights</button>
    </div>
    <div class="stats-panel active" id="panel-overview"></div>
    <div class="stats-panel" id="panel-champions"></div>
    <div class="stats-panel" id="panel-roles"></div>
    <div class="stats-panel" id="panel-advanced"></div>
    <div class="stats-panel" id="panel-matchups"></div>
    <div class="stats-panel" id="panel-items"></div>
    <div class="stats-panel" id="panel-synergy"></div>
    <div class="stats-panel" id="panel-builds"></div>
    <div class="stats-panel" id="panel-insights"></div>
  </div>

  <div class="extended-stats" id="extended-stats">
    <div class="ext-card" id="ext-duo"></div>
    <div class="ext-card" id="ext-wr-chart"></div>
    <div class="ext-card" id="ext-dow-wr"></div>
    <div class="ext-card" id="ext-streak-timeline"></div>
    <div class="ext-card" id="ext-heatmap" style="grid-column:1/-1;"></div>
    <div class="ext-card" id="ext-lp-chart" style="grid-column:1/-1;"></div>
    <div class="ext-card" id="ext-lp-velocity"></div>
    <div class="ext-card" id="ext-personal-enemies"></div>
    <div class="ext-card" id="ext-comeback"></div>
    <div class="ext-card" id="ext-records"></div>
    <div class="ext-card" id="ext-season-history"></div>
    <div class="ext-card" id="ext-session-summary"></div>
    <div class="ext-card" id="ext-queue-breakdown"></div>
    <div class="ext-card" id="ext-role-dist"></div>
    <div class="ext-card" id="ext-damage-profile"></div>
    <div class="ext-card" id="ext-duration-analysis"></div>
    <div class="ext-card" id="ext-best-time"></div>
    <div class="ext-card" id="ext-surrender-stats"></div>
    <div class="ext-card" id="ext-spell-analysis"></div>
    <div class="ext-card" id="ext-vision-trend"></div>
    <div class="ext-card" id="ext-peer-percentiles"></div>
    <div class="ext-card" id="ext-early-game"></div>
    <div class="ext-card" id="ext-objectives"></div>
    <div class="ext-card" id="ext-tilt-score"></div>
    <div class="ext-card" id="ext-playstyle"></div>
  </div>

  <div class="tilt-banner" id="tilt-banner"></div>

  <div class="goals-section" id="goals-section" style="display:none;">
    <div class="section-title">Goals</div>
    <div class="goal-list" id="goal-list"></div>
    <div class="goal-add" id="goal-add">
      <select id="goal-type-select">
        <option value="rank">Rank</option>
        <option value="winrate">Win Rate %</option>
        <option value="kda">KDA</option>
        <option value="mastery">Mastery</option>
        <option value="custom">Custom</option>
      </select>
      <input type="text" id="goal-target-input" placeholder="Target (e.g. Gold I, 55%, 3.0)" />
      <button id="goal-add-btn">Add</button>
    </div>
  </div>

  <div class="h2h-section" id="h2h-section">
    <div class="section-title">Head-to-Head Comparison</div>
    <div class="h2h-search">
      <input type="text" id="h2h-input" placeholder="Compare with... (e.g. Player#TAG)" />
      <button id="h2h-btn">Compare</button>
    </div>
    <div id="h2h-content"></div>
  </div>

  <div class="compare-section" id="compare-section" style="display:none;">
    <div class="section-title">Compare Players</div>
    <div class="compare-bar">
      <input type="text" id="compare-input" placeholder="Add player... (Name#TAG)" />
      <button id="compare-add-btn">Add</button>
    </div>
    <div id="compare-content"></div>
  </div>

  <div class="table-wrap" id="matches-section" style="display:none;">
    <div class="table-header">
      <div class="table-title">Recent Matches</div>
      <div class="queue-tabs" id="queue-tabs">
        <button class="queue-tab active" data-filter="all">All</button>
        <button class="queue-tab" data-filter="solo">Solo/Duo</button>
        <button class="queue-tab" data-filter="flex">Flex</button>
        <button class="queue-tab" data-filter="aram">ARAM</button>
        <button class="queue-tab" data-filter="other">Other</button>
      </div>
      <div class="match-filters">
        <select class="match-filter-select" id="champ-filter"><option value="">All Champions</option></select>
        <select class="match-filter-select" id="duration-filter">
          <option value="">Any Duration</option>
          <option value="short">&lt; 25 min</option>
          <option value="mid">25-35 min</option>
          <option value="long">&gt; 35 min</option>
        </select>
        <div class="view-toggle" id="view-toggle">
          <button class="view-toggle-btn active" data-view="table" title="Table view">&#9776;</button>
          <button class="view-toggle-btn" data-view="cards" title="Card view">&#9638;</button>
        </div>
      </div>
    </div>
    <div class="match-cards-grid" id="match-cards-grid" style="display:none;"></div>
    <table>
      <thead>
        <tr>
          <th>Result</th>
          <th>Champion</th>
          <th>KDA</th>
          <th>Score</th>
          <th>Items</th>
          <th>CS</th>
          <th>Damage</th>
          <th>Gold</th>
          <th>Vision</th>
          <th>Pos</th>
          <th>Time</th>
        </tr>
      </thead>
      <tbody id="matches-list"></tbody>
    </table>
  </div>

  <div class="rotation-section" id="rotation-section" style="display:none;">
    <div class="section-title">Free Champion Rotation</div>
    <div class="rotation-grid" id="rotation-grid"></div>
  </div>
</main>

<div id="toast-container"></div>
{{end}}

{{block scripts()}}
<script>
(function () {
  'use strict';

  var WS_URL = (location.protocol === 'https:' ? 'wss:' : 'ws:') + '//' + location.host + '/ws/updates';
  var ws = null;
  var reconnectDelay = 1000;
  var MAX_DELAY = 30000;
  var currentDdVersion = '14.5.1';
  var allMatches = [];
  var currentFilter = 'all';
  var currentPuuid = null;
  var itemData = {};
  var runeData = {};
  var currentPlayerData = null;
  var timelineCache = {};

  var SPELL_MAP = {
    1:'SummonerBoost',3:'SummonerExhaust',4:'SummonerFlash',
    6:'SummonerHaste',7:'SummonerHeal',11:'SummonerSmite',
    12:'SummonerTeleport',14:'SummonerDot',21:'SummonerBarrier',
    32:'SummonerSnowball',39:'SummonerSnowURFSnowball_Mark',
    2202:'SummonerCherryFlash',2201:'SummonerCherryHold'
  };

  function spellImg(id) { var n=SPELL_MAP[id]; return n ? 'https://ddragon.leagueoflegends.com/cdn/'+currentDdVersion+'/img/spell/'+n+'.png' : ''; }
  function itemImg(id) { return (id && id>0) ? 'https://ddragon.leagueoflegends.com/cdn/'+currentDdVersion+'/img/item/'+id+'.png' : ''; }

  function queueCategory(m) {
    if (m.queue_id===420) return 'solo';
    if (m.queue_id===440) return 'flex';
    if (m.game_mode==='ARAM'||m.queue_id===450||m.queue_id===900) return 'aram';
    return 'other';
  }
  function queueLabel(m) {
    if (m.queue_id===420) return 'Solo/Duo';
    if (m.queue_id===440) return 'Flex';
    if (m.game_mode==='ARAM') return 'ARAM';
    if (m.queue_id===900) return 'ARURF';
    if (m.queue_id===1700) return 'Arena';
    if (m.queue_id===490) return 'Quick Play';
    return m.game_mode||'Normal';
  }

  // ── Performance Score ─────────────────────────────
  function computePerfScore(m) {
    var k=m.kills||0, d=m.deaths||0, a=m.assists||0;
    var kdaRatio=d===0?(k+a)*1.5:(k+a)/d;
    var csMin=m.cs_per_min||0;
    var kp=m.kill_participation||0;
    var ds=m.damage_share||0;
    var dur=m.game_duration_raw||0;
    var vsMin=dur>0?(m.vision_score||0)/(dur/60):0;

    var kdaScore=Math.min(kdaRatio/6*3.0, 3.0);
    var csScore=Math.min(csMin/9*1.5, 1.5);
    var kpScore=Math.min(kp/0.7*1.5, 1.5);
    var dsScore=Math.min(ds/0.3*1.0, 1.0);
    var vsScore=Math.min(vsMin/1.5*1.0, 1.0);
    var winBonus=m.win?2.0:0;

    return Math.min(Math.round((kdaScore+csScore+kpScore+dsScore+vsScore+winBonus)*10)/10, 10.0);
  }

  function scoreClass(s) {
    if (s>=8) return 's-legendary';
    if (s>=6) return 's-great';
    if (s>=4) return 's-good';
    if (s>=2.5) return 's-ok';
    return 's-bad';
  }

  // ── Theme Toggle (#11) ───────────────────────────
  function initTheme() {
    var saved=localStorage.getItem('lc-theme');
    if (saved==='light') {
      document.body.classList.add('light-theme');
    } else if (!saved && window.matchMedia && !window.matchMedia('(prefers-color-scheme: dark)').matches) {
      document.body.classList.add('light-theme');
    }
    updateThemeIcon();
  }
  function toggleTheme() {
    document.body.classList.toggle('light-theme');
    localStorage.setItem('lc-theme', document.body.classList.contains('light-theme')?'light':'dark');
    updateThemeIcon();
  }
  function updateThemeIcon() {
    var btn=document.getElementById('theme-toggle');
    btn.innerHTML=document.body.classList.contains('light-theme')?'&#9728;':'&#9790;';
  }

  // ── Gold Efficiency (#13) ──────────────────────────
  function goldEffPct(m) {
    if (!m.gold_earned||m.gold_earned===0) return 0;
    return Math.round((m.gold_spent||0)/m.gold_earned*100);
  }

  // ── Comeback Detection (#15) ───────────────────────
  // A "comeback" = win where team was down in gold (proxy: player had below-avg gold but won)
  function isComeback(m, avgGold) {
    return m.win && m.gold_earned < avgGold * 0.85;
  }

  // ── Meta Compliance (#16) ──────────────────────────
  // Compare player's keystone to most common keystone for that champion across all matches
  var champKeystoneMap = {};
  function buildMetaMap(matches) {
    champKeystoneMap = {};
    // Count keystones per champion from all team participants
    for (var i=0;i<matches.length;i++) {
      var teams = (matches[i].allies||[]).concat(matches[i].enemies||[]);
      for (var j=0;j<teams.length;j++) {
        var p=teams[j];
        if (!p.champion_name||!p.perks_keystone) continue;
        if (!champKeystoneMap[p.champion_name]) champKeystoneMap[p.champion_name]={};
        var ks=p.perks_keystone;
        champKeystoneMap[p.champion_name][ks]=(champKeystoneMap[p.champion_name][ks]||0)+1;
      }
    }
  }
  function isMetaRune(champName, keystoneId) {
    var map=champKeystoneMap[champName];
    if (!map||!keystoneId) return null; // unknown
    var best=0, bestId=0;
    for (var k in map) { if(map[k]>best){best=map[k];bestId=parseInt(k);} }
    return keystoneId===bestId;
  }

  // ── Connection ─────────────────────────────────────
  function connect() {
    try { ws = new WebSocket(WS_URL); } catch(_) { scheduleReconnect(); return; }
    ws.onopen = function() { reconnectDelay=1000; setStatus('connected','Connected'); };
    ws.onmessage = function(e) {
      var outer; try { outer=JSON.parse(e.data); } catch(_) { return; }
      var msg;
      if (outer.topic==='ws.send'&&outer.data&&outer.data.data) { try { msg=JSON.parse(outer.data.data); } catch(_) { return; } }
      else msg=outer;
      handleWsMessage(msg);
    };
    ws.onclose = function() { setStatus('disconnected','Disconnected'); scheduleReconnect(); };
    ws.onerror = function() {};
  }
  function scheduleReconnect() { setTimeout(function(){ setStatus('reconnecting','Reconnecting...'); connect(); }, reconnectDelay); reconnectDelay=Math.min(reconnectDelay*2,MAX_DELAY); }
  function setStatus(state,text) { document.getElementById('status-dot').className='dot '+state; document.getElementById('status-text').textContent=text; }

  function handleWsMessage(msg) {
    if (msg.type==='rank_change') {
      showToast('<strong>'+esc(msg.player_name)+'</strong> '+esc(msg.old_rank)+' &rarr; '+esc(msg.new_rank),'gold');
    } else if (msg.type==='new_match') {
      var kda=msg.kills+'/'+msg.deaths+'/'+msg.assists;
      var result=msg.win?'Victory':'Defeat';
      var lpStr='';
      if (msg.lp_diff) { lpStr=msg.lp_diff>0?' <strong style="color:var(--green)">+'+msg.lp_diff+' LP</strong>':' <strong style="color:var(--red)">'+msg.lp_diff+' LP</strong>'; }
      var pentaStr = msg.penta_kills > 0 ? ' <strong style="color:var(--gold)">PENTAKILL!</strong>' : '';
      showToast('<strong>'+esc(msg.player_name)+'</strong> '+result+lpStr+pentaStr+'<br>'+esc(msg.champion_name)+' '+kda+(msg.cs?' &middot; '+msg.cs+' CS':'')+(msg.total_damage?' &middot; '+fmtNumber(msg.total_damage)+' DMG':''), msg.win?'success':'error');
    } else if (msg.type==='fetch_failed') {
      showToast('Fetch failed: '+esc(msg.player_name)+' — '+esc(msg.error),'error');
    }
  }

  // ── Server Status ──────────────────────────────────
  function loadServerStatus() {
    fetch('/api/status').then(function(r){return r.json();}).then(function(data){
      var el=document.getElementById('server-status');
      // Only show actual incidents (not informational maintenances like "Update Available")
      var issues=[];
      var incidents=data.incidents||[];
      for (var i=0;i<incidents.length;i++) issues.push(incidents[i]);
      var maints=data.maintenances||[];
      for (var i=0;i<maints.length;i++) {
        // Skip informational/scheduled maintenances — only show in_progress ones
        if (maints[i].maintenance_status==='in_progress') issues.push(maints[i]);
      }
      if (issues.length===0) { el.classList.remove('visible'); return; }
      var html='';
      for (var i=0;i<issues.length;i++) {
        html+='<div class="ssb-title">'+(issues[i].severity==='critical'?'CRITICAL: ':'')+esc(issues[i].title||'Server Issue')+'</div>';
        if (issues[i].content) html+='<div>'+esc(issues[i].content)+'</div>';
      }
      el.innerHTML=html;
      el.classList.add('visible');
    }).catch(function(){});
  }

  // ── Recent Searches ─────────────────────────────────
  function loadRecentSearches() {
    fetch('/api/recent-searches').then(function(r){return r.json();}).then(function(data){
      var searches=data.searches||[];
      var sel=document.getElementById('recent-select');
      sel.innerHTML='<option value="">Recent searches...</option>';
      if (searches.length===0) { sel.style.display='none'; return; }
      for (var i=0;i<searches.length;i++) {
        var s=searches[i];
        var label=s.game_name+'#'+s.tag_line;
        var opt=document.createElement('option');
        opt.value=label;
        opt.textContent=label;
        sel.appendChild(opt);
      }
      sel.style.display='';
    }).catch(function(){});
  }

  // ── Search ─────────────────────────────────────────
  function doSearch() {
    var input=document.getElementById('search-input').value.trim();
    if (!input) return;
    var parts=input.split('#');
    if (parts.length<2) { showError('Format: GameName#TagLine'); return; }
    var name=parts[0].trim(), tag=parts.slice(1).join('#').trim();
    if (!name||!tag) { showError('Format: GameName#TagLine'); return; }
    hideError(); showLoading(true);
    document.getElementById('btn-search').disabled=true;
    var platform=document.getElementById('region-select').value;
    fetch('/api/search?name='+encodeURIComponent(name)+'&tag='+encodeURIComponent(tag)+'&platform='+encodeURIComponent(platform))
      .then(function(r){ if(!r.ok) return r.json().then(function(d){throw new Error(d.error||'Error '+r.status);}); return r.json(); })
      .then(function(data){
        showLoading(false); document.getElementById('btn-search').disabled=false;
        if (data.dd_version) currentDdVersion=data.dd_version;
        if (data.items_data) itemData=data.items_data;
        if (data.runes_data) runeData=data.runes_data;
        currentPuuid=data.account&&data.account.puuid;
        // Update URL state so the profile link is shareable
        if (data.account&&data.account.game_name) {
          var p=new URLSearchParams();
          p.set('player',data.account.game_name+'#'+data.account.tag_line);
          p.set('platform',platform);
          history.pushState({},'','?'+p.toString());
        }
        renderProfile(data);
        checkLiveGamePoll(data);
        loadExtendedStats();
        loadRecentSearches();
        loadFavorites();
      })
      .catch(function(err){ showLoading(false); document.getElementById('btn-search').disabled=false; showError(err.message); });
  }

  // ── DDragon data (items + runes) ───────────────────
  function loadDDragonData() {
    fetch('/api/rotations').then(function(r){return r.json();}).then(function(data){
      if (data.dd_version) currentDdVersion=data.dd_version;
      var champs=data.free_champions||[];
      if (champs.length===0) return;
      var section=document.getElementById('rotation-section');
      var grid=document.getElementById('rotation-grid');
      section.style.display=''; grid.innerHTML='';
      for (var i=0;i<champs.length;i++) {
        var c=champs[i], el=document.createElement('div');
        el.className='rotation-champ';
        el.innerHTML=(c.image?'<img src="'+esc(c.image)+'" alt="'+esc(c.name)+'" title="'+esc(c.name+(c.title?' — '+c.title:''))+'" />':'<div style="width:48px;height:48px;border-radius:8px;background:var(--border);"></div>')+'<div class="rotation-champ-name">'+esc(c.name)+'</div>';
        grid.appendChild(el);
      }
    }).catch(function(){});
  }

  // ── Rendering ──────────────────────────────────────
  function renderProfile(data) {
    var card=document.getElementById('profile-card');
    card.classList.add('visible');
    var acc=data.account||{}, sum=data.summoner||{};
    document.getElementById('profile-name').innerHTML=esc(acc.game_name)+' <span>#'+esc(acc.tag_line)+'</span>';
    document.getElementById('profile-level').textContent='Level '+(sum.level||'—');
    document.getElementById('profile-icon').src=sum.profile_icon_url||'';

    var chEl=document.getElementById('profile-challenges');
    chEl.innerHTML='';
    var ch=data.challenges;
    if (ch&&ch.level) {
      chEl.innerHTML='<div class="challenge-badge">Challenges: <span class="cl-level '+esc(ch.level)+'">'+esc(ch.level)+'</span> <span class="muted">'+(ch.current||0)+' / '+(ch.max||0)+' pts</span>'+(ch.percentile!=null?' <span class="muted">(Top '+Math.round(ch.percentile*100)+'%)</span>':'')+'</div>';
    }

    // Ranked
    var grid=document.getElementById('ranked-grid');
    grid.innerHTML='';
    var ranked=data.ranked||[];
    if (ranked.length===0) grid.innerHTML='<div class="ranked-card"><div class="queue">Ranked</div><div class="tier" style="color:var(--text-muted)">Unranked</div></div>';
    for (var i=0;i<ranked.length;i++) {
      var r=ranked[i], total=(r.wins||0)+(r.losses||0), wr=total>0?Math.round(r.wins/total*100):0;
      var queueName=r.queueType==='RANKED_SOLO_5x5'?'Solo/Duo':r.queueType==='RANKED_FLEX_SR'?'Flex':r.queueType;
      var badges='';
      if (r.hotStreak) badges+='<span class="ranked-badge-item hot">On Fire</span>';
      if (r.freshBlood) badges+='<span class="ranked-badge-item fresh">Fresh</span>';
      if (r.veteran) badges+='<span class="ranked-badge-item vet">Veteran</span>';
      var el=document.createElement('div'); el.className='ranked-card';
      el.innerHTML='<div class="queue">'+esc(queueName)+'</div><div class="tier">'+esc(r.tier)+' '+esc(r.rank)+'</div><div class="lp">'+(r.leaguePoints||0)+' LP</div><div class="winrate">'+wr+'% WR ('+(r.wins||0)+'W '+(r.losses||0)+'L)</div>'+(badges?'<div class="ranked-badges">'+badges+'</div>':'')+'<div class="wr-bar"><div class="wr-bar-fill" style="width:'+wr+'%"></div></div>';
      grid.appendChild(el);
    }

    renderMastery(data.mastery||[]);
    renderLiveGame(data.live_game);

    allMatches=data.matches||[];
    // Build meta map from all participants
    buildMetaMap(allMatches);
    // Compute perf scores, gold eff, comebacks
    var totalScore=0, totalGold=0;
    for (var si=0;si<allMatches.length;si++) {
      allMatches[si]._score=computePerfScore(allMatches[si]);
      totalScore+=allMatches[si]._score;
      totalGold+=(allMatches[si].gold_earned||0);
    }
    var avgGold=allMatches.length>0?totalGold/allMatches.length:0;
    for (var si=0;si<allMatches.length;si++) {
      allMatches[si]._comeback=isComeback(allMatches[si], avgGold);
      allMatches[si]._meta=isMetaRune(allMatches[si].champion_name, allMatches[si].perks_keystone);
    }
    if (data.stats&&allMatches.length>0) data.stats.avg_score=Math.round(totalScore/allMatches.length*10)/10;

    // Populate champion filter dropdown
    var champSelect=document.getElementById('champ-filter');
    champSelect.innerHTML='<option value="">All Champions</option>';
    var champSet={};
    for (var si=0;si<allMatches.length;si++) {
      var cn=allMatches[si].champion_name;
      if (cn&&!champSet[cn]) { champSet[cn]=true; }
    }
    var champNames=Object.keys(champSet).sort();
    for (var si=0;si<champNames.length;si++) {
      var opt=document.createElement('option'); opt.value=champNames[si]; opt.textContent=champNames[si];
      champSelect.appendChild(opt);
    }

    renderStats(data.stats);
    renderTiltDetector(allMatches);
    currentPlayerData=data;
    document.getElementById('h2h-section').classList.add('visible');
    document.getElementById('compare-section').style.display='';
    currentFilter='all'; setActiveTab('all'); renderMatches(allMatches);

    // Rank Percentile (#21)
    var rpEl=document.getElementById('profile-rank-pct');
    if (data.rank_percentile!=null) {
      var topPct=data.rank_percentile;
      rpEl.innerHTML='<div class="rank-pct">Top '+topPct+'% of ranked players<div class="rank-pct-bar"><div class="rank-pct-fill" style="width:'+(100-topPct)+'%"></div></div></div>';
    } else { rpEl.innerHTML=''; }

    // Favorite button (#18)
    var favBtn=document.getElementById('fav-toggle');
    favBtn.innerHTML=data.is_favorite?'&#9733;':'&#9734;';
    favBtn.classList.toggle('active',!!data.is_favorite);

    // Goals (#26)
    renderGoals(data.goals||[]);

    // Match notes (#27) — store for use in match rendering
    window._matchNotes=data.match_notes||{};
  }

  function renderMastery(mastery) {
    var mGrid=document.getElementById('mastery-grid');
    mGrid.innerHTML='';
    if (mastery.length===0) { mGrid.innerHTML='<div class="muted" style="padding:12px;">No mastery data</div>'; return; }
    for (var j=0;j<mastery.length;j++) {
      var m=mastery[j];
      var pts=m.championPoints>=1000000?(m.championPoints/1000000).toFixed(1)+'M':m.championPoints>=1000?Math.round(m.championPoints/1000)+'k':m.championPoints;
      var progressPct=0,sinceLevel=m.championPointsSinceLastLevel||0,untilNext=m.championPointsUntilNextLevel||0;
      if (sinceLevel+untilNext>0) progressPct=Math.round(sinceLevel/(sinceLevel+untilNext)*100);
      var lastPlayed='';
      if (m.lastPlayTime) { var d=new Date(m.lastPlayTime); if(d.getFullYear()>2000){var now=new Date(),diffDays=Math.floor((now-d)/(1000*60*60*24)); lastPlayed=diffDays===0?'Today':diffDays===1?'Yesterday':diffDays<30?diffDays+'d ago':Math.floor(diffDays/30)+'mo ago';}}
      var card=document.createElement('div'); card.className='mastery-card';
      var imgHtml=m.champion_image?'<img class="mastery-champ-icon" src="'+esc(m.champion_image)+'" />':'<div class="mastery-champ-icon" style="background:var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--text-muted);">'+(m.championId||'?')+'</div>';
      card.innerHTML=imgHtml+'<div class="mastery-details"><div class="mastery-champ-name">'+esc(m.champion_name||'Champion '+m.championId)+'</div>'+(m.champion_title?'<div class="mastery-champ-title">'+esc(m.champion_title)+'</div>':'')+'<div class="mastery-stats"><span class="mastery-stat"><strong>'+pts+'</strong> pts</span>'+(m.chestGranted?'<span class="mastery-stat" title="Chest earned">&#128230;</span>':'')+(lastPlayed?'<span class="mastery-stat">'+lastPlayed+'</span>':'')+'</div>'+(untilNext>0?'<div class="mastery-progress"><div class="mastery-progress-fill" style="width:'+progressPct+'%"></div></div>':'')+'</div><div class="mastery-level-badge">M'+(m.championLevel||0)+'</div>';
      mGrid.appendChild(card);
    }
  }

  function renderLiveGame(lg) {
    var banner=document.getElementById('live-game-banner');
    if (!lg) { banner.classList.remove('visible'); return; }
    banner.classList.add('visible');
    var queueNames={420:'Solo/Duo',440:'Flex',450:'ARAM',900:'ARURF',1700:'Arena',490:'Quick Play'};
    var queueStr=queueNames[lg.queue_id]||lg.game_mode||'CLASSIC';
    document.getElementById('live-game-mode').innerHTML='IN GAME — '+esc(queueStr)+(Math.floor((lg.game_length||0)/60)>0?' ('+Math.floor(lg.game_length/60)+' min)':'')+(lg.queue_id?'<span class="live-queue-badge">Q'+lg.queue_id+'</span>':'');
    var teamsEl=document.getElementById('live-teams');
    var blueHtml='<div class="live-team-blue"><div class="live-team-label">Blue Team</div>';
    var redHtml='<div class="live-team-red"><div class="live-team-label">Red Team</div>';
    for (var i=0;i<(lg.participants||[]).length;i++) {
      var p=lg.participants[i], icon=p.champion_image?'<img src="'+esc(p.champion_image)+'" />':'';
      var s1=spellImg(p.summoner1),s2=spellImg(p.summoner2);
      var spells='<div class="live-player-spells">'+(s1?'<img src="'+s1+'" />' :'')+(s2?'<img src="'+s2+'" />':'')+'</div>';
      // Runes
      var runesHtml='';
      if (p.perks_keystone||p.perks_sub) {
        runesHtml='<div class="live-player-runes">';
        var ks=runeData[String(p.perks_keystone)];
        var sub=runeData[String(p.perks_sub)];
        if (ks&&ks.icon) runesHtml+='<img src="'+esc(ks.icon)+'" title="'+esc(ks.name||'')+'" />';
        if (sub&&sub.icon) runesHtml+='<img src="'+esc(sub.icon)+'" title="'+esc(sub.name||'')+'" />';
        runesHtml+='</div>';
      }
      // Ranked
      var rankHtml='';
      if (p.ranked) {
        var r=p.ranked;
        rankHtml='<span class="live-player-rank">'+esc(r.tier)+' '+esc(r.rank)+' '+(r.lp||0)+' LP</span>';
      }
      var isMe=currentPuuid&&p.puuid===currentPuuid;
      var champWrHtml='';
      if (p.champion_wr!==undefined&&p.champion_wr!==null) champWrHtml='<span class="live-champ-wr" style="color:'+(p.champion_wr>=50?'var(--green)':'var(--red)')+'">'+p.champion_wr+'% on champ</span>';
      var masteryHtml=p.mastery_level?'<span class="live-mastery muted">M'+p.mastery_level+'</span>':'';
      var streakHtml='';
      if (p.streak&&Math.abs(p.streak)>=3) { var sClr=p.streak>0?'var(--green)':'var(--red)'; streakHtml='<span style="color:'+sClr+';font-size:11px;">'+(p.streak>0?p.streak+'W':Math.abs(p.streak)+'L')+'</span>'; }
      var row='<div class="live-player'+(isMe?' is-me':'')+'">'+icon+spells+runesHtml+'<span>'+esc(p.champion_name)+'</span>'+masteryHtml+' <span class="muted">'+esc(p.summoner_name||'')+'</span>'+rankHtml+champWrHtml+streakHtml+'</div>';
      if (p.team_id===100) blueHtml+=row; else redHtml+=row;
    }
    // Bans
    var blueBans='',redBans='';
    if (lg.bans&&lg.bans.length>0) {
      var bbItems=[],rbItems=[];
      for (var b=0;b<lg.bans.length;b++) {
        var ban=lg.bans[b];
        var banImg=ban.champion_image?'<img class="live-ban-icon" src="'+esc(ban.champion_image)+'" title="'+esc(ban.champion_name||'Ban')+'" />':'';
        if (ban.team_id===100) bbItems.push(banImg); else rbItems.push(banImg);
      }
      if (bbItems.length>0) blueBans='<div class="live-bans"><span class="live-bans-label">Bans:</span>'+bbItems.join('')+'</div>';
      if (rbItems.length>0) redBans='<div class="live-bans"><span class="live-bans-label">Bans:</span>'+rbItems.join('')+'</div>';
    }
    teamsEl.innerHTML=blueHtml+blueBans+'</div>'+redHtml+redBans+'</div>';
  }

  function renderStats(stats) {
    var section=document.getElementById('stats-section');
    if (!stats) { section.classList.remove('visible'); return; }
    section.classList.add('visible');

    // ── Tab: Overview ─────────────────────────────────
    var ov=document.getElementById('panel-overview');
    var wrColor=stats.winrate>=50?'green':'red';
    var kdaColor=stats.avg_kda>=3?'green':stats.avg_kda>=2?'gold':'red';
    var streakHtml='';
    if (stats.streak>=2) streakHtml='<div class="so-streak '+(stats.streak_type==='W'?'win-streak':'loss-streak')+'">'+stats.streak+stats.streak_type+' Streak</div>';

    var mkHtml='';
    if (stats.penta_kills>0||stats.quadra_kills>0||stats.triple_kills>0) {
      mkHtml='<div class="multikill-badges">';
      if (stats.penta_kills>0) mkHtml+='<span class="mk-badge mk-penta">'+stats.penta_kills+'x Penta</span>';
      if (stats.quadra_kills>0) mkHtml+='<span class="mk-badge mk-quadra">'+stats.quadra_kills+'x Quadra</span>';
      if (stats.triple_kills>0) mkHtml+='<span class="mk-badge mk-triple">'+stats.triple_kills+'x Triple</span>';
      mkHtml+='</div>';
    }

    var dmgTotal=(stats.total_damage_physical||0)+(stats.total_damage_magic||0)+(stats.total_damage_true||0);
    var dmgBarHtml='';
    if (dmgTotal>0) {
      var pPct=Math.round(stats.total_damage_physical/dmgTotal*100);
      var mPct=Math.round(stats.total_damage_magic/dmgTotal*100);
      var tPct=100-pPct-mPct;
      dmgBarHtml='<div class="dmg-breakdown"><div class="dmg-phys" style="width:'+pPct+'%"></div><div class="dmg-magic" style="width:'+mPct+'%"></div><div class="dmg-true" style="width:'+tPct+'%"></div></div><div class="dmg-legend"><span class="dl-phys">Physical '+pPct+'%</span><span class="dl-magic">Magic '+mPct+'%</span><span class="dl-true">True '+tPct+'%</span></div>';
    }

    ov.innerHTML='<div class="so-grid">'+
      '<div class="so-item"><div class="so-label">Win Rate</div><div class="so-value '+wrColor+'">'+stats.winrate+'%</div></div>'+
      '<div class="so-item"><div class="so-label">KDA</div><div class="so-value '+kdaColor+'">'+stats.avg_kills+'/'+stats.avg_deaths+'/'+stats.avg_assists+'</div></div>'+
      '<div class="so-item"><div class="so-label">KDA Ratio</div><div class="so-value">'+stats.avg_kda+'</div></div>'+
      '<div class="so-item"><div class="so-label">CS/min</div><div class="so-value">'+stats.avg_cs_min+'</div></div>'+
      '<div class="so-item"><div class="so-label">Avg Damage</div><div class="so-value">'+fmtNumber(stats.avg_damage)+'</div></div>'+
      '<div class="so-item"><div class="so-label">Avg Gold</div><div class="so-value gold">'+fmtNumber(stats.avg_gold)+'</div></div>'+
      '<div class="so-item"><div class="so-label">Kill Part.</div><div class="so-value">'+(stats.avg_kill_participation||0)+'%</div></div>'+
      '<div class="so-item"><div class="so-label">Dmg Share</div><div class="so-value">'+(stats.avg_damage_share||0)+'%</div></div>'+
      '<div class="so-item"><div class="so-label">Vision</div><div class="so-value">'+stats.avg_vision+'</div></div>'+
      '<div class="so-item"><div class="so-label">Wards</div><div class="so-value">'+(stats.avg_wards_placed||0)+'</div></div>'+
      '<div class="so-item"><div class="so-label">Record</div><div class="so-value">'+stats.wins+'W '+stats.losses+'L</div></div>'+
      '<div class="so-item"><div class="so-label">Ctrl Wards</div><div class="so-value">'+(stats.avg_control_wards||0)+'</div></div>'+
      '<div class="so-item"><div class="so-label">Avg Score</div><div class="so-value"><span class="perf-score '+scoreClass(stats.avg_score||0)+'">'+(stats.avg_score||0).toFixed(1)+'</span></div></div>'+
      '<div class="so-item"><div class="so-label">Games</div><div class="so-value">'+stats.games+'</div></div>'+
      '<div class="so-item"><div class="so-label">Pool</div><div class="so-value"><span class="pool-badge '+(stats.pool_depth==='One-Trick'?'one-trick':stats.pool_depth==='Specialist'?'specialist':'versatile')+'">'+esc(stats.pool_depth||'—')+'</span></div></div>'+
      '<div class="so-item"><div class="so-label">Playstyle</div><div class="so-value"><span class="pref-badge">'+esc(stats.game_length_pref||'—')+'</span></div></div>'+
      '</div>'+streakHtml+mkHtml+dmgBarHtml;

    // Recent form (last 5 games)
    var rf=stats.recent_form;
    if (rf) {
      var rfWrDiff=rf.winrate-stats.winrate;
      var rfKdaDiff=rf.avg_kda-stats.avg_kda;
      var trendCls=rfWrDiff>5?'up':rfWrDiff<-5?'down':'neutral';
      var trendIcon=rfWrDiff>5?'&#9650;':rfWrDiff<-5?'&#9660;':'&#9644;';
      var rfWrColor=rf.winrate>=50?'green':'red';
      var rfKdaColor=rf.avg_kda>=3?'green':rf.avg_kda>=2?'gold':'red';
      ov.innerHTML+='<div class="recent-form"><div class="rf-header"><span class="rf-title">Last '+rf.games+' Games</span><span class="rf-trend '+trendCls+'">'+trendIcon+' '+(rfWrDiff>0?'+':'')+rfWrDiff+'% WR</span></div><div class="rf-stats"><div class="rf-stat"><div class="rf-stat-val" style="color:var(--'+rfWrColor+')">'+rf.winrate+'%</div><div class="rf-stat-label">Win Rate</div></div><div class="rf-stat"><div class="rf-stat-val" style="color:var(--'+rfKdaColor+')">'+rf.avg_kda+'</div><div class="rf-stat-label">KDA</div></div><div class="rf-stat"><div class="rf-stat-val">'+rf.avg_kills+'/'+rf.avg_deaths+'/'+rf.avg_assists+'</div><div class="rf-stat-label">K/D/A</div></div><div class="rf-stat"><div class="rf-stat-val">'+rf.avg_cs_min+'</div><div class="rf-stat-label">CS/min</div></div><div class="rf-stat"><div class="rf-stat-val">'+fmtNumber(rf.avg_damage)+'</div><div class="rf-stat-label">Damage</div></div></div></div>';
    }

    // Performance sparkline (game-by-game scores)
    if (allMatches.length>1) {
      var spW=320, spH=40, pts=[];
      var maxS=1;
      for (var si=allMatches.length-1;si>=0;si--) { var sc=allMatches[si]._score||0; if(sc>maxS)maxS=sc; }
      for (var si=allMatches.length-1;si>=0;si--) {
        var x=Math.round((allMatches.length-1-si)/(allMatches.length-1)*spW);
        var y=Math.round(spH-((allMatches[si]._score||0)/maxS*(spH-4)+2));
        pts.push(x+','+y);
      }
      var sparkSvg='<div class="rf-sparkline"><svg viewBox="0 0 '+spW+' '+spH+'" preserveAspectRatio="none">';
      sparkSvg+='<polyline points="'+pts.join(' ')+'" fill="none" stroke="var(--gold)" stroke-width="1.5" />';
      // Dots for wins/losses
      for (var si=allMatches.length-1;si>=0;si--) {
        var x=Math.round((allMatches.length-1-si)/(allMatches.length-1)*spW);
        var y=Math.round(spH-((allMatches[si]._score||0)/maxS*(spH-4)+2));
        sparkSvg+='<circle cx="'+x+'" cy="'+y+'" r="2.5" fill="var(--'+(allMatches[si].win?'green':'red')+')" />';
      }
      sparkSvg+='</svg></div>';
      ov.innerHTML+=sparkSvg;
    }

    // ── Tab: Champions (expanded) ─────────────────────
    var chEl=document.getElementById('panel-champions');
    var topChamps=stats.top_champions||[];
    var champHtml='<div class="champ-expanded-grid">';
    for (var i=0;i<topChamps.length;i++) {
      var c=topChamps[i], cWr=c.games>0?Math.round(c.wins/c.games*100):0;
      var wrCls=cWr>=55?'green':cWr<=45?'red':'gold';
      var cIcon=c.champion_image?'<img class="ce-icon" src="'+esc(c.champion_image)+'" />':'<div class="ce-icon" style="background:var(--border);"></div>';

      var POS_SHORT={TOP:'Top',JUNGLE:'JGL',MIDDLE:'Mid',BOTTOM:'ADC',UTILITY:'SUP'};
      var badges='';
      if (c.top_position) badges+='<span class="ce-badge" style="background:rgba(59,130,246,0.1);color:var(--blue);">'+(POS_SHORT[c.top_position]||c.top_position)+'</span>';
      if (c.top_keystone&&runeData[String(c.top_keystone)]) {
        var ks=runeData[String(c.top_keystone)];
        badges+='<span class="ce-badge" style="background:rgba(200,155,60,0.1);color:var(--gold);display:flex;align-items:center;gap:3px;"><img src="'+esc(ks.icon)+'" style="width:12px;height:12px;border-radius:50%;" />'+esc(ks.name)+'</span>';
      }

      // Damage composition bar
      var cDmgBar='';
      if ((c.dmg_physical_pct||0)+(c.dmg_magic_pct||0)+(c.dmg_true_pct||0)>0) {
        cDmgBar='<div class="ce-dmg-bar"><div class="phys" style="width:'+c.dmg_physical_pct+'%"></div><div class="magic" style="width:'+c.dmg_magic_pct+'%"></div><div class="true-d" style="width:'+c.dmg_true_pct+'%"></div></div><div class="ce-dmg-legend"><span style="color:#ef4444;">Phys '+c.dmg_physical_pct+'%</span><span style="color:#3b82f6;">Magic '+c.dmg_magic_pct+'%</span><span style="color:#e2e8f0;">True '+c.dmg_true_pct+'%</span></div>';
      }
      // Rune WR tags
      var runeTagsHtml='';
      var cRunes=c.runes||[];
      if (cRunes.length>0) {
        runeTagsHtml='<div class="ce-runes">';
        for (var ri=0;ri<cRunes.length;ri++) {
          var cr=cRunes[ri];
          var crData=runeData[String(cr.keystone)];
          var crWrCls=cr.winrate>=50?'green':'red';
          if (crData&&crData.icon) runeTagsHtml+='<span class="ce-rune-tag"><img src="'+esc(crData.icon)+'" />'+esc(crData.name||'')+' <span style="color:var(--'+crWrCls+')">'+cr.winrate+'%</span> ('+cr.games+')</span>';
        }
        runeTagsHtml+='</div>';
      }

      champHtml+='<div class="ce-card"><div class="ce-header">'+cIcon+'<div><div class="ce-name">'+esc(c.champion_name)+'</div><div class="ce-sub"><span style="color:var(--'+wrCls+')">'+cWr+'% WR</span> &middot; '+c.wins+'W '+c.losses+'L &middot; '+c.games+' games</div>'+(badges?'<div class="ce-badges">'+badges+'</div>':'')+'</div></div><div class="ce-wr-bar"><div class="ce-wr-fill" style="width:'+cWr+'%"></div></div><div class="ce-stats"><div class="ce-stat"><div class="ce-stat-val">'+c.avg_kda+'</div><div class="ce-stat-label">KDA</div></div><div class="ce-stat"><div class="ce-stat-val">'+(c.avg_cs_min||0)+'</div><div class="ce-stat-label">CS/m</div></div><div class="ce-stat"><div class="ce-stat-val">'+fmtNumber(c.avg_damage||0)+'</div><div class="ce-stat-label">DMG</div></div><div class="ce-stat"><div class="ce-stat-val" style="color:var(--gold)">'+fmtNumber(c.avg_gold||0)+'</div><div class="ce-stat-label">Gold</div></div><div class="ce-stat"><div class="ce-stat-val">'+(c.avg_kp||0)+'%</div><div class="ce-stat-label">KP</div></div><div class="ce-stat"><div class="ce-stat-val">'+(c.avg_ds||0)+'%</div><div class="ce-stat-label">DMG%</div></div><div class="ce-stat"><div class="ce-stat-val">'+(c.avg_vision||0)+'</div><div class="ce-stat-label">Vision</div></div><div class="ce-stat"><div class="ce-stat-val">'+c.avg_kills+'/'+c.avg_deaths+'/'+c.avg_assists+'</div><div class="ce-stat-label">Avg KDA</div></div></div>'+cDmgBar+runeTagsHtml+'</div>';
    }
    champHtml+='</div>';
    if (topChamps.length===0) champHtml='<div class="muted">No champion data</div>';
    chEl.innerHTML=champHtml;

    // ── Tab: Roles (donut chart) ──────────────────────
    var roleEl=document.getElementById('panel-roles');
    var roles=stats.roles||[];
    var ROLE_NAMES={TOP:'Top',JUNGLE:'Jungle',MIDDLE:'Mid',BOTTOM:'ADC',UTILITY:'Support'};
    var ROLE_COLORS={TOP:'#ef4444',JUNGLE:'#22c55e',MIDDLE:'#3b82f6',BOTTOM:'#f59e0b',UTILITY:'#a855f7'};

    if (roles.length===0) { roleEl.innerHTML='<div class="muted">No role data</div>'; }
    else {

    // Build SVG donut
    var totalGames=0;
    for (var j=0;j<roles.length;j++) totalGames+=roles[j].count;
    var R=54, CX=70, CY=70, circumference=2*Math.PI*R;
    var svgPaths='';
    var legendHtml='';
    var offset=0;

    for (var j=0;j<roles.length;j++) {
      var r=roles[j];
      var pct=totalGames>0?r.count/totalGames:0;
      var dashLen=pct*circumference;
      var dashGap=circumference-dashLen;
      var color=ROLE_COLORS[r.position]||'var(--text-muted)';
      svgPaths+='<circle cx="'+CX+'" cy="'+CY+'" r="'+R+'" fill="none" stroke="'+color+'" stroke-width="16" stroke-dasharray="'+dashLen.toFixed(1)+' '+dashGap.toFixed(1)+'" stroke-dashoffset="'+(-offset).toFixed(1)+'" transform="rotate(-90 '+CX+' '+CY+')" />';
      offset+=dashLen;

      var rName=ROLE_NAMES[r.position]||r.position;
      legendHtml+='<div class="donut-legend-item"><div class="donut-legend-dot" style="background:'+color+'"></div><span class="donut-legend-name">'+esc(rName)+'</span><span class="donut-legend-pct">'+r.pct+'%</span><span class="donut-legend-games">'+r.count+'G</span></div>';
    }

    var svg='<svg class="donut-svg" viewBox="0 0 140 140">'+svgPaths+'<text x="'+CX+'" y="'+CY+'" text-anchor="middle" dominant-baseline="central" fill="var(--text)" font-size="14" font-weight="700" font-family="var(--font-mono)">'+totalGames+'</text><text x="'+CX+'" y="'+(CY+14)+'" text-anchor="middle" fill="var(--text-muted)" font-size="9">games</text></svg>';

    roleEl.innerHTML='<div class="donut-wrap">'+svg+'<div class="donut-legend">'+legendHtml+'</div></div>';
    } // end roles else

    // ── Tab: Advanced ───────────────────────────────
    var advEl=document.getElementById('panel-advanced');
    var advHtml='';

    // Radar chart in overview: KDA, CS, Damage, Vision, KP, Gold
    // Normalize each axis to 0-1 range with reasonable ceilings
    var radarAxes=[
      {name:'KDA',val:stats.avg_kda||0,max:6,color:'#3b82f6'},
      {name:'CS/min',val:stats.avg_cs_min||0,max:10,color:'#22c55e'},
      {name:'Damage',val:(stats.avg_damage||0)/1000,max:30,color:'#ef4444'},
      {name:'Vision',val:stats.avg_vision||0,max:40,color:'#a855f7'},
      {name:'KP',val:stats.avg_kill_participation||0,max:100,color:'#f59e0b'},
      {name:'Gold',val:(stats.avg_gold||0)/1000,max:16,color:'#c89b3c'},
    ];
    var rCX=100,rCY=100,rR=80,axes=radarAxes.length;
    var radarSvg='<svg class="radar-svg" viewBox="0 0 200 200">';
    // Grid rings
    for (var ring=1;ring<=4;ring++) {
      var rr=rR*ring/4, pts='';
      for (var ai=0;ai<axes;ai++) {
        var angle=-Math.PI/2+2*Math.PI*ai/axes;
        pts+=(rCX+rr*Math.cos(angle))+','+(rCY+rr*Math.sin(angle))+' ';
      }
      radarSvg+='<polygon points="'+pts+'" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1" />';
    }
    // Axis lines
    for (var ai=0;ai<axes;ai++) {
      var angle=-Math.PI/2+2*Math.PI*ai/axes;
      radarSvg+='<line x1="'+rCX+'" y1="'+rCY+'" x2="'+(rCX+rR*Math.cos(angle))+'" y2="'+(rCY+rR*Math.sin(angle))+'" stroke="rgba(255,255,255,0.08)" stroke-width="1" />';
    }
    // Data polygon
    var dataPts='', labelsSvg='';
    for (var ai=0;ai<axes;ai++) {
      var ax=radarAxes[ai];
      var norm=Math.min(ax.val/ax.max,1);
      var angle=-Math.PI/2+2*Math.PI*ai/axes;
      var px=rCX+rR*norm*Math.cos(angle), py=rCY+rR*norm*Math.sin(angle);
      dataPts+=px+','+py+' ';
      // Label position (outside the chart)
      var lx=rCX+(rR+14)*Math.cos(angle), ly=rCY+(rR+14)*Math.sin(angle);
      var anchor=Math.abs(Math.cos(angle))<0.1?'middle':Math.cos(angle)>0?'start':'end';
      labelsSvg+='<text x="'+lx+'" y="'+ly+'" text-anchor="'+anchor+'" dominant-baseline="central" fill="'+ax.color+'" font-size="8" font-weight="600" font-family="var(--font-mono)">'+ax.name+'</text>';
    }
    radarSvg+='<polygon points="'+dataPts+'" fill="rgba(200,155,60,0.15)" stroke="var(--gold)" stroke-width="1.5" />';
    radarSvg+=labelsSvg+'</svg>';

    var radarLeg='<div class="radar-legend">';
    for (var ai=0;ai<radarAxes.length;ai++) {
      var ax=radarAxes[ai];
      radarLeg+='<div class="radar-legend-item"><div class="radar-legend-dot" style="background:'+ax.color+'"></div><span class="radar-legend-name">'+ax.name+'</span><span class="radar-legend-val">'+ax.val+'</span></div>';
    }
    radarLeg+='</div>';

    advHtml+='<div class="radar-wrap">'+radarSvg+radarLeg+'</div>';

    // Advanced stat cards
    function fmtDur(s) { if(!s) return '—'; var m=Math.floor(s/60),ss=s%60; return m+':'+(ss<10?'0':'')+ss; }
    advHtml+='<div class="adv-grid">';
    advHtml+='<div class="adv-card"><div class="adv-val" style="color:var(--red);">'+(stats.first_blood_rate||0)+'%</div><div class="adv-label">First Blood</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val">'+(stats.surrender_rate||0)+'%</div><div class="adv-label">Surrender Rate</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val" style="color:var(--green);">'+fmtDur(stats.avg_duration_win)+'</div><div class="adv-label">Avg Win Length</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val" style="color:var(--red);">'+fmtDur(stats.avg_duration_loss)+'</div><div class="adv-label">Avg Loss Length</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val">'+fmtNumber(stats.avg_damage_per_min||0)+'</div><div class="adv-label">DPM</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val" style="color:var(--gold);">'+(stats.avg_gold_per_min||0)+'</div><div class="adv-label">Gold/min</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val">'+(stats.damage_per_gold||0)+'</div><div class="adv-label">DMG/Gold</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val">'+fmtNumber(stats.avg_damage_taken||0)+'</div><div class="adv-label">Avg DMG Taken</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val" style="color:var(--blue);">'+(stats.unique_champions||0)+'</div><div class="adv-label">Unique Champs</div></div>';
    advHtml+='<div class="adv-card"><div class="adv-val">'+fmtDur(stats.avg_game_duration)+'</div><div class="adv-label">Avg Game</div></div>';
    advHtml+='</div>';

    // Game length breakdown
    if (stats.short_game_wr!=null||stats.long_game_wr!=null) {
      advHtml+='<div class="stats-section-title">Game Length Analysis</div><div class="gl-bars">';
      if (stats.short_game_count>0) {
        var sgCls=stats.short_game_wr>=50?'green':'red';
        advHtml+='<div class="gl-bar"><div class="gl-bar-label">&lt; 25 min</div><div class="gl-bar-val" style="color:var(--'+sgCls+')">'+(stats.short_game_wr!=null?stats.short_game_wr+'%':'—')+'</div><div class="gl-bar-sub">'+stats.short_game_count+' games</div></div>';
      }
      var midCount=stats.games-(stats.short_game_count||0)-(stats.long_game_count||0);
      if (midCount>0) {
        var midWins=stats.wins-(stats.short_game_wr!=null?Math.round(stats.short_game_wr*stats.short_game_count/100):0)-(stats.long_game_wr!=null?Math.round(stats.long_game_wr*stats.long_game_count/100):0);
        var midWr=midCount>0?Math.round(Math.max(0,midWins)/midCount*100):0;
        var mgCls=midWr>=50?'green':'red';
        advHtml+='<div class="gl-bar"><div class="gl-bar-label">25-35 min</div><div class="gl-bar-val" style="color:var(--'+mgCls+')">'+midWr+'%</div><div class="gl-bar-sub">'+midCount+' games</div></div>';
      }
      if (stats.long_game_count>0) {
        var lgCls=stats.long_game_wr>=50?'green':'red';
        advHtml+='<div class="gl-bar"><div class="gl-bar-label">&gt; 35 min</div><div class="gl-bar-val" style="color:var(--'+lgCls+')">'+(stats.long_game_wr!=null?stats.long_game_wr+'%':'—')+'</div><div class="gl-bar-sub">'+stats.long_game_count+' games</div></div>';
      }
      advHtml+='</div>';
    }

    // ── Objective Control ──────────────────────────
    advHtml+='<div class="stats-section-title">Objective Control (per game avg)</div>';
    advHtml+='<div class="obj-grid">';
    advHtml+='<div class="obj-card"><div class="obj-icon" style="color:#ef4444;">&#9670;</div><div class="obj-val">'+(stats.avg_dragon_takedowns||0)+'</div><div class="obj-label">Dragons</div></div>';
    advHtml+='<div class="obj-card"><div class="obj-icon" style="color:#a855f7;">&#9733;</div><div class="obj-val">'+(stats.avg_baron_takedowns||0)+'</div><div class="obj-label">Barons</div></div>';
    advHtml+='<div class="obj-card"><div class="obj-icon" style="color:#3b82f6;">&#9826;</div><div class="obj-val">'+(stats.avg_herald_takedowns||0)+'</div><div class="obj-label">Heralds</div></div>';
    advHtml+='<div class="obj-card"><div class="obj-icon" style="color:#f59e0b;">&#9960;</div><div class="obj-val">'+(stats.avg_turret_takedowns||0)+'</div><div class="obj-label">Turrets</div></div>';
    advHtml+='<div class="obj-card"><div class="obj-icon" style="color:#22c55e;">&#9964;</div><div class="obj-val">'+(stats.avg_inhibitor_takedowns||0)+'</div><div class="obj-label">Inhibitors</div></div>';
    advHtml+='<div class="obj-card"><div class="obj-icon" style="color:#c89b3c;">&#9876;</div><div class="obj-val">'+(stats.avg_solo_kills||0)+'</div><div class="obj-label">Solo Kills</div><div class="obj-total">'+stats.total_solo_kills+' total</div></div>';
    advHtml+='</div>';

    // ── Early Game ──────────────────────────────────
    advHtml+='<div class="stats-section-title">Early Game &amp; Laning</div>';
    advHtml+='<div class="early-grid">';
    if (stats.avg_cs_first10>0) advHtml+='<div class="early-card"><div class="early-val">'+(stats.avg_cs_first10||0)+'</div><div class="early-label">CS @ 10 min</div></div>';
    advHtml+='<div class="early-card"><div class="early-val" style="color:var(--gold);">'+(stats.avg_turret_plates||0)+'</div><div class="early-label">Turret Plates</div></div>';
    advHtml+='<div class="early-card"><div class="early-val" style="color:'+(stats.avg_cs_advantage>=0?'var(--green)':'var(--red)')+';">'+(stats.avg_cs_advantage>0?'+':'')+(stats.avg_cs_advantage||0)+'</div><div class="early-label">Max CS Lead</div></div>';
    advHtml+='<div class="early-card"><div class="early-val" style="color:'+(stats.avg_level_lead>=0?'var(--green)':'var(--red)')+';">'+(stats.avg_level_lead>0?'+':'')+(stats.avg_level_lead||0)+'</div><div class="early-label">Max Level Lead</div></div>';
    advHtml+='<div class="early-card"><div class="early-val">'+(stats.avg_vision_per_min||0)+'</div><div class="early-label">Vision/min</div></div>';
    advHtml+='</div>';

    // ── Snowball Index ──────────────────────────────
    var snowball=stats.snowball_index||0;
    var snowPct=Math.min(100,Math.max(0,Math.round(snowball/10*100))); // 10 = very dominant
    var snowColor=snowball>=6?'var(--green)':snowball>=3?'var(--gold)':'var(--red)';
    var snowLabel=snowball>=6?'Dominant':snowball>=3?'Balanced':'Passive';
    advHtml+='<div class="stats-section-title">Snowball Index</div>';
    advHtml+='<div class="snowball-wrap"><div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px;"><span style="font-size:18px;font-weight:700;font-family:var(--font-mono);color:'+snowColor+';">'+snowball+'</span><span style="font-size:11px;color:'+snowColor+';font-weight:600;">'+snowLabel+'</span></div><div class="snowball-bar"><div class="snowball-fill" style="width:'+snowPct+'%;background:'+snowColor+';"></div></div><div class="snowball-labels"><span>Passive</span><span>Dominant</span></div></div>';

    // Win vs Loss comparison
    var ws=stats.win_stats, ls=stats.loss_stats;
    if (ws&&ls) {
      var wlRows=[
        ['KDA',ws.avg_kda,ls.avg_kda],
        ['Kills',ws.avg_kills,ls.avg_kills],
        ['Deaths',ws.avg_deaths,ls.avg_deaths],
        ['Assists',ws.avg_assists,ls.avg_assists],
        ['CS/min',ws.avg_cs_min,ls.avg_cs_min],
        ['Damage',fmtNumber(ws.avg_damage),fmtNumber(ls.avg_damage)],
        ['Gold',fmtNumber(ws.avg_gold),fmtNumber(ls.avg_gold)],
        ['Vision',ws.avg_vision,ls.avg_vision],
        ['KP',ws.avg_kp+'%',ls.avg_kp+'%'],
      ];
      advHtml+='<div style="font-size:12px;font-weight:700;margin:12px 0 6px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Win vs Loss Comparison</div>';
      advHtml+='<div class="wl-compare"><div class="wl-col"><div class="wl-header win">When Winning</div>';
      for (var wi=0;wi<wlRows.length;wi++) advHtml+='<div class="wl-row"><span class="wl-label">'+wlRows[wi][0]+'</span><span class="wl-val" style="color:var(--green)">'+wlRows[wi][1]+'</span></div>';
      advHtml+='</div><div class="wl-divider"></div><div class="wl-col"><div class="wl-header loss">When Losing</div>';
      for (var wi=0;wi<wlRows.length;wi++) advHtml+='<div class="wl-row"><span class="wl-label">'+wlRows[wi][0]+'</span><span class="wl-val" style="color:var(--red)">'+wlRows[wi][2]+'</span></div>';
      advHtml+='</div></div>';
    }

    // Spell combos
    var combos=stats.spell_combos||[];
    if (combos.length>0) {
      advHtml+='<div style="font-size:12px;font-weight:700;margin:16px 0 6px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Summoner Spell Combos</div>';
      for (var ci=0;ci<Math.min(combos.length,8);ci++) {
        var sc=combos[ci], scWr=sc.games>0?Math.round(sc.wins/sc.games*100):0;
        var wrCls=scWr>=50?'green':'red';
        var s1Img=spellImg(sc.s1), s2Img=spellImg(sc.s2);
        var iconsHtml='<div class="spell-combo-icons">';
        if(s1Img) iconsHtml+='<img src="'+s1Img+'" />'; else iconsHtml+='<span style="font-size:10px;">S'+sc.s1+'</span>';
        if(s2Img) iconsHtml+='<img src="'+s2Img+'" />'; else iconsHtml+='<span style="font-size:10px;">S'+sc.s2+'</span>';
        iconsHtml+='</div>';
        advHtml+='<div class="spell-combo-row">'+iconsHtml+'<span class="spell-combo-games">'+sc.games+' games</span><span class="spell-combo-wr" style="color:var(--'+wrCls+')">'+scWr+'%</span></div>';
      }
    }

    advEl.innerHTML=advHtml;

    // ── Tab: Matchups ───────────────────────────────
    var muEl=document.getElementById('panel-matchups');
    var matchups=stats.enemy_matchups||[];
    if (matchups.length===0) {
      muEl.innerHTML='<div class="muted" style="padding:12px;">Not enough matchup data (need 2+ games vs same champion)</div>';
    } else {
      var muHtml='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;">';
      for (var mi=0;mi<matchups.length;mi++) {
        var mu=matchups[mi];
        var muWrCls=mu.winrate>=50?'green':'red';
        var muIcon=mu.champion_image?'<img class="mu-icon" src="'+esc(mu.champion_image)+'" />':'<div class="mu-icon" style="background:var(--border);"></div>';
        muHtml+='<div class="mu-card">'+muIcon+'<div class="mu-info"><div class="mu-name">'+esc(mu.champion_name)+'</div><div class="mu-wr" style="color:var(--'+muWrCls+')">'+mu.winrate+'% WR</div><div class="mu-games">'+mu.wins+'W '+mu.losses+'L ('+mu.games+' games)</div></div></div>';
      }
      muHtml+='</div>';
      muEl.innerHTML=muHtml;
    }

    // Lane matchups section within matchups tab
    var laneMu=stats.lane_matchups||[];
    if (laneMu.length>0) {
      var lmHtml='<div class="stats-section-title">Lane Opponents (same position)</div>';
      lmHtml+='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;">';
      for (var li=0;li<laneMu.length;li++) {
        var lm=laneMu[li];
        var lmWrCls=lm.winrate>=50?'green':'red';
        var lmIcon=lm.champion_image?'<img class="mu-icon" src="'+esc(lm.champion_image)+'" />':'<div class="mu-icon" style="background:var(--border);"></div>';
        lmHtml+='<div class="lane-mu-card">'+lmIcon+'<div class="mu-info"><div class="mu-name">'+esc(lm.champion_name)+'</div><div class="mu-wr" style="color:var(--'+lmWrCls+')">'+lm.winrate+'% WR</div><div class="lane-mu-vs"><span class="you">You: '+lm.my_avg_kills+'/'+lm.my_avg_deaths+'</span> vs <span class="opp">'+lm.opp_avg_kills+'/'+lm.opp_avg_deaths+'</span></div><div class="mu-games">'+lm.wins+'W '+lm.losses+'L ('+lm.games+')</div></div></div>';
      }
      lmHtml+='</div>';
      muEl.innerHTML+=lmHtml;
    }

    // ── Tab: Items ──────────────────────────────────
    var itemsEl=document.getElementById('panel-items');
    var commonItems=stats.common_items||[];
    if (commonItems.length===0) {
      itemsEl.innerHTML='<div class="muted" style="padding:12px;">Not enough data</div>';
    } else {
      var itHtml='<div class="stats-section-title">Most Built Items</div><div class="items-grid">';
      for (var ii=0;ii<commonItems.length;ii++) {
        var ci=commonItems[ii];
        var ciInfo=itemData[String(ci.item_id)];
        var ciName=ciInfo?ciInfo.name:'Item '+ci.item_id;
        var ciWrCls=ci.winrate>=50?'green':'red';
        itHtml+='<div class="item-stat-card"><img src="'+itemImg(ci.item_id)+'" title="'+esc(ciName)+'" /><div class="item-stat-info"><div class="item-stat-name">'+esc(ciName)+'</div><div class="item-stat-sub"><span style="color:var(--'+ciWrCls+')">'+ci.winrate+'%</span> &middot; '+ci.count+'x ('+ci.pick_rate+'%)</div></div></div>';
      }
      itHtml+='</div>';
      itemsEl.innerHTML=itHtml;
    }

    // ── Tab: Synergy ────────────────────────────────
    var syEl=document.getElementById('panel-synergy');
    var synergy=stats.ally_synergy||[];
    if (synergy.length===0) {
      syEl.innerHTML='<div class="muted" style="padding:12px;">Not enough synergy data (need 2+ games with same ally champion)</div>';
    } else {
      // Split into best and worst
      var sorted=synergy.slice().sort(function(a,b){return b.winrate-a.winrate||(b.games-a.games);});
      var best=sorted.filter(function(s){return s.winrate>=50;});
      var worst=sorted.filter(function(s){return s.winrate<50;}).reverse();

      var syHtml='';
      if (best.length>0) {
        syHtml+='<div class="stats-section-title" style="color:var(--green);">Best Synergy</div>';
        syHtml+='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;">';
        for (var bi=0;bi<Math.min(best.length,10);bi++) {
          var b=best[bi];
          var bIcon=b.champion_image?'<img class="sy-icon" src="'+esc(b.champion_image)+'" />':'<div class="sy-icon" style="background:var(--border);"></div>';
          syHtml+='<div class="sy-card">'+bIcon+'<div class="sy-info"><div class="sy-name">'+esc(b.champion_name)+'</div><div class="sy-wr" style="color:var(--green)">'+b.winrate+'% WR</div><div class="sy-games">'+b.wins+'W '+b.losses+'L ('+b.games+')</div></div></div>';
        }
        syHtml+='</div>';
      }
      if (worst.length>0) {
        syHtml+='<div class="stats-section-title" style="color:var(--red);">Worst Synergy</div>';
        syHtml+='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;">';
        for (var wi=0;wi<Math.min(worst.length,10);wi++) {
          var w=worst[wi];
          var wIcon=w.champion_image?'<img class="sy-icon" src="'+esc(w.champion_image)+'" />':'<div class="sy-icon" style="background:var(--border);"></div>';
          syHtml+='<div class="sy-card">'+wIcon+'<div class="sy-info"><div class="sy-name">'+esc(w.champion_name)+'</div><div class="sy-wr" style="color:var(--red)">'+w.winrate+'% WR</div><div class="sy-games">'+w.wins+'W '+w.losses+'L ('+w.games+')</div></div></div>';
        }
        syHtml+='</div>';
      }
      syEl.innerHTML=syHtml;
    }

    // ── Tab: Builds (#20) ─────────────────────────────
    var buildsEl=document.getElementById('panel-builds');
    var bRecs=currentPlayerData&&currentPlayerData.build_recommendations||[];
    if (bRecs.length===0) {
      buildsEl.innerHTML='<div class="muted" style="padding:12px;">Not enough data for build recommendations (need 2+ games per build)</div>';
    } else {
      var brHtml='<div class="stats-section-title">Best Builds by Champion</div><div class="build-recs">';
      for (var bi=0;bi<bRecs.length;bi++) {
        var br=bRecs[bi];
        var itemsHtml='';
        for (var ii=0;ii<br.items.length;ii++) {
          var info=itemData[String(br.items[ii])];
          itemsHtml+='<img src="'+itemImg(br.items[ii])+'" title="'+(info?esc(info.name):'Item '+br.items[ii])+'" />';
        }
        var wrCls=br.winrate>=55?'color:var(--green)':br.winrate<45?'color:var(--red)':'';
        brHtml+='<div class="build-rec-card"><div class="build-rec-champ">'+esc(br.champion_name)+'</div><div class="build-rec-items">'+itemsHtml+'</div><div class="build-rec-stats"><span style="'+wrCls+'">'+br.winrate+'% WR</span> &middot; '+br.games+' games</div></div>';
      }
      brHtml+='</div>';
      buildsEl.innerHTML=brHtml;
    }

    // ── Tab: Insights (#25, #29) ──────────────────────
    var insEl=document.getElementById('panel-insights');
    var insHtml='';

    // Patch Impact (#25)
    var pImpact=currentPlayerData&&currentPlayerData.patch_impact||[];
    if (pImpact.length>0) {
      insHtml+='<div class="stats-section-title">Performance Trends</div><p class="muted" style="font-size:11px;margin-bottom:8px;">Champions with significant WR changes (recent vs earlier games)</p><div class="patch-impact">';
      for (var pi=0;pi<pImpact.length;pi++) {
        var p=pImpact[pi];
        var cls=p.diff>0?'up':'down';
        var arrow=p.diff>0?'&#9650;':'&#9660;';
        insHtml+='<div class="patch-card"><span>'+esc(p.champion_name)+'</span><span class="patch-diff '+cls+'">'+arrow+' '+Math.abs(p.diff)+'%</span><span class="muted" style="font-size:10px;">'+p.old_wr+'% &rarr; '+p.new_wr+'%</span></div>';
      }
      insHtml+='</div>';
    }

    // Champion Recommendations (#29)
    var cRecs=currentPlayerData&&currentPlayerData.champion_recommendations||[];
    if (cRecs.length>0) {
      insHtml+='<div class="stats-section-title" style="margin-top:16px;">Champion Recommendations</div><div class="champ-recs">';
      for (var ci=0;ci<cRecs.length;ci++) {
        var cr=cRecs[ci];
        var crIcon=cr.champion_image?'<img src="'+esc(cr.champion_image)+'" />':'';
        insHtml+='<div class="champ-rec">'+crIcon+'<div><div class="champ-rec-name">'+esc(cr.champion_name)+'</div><div class="champ-rec-reason">'+esc(cr.reason)+'</div></div></div>';
      }
      insHtml+='</div>';
    }

    if (!insHtml) insHtml='<div class="muted" style="padding:12px;">Not enough data for insights yet</div>';
    insEl.innerHTML=insHtml;
  }

  // ── Head-to-Head (#4) ───────────────────────────
  function doH2HSearch() {
    var input=document.getElementById('h2h-input').value.trim();
    if (!input) return;
    var parts=input.split('#');
    if (parts.length<2) return;
    var name=parts[0].trim(), tag=parts.slice(1).join('#').trim();
    if (!name||!tag) return;
    document.getElementById('h2h-btn').disabled=true;
    var h2hPlatform=document.getElementById('region-select').value;
    fetch('/api/search?name='+encodeURIComponent(name)+'&tag='+encodeURIComponent(tag)+'&platform='+encodeURIComponent(h2hPlatform))
      .then(function(r){ if(!r.ok) throw new Error('Error'); return r.json(); })
      .then(function(data){
        document.getElementById('h2h-btn').disabled=false;
        renderH2H(currentPlayerData, data);
      })
      .catch(function(){ document.getElementById('h2h-btn').disabled=false; showToast('Could not find player for comparison','error'); });
  }

  function renderH2H(p1, p2) {
    var el=document.getElementById('h2h-content');
    if (!p1||!p2||!p1.stats||!p2.stats) { el.innerHTML='<div class="muted">Not enough data</div>'; return; }
    var s1=p1.stats, s2=p2.stats;
    var a1=p1.account||{}, a2=p2.account||{};

    var rows=[
      ['Win Rate', s1.winrate+'%', s2.winrate+'%', true],
      ['KDA', s1.avg_kda, s2.avg_kda, true],
      ['Avg Kills', s1.avg_kills, s2.avg_kills, true],
      ['Avg Deaths', s1.avg_deaths, s2.avg_deaths, false],
      ['Avg Assists', s1.avg_assists, s2.avg_assists, true],
      ['CS/min', s1.avg_cs_min, s2.avg_cs_min, true],
      ['Avg Damage', fmtNumber(s1.avg_damage), fmtNumber(s2.avg_damage), true],
      ['Avg Gold', fmtNumber(s1.avg_gold), fmtNumber(s2.avg_gold), true],
      ['Vision', s1.avg_vision, s2.avg_vision, true],
      ['KP', (s1.avg_kill_participation||0)+'%', (s2.avg_kill_participation||0)+'%', true],
      ['Dmg Share', (s1.avg_damage_share||0)+'%', (s2.avg_damage_share||0)+'%', true],
      ['Games', s1.games, s2.games, true],
    ];

    var html='<div class="h2h-grid"><div class="h2h-col"><div class="h2h-player-name">'+esc(a1.game_name)+'<br><span class="muted" style="font-size:12px;">#'+esc(a1.tag_line)+'</span></div>';
    for (var ri=0;ri<rows.length;ri++) {
      var r=rows[ri], n1=parseFloat(r[1])||0, n2=parseFloat(r[2])||0;
      var c1=n1===n2?'':(r[3]?(n1>n2?'better':'worse'):(n1<n2?'better':'worse'));
      html+='<div class="h2h-row"><span class="h2h-label">'+r[0]+'</span><span class="h2h-val '+c1+'">'+r[1]+'</span></div>';
    }
    html+='</div><div class="h2h-vs">VS</div><div class="h2h-col"><div class="h2h-player-name">'+esc(a2.game_name)+'<br><span class="muted" style="font-size:12px;">#'+esc(a2.tag_line)+'</span></div>';
    for (var ri=0;ri<rows.length;ri++) {
      var r=rows[ri], n1=parseFloat(r[1])||0, n2=parseFloat(r[2])||0;
      var c2=n1===n2?'':(r[3]?(n2>n1?'better':'worse'):(n2<n1?'better':'worse'));
      html+='<div class="h2h-row"><span class="h2h-label">'+r[0]+'</span><span class="h2h-val '+c2+'">'+r[2]+'</span></div>';
    }
    html+='</div></div>';
    el.innerHTML=html;
  }

  // ── Match Timeline (#1) ─────────────────────────
  function loadTimeline(matchId, container, participants) {
    if (timelineCache[matchId]) {
      renderTimeline(timelineCache[matchId], container, participants);
      return;
    }
    container.innerHTML='<div class="tl-loading">Loading timeline...</div>';
    fetch('/api/match/'+encodeURIComponent(matchId)+'/timeline')
      .then(function(r){ if(!r.ok) throw new Error('Error'); return r.json(); })
      .then(function(data){
        timelineCache[matchId]=data;
        renderTimeline(data, container, participants);
      })
      .catch(function(){ container.innerHTML='<div class="tl-loading">Timeline unavailable</div>'; });
  }

  function renderTimeline(data, container, matchParticipants) {
    if (!data||!data.events||data.events.length===0) { container.innerHTML='<div class="tl-loading">No events</div>'; return; }

    // Build participant id -> name/team map from match data
    var pMap={}, pTeam={};
    var allPlayers=(matchParticipants.allies||[]).concat(matchParticipants.enemies||[]);
    // Find which puuid is "me" to determine my team
    var myPuuid='';
    for (var j=0;j<(matchParticipants.allies||[]).length;j++) {
      if ((matchParticipants.allies[j]).is_me) { myPuuid=(matchParticipants.allies[j]).puuid; break; }
    }
    var myTeamIds={};
    if (data.participants) {
      for (var pid in data.participants) {
        var pp=data.participants[pid];
        for (var j=0;j<allPlayers.length;j++) {
          if (allPlayers[j].puuid===pp.puuid) {
            pMap[pid]=allPlayers[j].champion_name||'P'+pid;
            // allies have is_me or are in allies array
            var isAlly=false;
            for (var ak=0;ak<(matchParticipants.allies||[]).length;ak++) {
              if (matchParticipants.allies[ak].puuid===pp.puuid) { isAlly=true; break; }
            }
            pTeam[pid]=isAlly?'ally':'enemy';
            if (isAlly) myTeamIds[pid]=true;
            break;
          }
        }
        if (!pMap[pid]) pMap[pid]='P'+pid;
      }
    }
    function pName(id) { return pMap[id]||'P'+id; }

    var MONSTER_NAMES={DRAGON:'Dragon',BARON_NASHOR:'Baron',RIFTHERALD:'Herald',ELDER_DRAGON:'Elder Dragon',HORDE:'Voidgrubs'};
    var DRAGON_NAMES={FIRE_DRAGON:'Infernal',WATER_DRAGON:'Ocean',AIR_DRAGON:'Cloud',EARTH_DRAGON:'Mountain',HEXTECH_DRAGON:'Hextech',CHEMTECH_DRAGON:'Chemtech',ELDER_DRAGON:'Elder'};

    // Unique tab IDs
    var uid='tl'+Math.random().toString(36).substr(2,6);

    // ── Events list ──
    var evtHtml='<div class="tl-events">';
    var evts=data.events;
    for (var i=0;i<evts.length;i++) {
      var e=evts[i];
      var min=Math.floor((e.timestamp||0)/60000);
      var sec=Math.floor(((e.timestamp||0)%60000)/1000);
      var time=min+':'+('0'+sec).slice(-2);
      var icon='', desc='', cls='';

      if (e.type==='kill') {
        icon='&#9876;'; cls='tl-kill';
        desc='<strong>'+esc(pName(e.killer_id))+'</strong> killed <strong>'+esc(pName(e.victim_id))+'</strong>';
        if (e.assists&&e.assists.length>0) {
          var aNames=[];
          for (var a=0;a<e.assists.length;a++) aNames.push(pName(e.assists[a]));
          desc+=' <span class="muted">(assist: '+esc(aNames.join(', '))+')</span>';
        }
      } else if (e.type==='objective') {
        icon='&#9733;'; cls='tl-objective';
        var mName=MONSTER_NAMES[e.monster]||e.monster||'Monster';
        if (e.monster_sub) mName=(DRAGON_NAMES[e.monster_sub]||e.monster_sub)+' '+mName;
        var teamStr=e.team_id===100?'<span style="color:var(--blue)">Blue</span>':'<span style="color:var(--red)">Red</span>';
        desc=teamStr+' team killed <strong>'+esc(mName)+'</strong>';
      } else if (e.type==='building') {
        icon='&#9960;'; cls='tl-building';
        var bName=e.building==='TOWER_BUILDING'?'Tower':'Inhibitor';
        var lane=(e.lane||'').replace('_LANE','');
        var towerType=e.tower||'';
        if (towerType==='OUTER_TURRET') bName='Outer Tower';
        else if (towerType==='INNER_TURRET') bName='Inner Tower';
        else if (towerType==='BASE_TURRET') bName='Base Tower';
        else if (towerType==='NEXUS_TURRET') bName='Nexus Tower';
        var teamStr=e.team_id===100?'<span style="color:var(--red)">Red</span>':'<span style="color:var(--blue)">Blue</span>';
        desc=teamStr+' '+esc(lane)+' '+esc(bName)+' destroyed';
      }

      evtHtml+='<div class="tl-event"><span class="tl-time">'+time+'</span><span class="tl-icon '+cls+'">'+icon+'</span><span class="tl-desc '+cls+'">'+desc+'</span></div>';
    }
    evtHtml+='</div>';

    // ── Kill Map SVG ──
    // Map coordinates: Riot uses ~0-15000 range, we map to 400x400 SVG
    var MAP_SIZE=15000, SVG_SIZE=400;
    var killMapHtml='<div class="kill-map-wrap"><svg viewBox="0 0 '+SVG_SIZE+' '+SVG_SIZE+'" xmlns="http://www.w3.org/2000/svg">';
    // Background (dark map)
    killMapHtml+='<rect width="'+SVG_SIZE+'" height="'+SVG_SIZE+'" fill="#0d1117" rx="4"/>';
    // Map grid lines for orientation
    for (var g=0;g<5;g++) {
      var gp=Math.round(g*SVG_SIZE/4);
      killMapHtml+='<line x1="'+gp+'" y1="0" x2="'+gp+'" y2="'+SVG_SIZE+'" stroke="rgba(255,255,255,0.04)"/>';
      killMapHtml+='<line x1="0" y1="'+gp+'" x2="'+SVG_SIZE+'" y2="'+gp+'" stroke="rgba(255,255,255,0.04)"/>';
    }
    // Diagonal (base to base)
    killMapHtml+='<line x1="0" y1="'+SVG_SIZE+'" x2="'+SVG_SIZE+'" y2="0" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4,4"/>';
    // Lane indicators
    killMapHtml+='<text x="'+Math.round(SVG_SIZE*0.08)+'" y="'+Math.round(SVG_SIZE*0.15)+'" fill="rgba(255,255,255,0.12)" font-size="10">TOP</text>';
    killMapHtml+='<text x="'+Math.round(SVG_SIZE*0.45)+'" y="'+Math.round(SVG_SIZE*0.52)+'" fill="rgba(255,255,255,0.12)" font-size="10">MID</text>';
    killMapHtml+='<text x="'+Math.round(SVG_SIZE*0.82)+'" y="'+Math.round(SVG_SIZE*0.92)+'" fill="rgba(255,255,255,0.12)" font-size="10">BOT</text>';
    // Blue/Red base markers
    killMapHtml+='<circle cx="'+Math.round(SVG_SIZE*0.04)+'" cy="'+Math.round(SVG_SIZE*0.96)+'" r="8" fill="rgba(59,130,246,0.2)" stroke="rgba(59,130,246,0.4)"/>';
    killMapHtml+='<circle cx="'+Math.round(SVG_SIZE*0.96)+'" cy="'+Math.round(SVG_SIZE*0.04)+'" r="8" fill="rgba(239,68,68,0.2)" stroke="rgba(239,68,68,0.4)"/>';

    // Plot kill events
    var killEvents=[];
    for (var i=0;i<evts.length;i++) {
      if (evts[i].type==='kill'&&evts[i].x!=null&&evts[i].y!=null) killEvents.push(evts[i]);
    }
    for (var i=0;i<killEvents.length;i++) {
      var ke=killEvents[i];
      // Map coords: x goes right, y goes up in Riot but SVG y goes down
      var sx=Math.round(ke.x/MAP_SIZE*SVG_SIZE);
      var sy=SVG_SIZE-Math.round(ke.y/MAP_SIZE*SVG_SIZE);
      sx=Math.max(4,Math.min(SVG_SIZE-4,sx));
      sy=Math.max(4,Math.min(SVG_SIZE-4,sy));

      var isMyKill=myTeamIds[String(ke.killer_id)];
      var isMyDeath=myTeamIds[String(ke.victim_id)];
      var color=isMyKill?'#22c55e':'#ef4444';
      var opacity=isMyKill?0.8:0.7;
      var r=isMyKill?5:4;
      killMapHtml+='<circle cx="'+sx+'" cy="'+sy+'" r="'+r+'" fill="'+color+'" fill-opacity="'+opacity+'"><title>'+Math.floor(ke.timestamp/60000)+'m — '+esc(pName(ke.killer_id))+' killed '+esc(pName(ke.victim_id))+'</title></circle>';
    }

    killMapHtml+='</svg><div class="km-legend"><span><span class="dot-kill"></span> Your team kills</span><span><span class="dot-death"></span> Enemy kills</span></div></div>';

    // ── Gold Difference Graph ──
    var goldHtml='';
    var gf=data.gold_frames;
    if (gf&&gf.length>1) {
      // Determine which side is "my" team (blue=participants 1-5, red=6-10)
      var myIsBlue=false;
      for (var pid in myTeamIds) { if (parseInt(pid)<=5) { myIsBlue=true; break; } }

      var GW=600, GH=200, PAD_L=45, PAD_R=10, PAD_T=20, PAD_B=25;
      var plotW=GW-PAD_L-PAD_R, plotH=GH-PAD_T-PAD_B;
      var diffs=[];
      var minDiff=0, maxDiff=0;
      for (var i=0;i<gf.length;i++) {
        var d=myIsBlue?(gf[i].blue_gold-gf[i].red_gold):(gf[i].red_gold-gf[i].blue_gold);
        diffs.push(d);
        if (d<minDiff) minDiff=d;
        if (d>maxDiff) maxDiff=d;
      }
      // Ensure symmetric range
      var absMax=Math.max(Math.abs(minDiff),Math.abs(maxDiff),500);
      minDiff=-absMax; maxDiff=absMax;
      var range=maxDiff-minDiff;

      goldHtml='<div class="gold-graph-wrap"><svg viewBox="0 0 '+GW+' '+GH+'" xmlns="http://www.w3.org/2000/svg">';
      goldHtml+='<rect width="'+GW+'" height="'+GH+'" fill="transparent"/>';

      // Zero line
      var zeroY=PAD_T+Math.round((maxDiff/(range||1))*plotH);
      goldHtml+='<line x1="'+PAD_L+'" y1="'+zeroY+'" x2="'+(GW-PAD_R)+'" y2="'+zeroY+'" stroke="rgba(255,255,255,0.2)" stroke-dasharray="4,2"/>';
      goldHtml+='<text x="'+(PAD_L-4)+'" y="'+(zeroY+3)+'" fill="rgba(255,255,255,0.4)" font-size="9" text-anchor="end">0</text>';

      // Y axis labels
      var ySteps=[Math.round(absMax/2), absMax];
      for (var s=0;s<ySteps.length;s++) {
        var val=ySteps[s];
        var yPos=PAD_T+Math.round(((maxDiff-val)/(range||1))*plotH);
        var yNeg=PAD_T+Math.round(((maxDiff+val)/(range||1))*plotH);
        goldHtml+='<text x="'+(PAD_L-4)+'" y="'+(yPos+3)+'" fill="rgba(34,197,94,0.5)" font-size="8" text-anchor="end">+'+fmtNumber(val)+'</text>';
        goldHtml+='<line x1="'+PAD_L+'" y1="'+yPos+'" x2="'+(GW-PAD_R)+'" y2="'+yPos+'" stroke="rgba(255,255,255,0.04)"/>';
        goldHtml+='<text x="'+(PAD_L-4)+'" y="'+(yNeg+3)+'" fill="rgba(239,68,68,0.5)" font-size="8" text-anchor="end">-'+fmtNumber(val)+'</text>';
        goldHtml+='<line x1="'+PAD_L+'" y1="'+yNeg+'" x2="'+(GW-PAD_R)+'" y2="'+yNeg+'" stroke="rgba(255,255,255,0.04)"/>';
      }

      // Fill area above/below zero
      var pts=[];
      for (var i=0;i<diffs.length;i++) {
        var px=PAD_L+Math.round(i/(diffs.length-1)*plotW);
        var py=PAD_T+Math.round(((maxDiff-diffs[i])/(range||1))*plotH);
        pts.push({x:px,y:py});
      }

      // Positive fill (green area above zero)
      var posPath='M'+PAD_L+','+zeroY;
      for (var i=0;i<pts.length;i++) {
        var cy=Math.min(pts[i].y,zeroY);
        posPath+=' L'+pts[i].x+','+cy;
      }
      posPath+=' L'+pts[pts.length-1].x+','+zeroY+' Z';
      goldHtml+='<path d="'+posPath+'" fill="rgba(34,197,94,0.12)"/>';

      // Negative fill (red area below zero)
      var negPath='M'+PAD_L+','+zeroY;
      for (var i=0;i<pts.length;i++) {
        var cy=Math.max(pts[i].y,zeroY);
        negPath+=' L'+pts[i].x+','+cy;
      }
      negPath+=' L'+pts[pts.length-1].x+','+zeroY+' Z';
      goldHtml+='<path d="'+negPath+'" fill="rgba(239,68,68,0.12)"/>';

      // Line
      var linePath='M'+pts[0].x+','+pts[0].y;
      for (var i=1;i<pts.length;i++) linePath+=' L'+pts[i].x+','+pts[i].y;
      goldHtml+='<path d="'+linePath+'" fill="none" stroke="var(--gold)" stroke-width="2"/>';

      // Dots at each frame
      for (var i=0;i<pts.length;i++) {
        var min=Math.round((gf[i].timestamp||0)/60000);
        goldHtml+='<circle cx="'+pts[i].x+'" cy="'+pts[i].y+'" r="3" fill="var(--gold)" fill-opacity="0.6"><title>'+min+'m: '+(diffs[i]>=0?'+':'')+fmtNumber(diffs[i])+' gold</title></circle>';
      }

      // X axis labels (time)
      var maxMin=Math.round((gf[gf.length-1].timestamp||0)/60000);
      var xStep=maxMin<=20?5:10;
      for (var t=0;t<=maxMin;t+=xStep) {
        var xp=PAD_L+Math.round((t/maxMin)*plotW);
        goldHtml+='<text x="'+xp+'" y="'+(GH-5)+'" fill="rgba(255,255,255,0.3)" font-size="9" text-anchor="middle">'+t+'m</text>';
      }

      goldHtml+='</svg><div class="gg-legend"><span style="color:var(--green)">&#9650; Your team ahead</span><span style="color:var(--red)">&#9660; Enemy ahead</span></div></div>';
    }

    // ── Assemble with tabs ──
    var hasKillMap=killEvents.length>0;
    var hasGold=goldHtml.length>0;

    var html='<div class="tl-container"><div class="tl-tabs">';
    html+='<div class="tl-tab active" data-tl-panel="'+uid+'-events">Events</div>';
    if (hasKillMap) html+='<div class="tl-tab" data-tl-panel="'+uid+'-killmap">Kill Map</div>';
    if (hasGold) html+='<div class="tl-tab" data-tl-panel="'+uid+'-gold">Gold Graph</div>';
    html+='</div>';
    html+='<div class="tl-panel active" id="'+uid+'-events">'+evtHtml+'</div>';
    if (hasKillMap) html+='<div class="tl-panel" id="'+uid+'-killmap">'+killMapHtml+'</div>';
    if (hasGold) html+='<div class="tl-panel" id="'+uid+'-gold">'+goldHtml+'</div>';
    html+='</div>';
    container.innerHTML=html;

    // Wire up tab switching
    var tabBtns=container.querySelectorAll('.tl-tab');
    for (var t=0;t<tabBtns.length;t++) {
      tabBtns[t].addEventListener('click', function(ev){
        var panelId=ev.target.getAttribute('data-tl-panel');
        var allTabs=ev.target.parentNode.querySelectorAll('.tl-tab');
        var allPanels=ev.target.parentNode.parentNode.querySelectorAll('.tl-panel');
        for (var tt=0;tt<allTabs.length;tt++) allTabs[tt].classList.toggle('active',allTabs[tt]===ev.target);
        for (var tt=0;tt<allPanels.length;tt++) allPanels[tt].classList.toggle('active',allPanels[tt].id===panelId);
      });
    }
  }

  // ── Tilt Detector ────────────────────────────────
  function renderTiltDetector(matches) {
    var banner=document.getElementById('tilt-banner');
    if (!matches||matches.length<3) { banner.classList.remove('visible'); return; }

    // Count current losing streak from most recent match
    var streak=0;
    for (var i=0;i<matches.length;i++) { if (!matches[i].win) streak++; else break; }

    if (streak<3) { banner.classList.remove('visible'); return; }

    // Compute tilt stats vs overall
    var tK=0,tD=0,tA=0,tDmg=0,tScore=0;
    var aK=0,aD=0,aA=0,aDmg=0,aScore=0;
    for (var i=0;i<matches.length;i++) {
      var m=matches[i];
      aK+=m.kills; aD+=m.deaths; aA+=m.assists; aDmg+=m.total_damage; aScore+=(m._score||0);
      if (i<streak) { tK+=m.kills; tD+=m.deaths; tA+=m.assists; tDmg+=m.total_damage; tScore+=(m._score||0); }
    }
    var n=matches.length;
    var tKda=tD>0?((tK+tA)/tD).toFixed(1):'Perfect';
    var aKda=aD>0?((aK+aA)/aD).toFixed(1):'Perfect';

    banner.classList.add('visible');
    banner.innerHTML='<div class="tilt-title"><span style="font-size:16px;">&#9888;</span> TILT ALERT: '+streak+' losses in a row</div>'+
      '<div class="tilt-compare">'+
      '<div class="tilt-col"><div class="tilt-col-label" style="color:var(--red);">During Tilt ('+streak+' games)</div>'+
        '<div class="tilt-stat"><span class="tilt-stat-name">KDA</span><span class="tilt-stat-val" style="color:var(--red)">'+Math.round(tK/streak*10)/10+'/'+Math.round(tD/streak*10)/10+'/'+Math.round(tA/streak*10)/10+' ('+tKda+')</span></div>'+
        '<div class="tilt-stat"><span class="tilt-stat-name">Avg Damage</span><span class="tilt-stat-val">'+fmtNumber(Math.round(tDmg/streak))+'</span></div>'+
        '<div class="tilt-stat"><span class="tilt-stat-name">Avg Score</span><span class="tilt-stat-val"><span class="perf-score '+scoreClass(tScore/streak)+'">'+(tScore/streak).toFixed(1)+'</span></span></div>'+
      '</div>'+
      '<div class="tilt-col"><div class="tilt-col-label" style="color:var(--green);">Overall ('+n+' games)</div>'+
        '<div class="tilt-stat"><span class="tilt-stat-name">KDA</span><span class="tilt-stat-val" style="color:var(--green)">'+Math.round(aK/n*10)/10+'/'+Math.round(aD/n*10)/10+'/'+Math.round(aA/n*10)/10+' ('+aKda+')</span></div>'+
        '<div class="tilt-stat"><span class="tilt-stat-name">Avg Damage</span><span class="tilt-stat-val">'+fmtNumber(Math.round(aDmg/n))+'</span></div>'+
        '<div class="tilt-stat"><span class="tilt-stat-name">Avg Score</span><span class="tilt-stat-val"><span class="perf-score '+scoreClass(aScore/n)+'">'+(aScore/n).toFixed(1)+'</span></span></div>'+
      '</div></div>';
  }

  // ── Extended Stats (Duo Partners + WR Chart) ───────
  function loadExtendedStats() {
    if (!currentPuuid) return;
    var section=document.getElementById('extended-stats');
    fetch('/api/player/'+currentPuuid+'/stats')
      .then(function(r){return r.json();})
      .then(function(data){
        var hasDuo=(data.duo_partners&&data.duo_partners.length>0);
        var hasWr=(data.wr_history&&data.wr_history.length>0);
        var hasLp=(data.lp_history&&data.lp_history.solo&&data.lp_history.solo.length>1)||(data.lp_history&&data.lp_history.flex&&data.lp_history.flex.length>1);
        var hasHeatmap=allMatches.length>0;
        var hasW4=(data.queue_breakdown&&data.queue_breakdown.length>0)||(data.role_distribution&&data.role_distribution.length>0)||(data.surrender_stats&&data.surrender_stats.total_games)||(data.time_analysis&&data.time_analysis.by_hour&&data.time_analysis.by_hour.length>0);
        var hasW5=(data.peer_percentiles&&data.peer_percentiles.sample_size)||(data.vision_trend&&data.vision_trend.length>0)||(data.early_game&&data.early_game.total_games);
        if (!hasDuo&&!hasWr&&!hasLp&&!hasHeatmap&&!hasW4&&!hasW5) { section.classList.remove('visible'); return; }
        section.classList.add('visible');

        // Duo Partners
        var duoEl=document.getElementById('ext-duo');
        if (hasDuo) {
          var html='<div class="ext-title">Duo Partners</div>';
          for (var i=0;i<Math.min(data.duo_partners.length,8);i++) {
            var d=data.duo_partners[i], wr=d.games_together>0?Math.round(d.wins_together/d.games_together*100):0;
            var wrCls=wr>=50?'green':'red';
            html+='<div class="duo-row"><div class="duo-name">'+esc(d.summoner_name)+(d.tag_line?' <span class="muted">#'+esc(d.tag_line)+'</span>':'')+'</div><div class="duo-games">'+d.games_together+'G</div><div class="duo-wr" style="color:var(--'+wrCls+')">'+wr+'%</div></div>';
          }
          duoEl.innerHTML=html;
        } else {
          duoEl.innerHTML='<div class="ext-title">Duo Partners</div><div class="muted" style="font-size:12px;">Not enough data</div>';
        }

        // WR History Chart
        var wrEl=document.getElementById('ext-wr-chart');
        if (hasWr) {
          var days=data.wr_history;
          var maxGames=1;
          for (var k=0;k<days.length;k++) { if(days[k].games>maxGames) maxGames=days[k].games; }
          var barsHtml='<div class="wr-chart">';
          for (var k=0;k<days.length;k++) {
            var day=days[k], h=Math.max(4,Math.round(day.games/maxGames*80));
            var dayWr=day.games>0?Math.round(day.wins/day.games*100):50;
            var cls=dayWr>=60?'win':dayWr<=40?'loss':'mixed';
            barsHtml+='<div class="wr-chart-bar '+cls+'" style="height:'+h+'px;" title="'+day.day+': '+day.wins+'W '+day.losses+'L ('+dayWr+'% WR)"></div>';
          }
          barsHtml+='</div>';
          var labels='<div class="wr-chart-labels"><span>'+(days[0]?days[0].day:'')+'</span><span>'+(days[days.length-1]?days[days.length-1].day:'')+'</span></div>';
          wrEl.innerHTML='<div class="ext-title">Win Rate (Last 30 Days)</div>'+barsHtml+labels;
        } else {
          wrEl.innerHTML='<div class="ext-title">Win Rate History</div><div class="muted" style="font-size:12px;">Not enough data</div>';
        }

        // Day-of-Week Win Rate (#12)
        var dowEl=document.getElementById('ext-dow-wr');
        if (allMatches.length>0) {
          var DAY_SHORT=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
          var dowStats=[];
          for (var di=0;di<7;di++) dowStats.push({games:0,wins:0});
          for (var di=0;di<allMatches.length;di++) {
            var gc=allMatches[di].game_creation;
            if (!gc) continue;
            var dow=(new Date(gc).getDay()+6)%7;
            dowStats[dow].games++;
            if (allMatches[di].win) dowStats[dow].wins++;
          }
          var dowHtml='<div class="ext-title">Win Rate by Day</div><div class="dow-grid">';
          for (var di=0;di<7;di++) {
            var ds=dowStats[di];
            var dWr=ds.games>0?Math.round(ds.wins/ds.games*100):0;
            var dClr=ds.games===0?'var(--text-muted)':dWr>=55?'var(--green)':dWr<=45?'var(--red)':'var(--text)';
            dowHtml+='<div class="dow-cell"><div class="dow-cell-day">'+DAY_SHORT[di]+'</div><div class="dow-cell-wr" style="color:'+dClr+'">'+(ds.games>0?dWr+'%':'—')+'</div><div class="dow-cell-games">'+ds.games+'G</div></div>';
          }
          dowHtml+='</div>';
          dowEl.innerHTML=dowHtml;
          dowEl.style.display='';
        } else {
          dowEl.style.display='none';
        }

        // Streak Timeline (#17)
        var stEl=document.getElementById('ext-streak-timeline');
        if (allMatches.length>0) {
          var stHtml='<div class="ext-title">Win/Loss Timeline</div><div class="streak-timeline">';
          // Reverse so oldest is left
          for (var si=allMatches.length-1;si>=0;si--) {
            var sm=allMatches[si];
            stHtml+='<div class="streak-block '+(sm.win?'w':'l')+'" title="'+(sm.champion_name||'?')+' '+(sm.win?'W':'L')+' '+esc(sm.game_duration||'')+'"></div>';
          }
          stHtml+='</div>';
          // Compute longest streaks
          var longestW=0,longestL=0,curW=0,curL=0;
          for (var si=0;si<allMatches.length;si++) {
            if (allMatches[si].win) { curW++; curL=0; if(curW>longestW)longestW=curW; }
            else { curL++; curW=0; if(curL>longestL)longestL=curL; }
          }
          stHtml+='<div style="display:flex;gap:12px;margin-top:6px;font-size:11px;">';
          stHtml+='<span style="color:var(--green);">Best: '+longestW+'W</span>';
          stHtml+='<span style="color:var(--red);">Worst: '+longestL+'L</span>';
          stHtml+='</div>';
          stEl.innerHTML=stHtml;
          stEl.style.display='';
        } else {
          stEl.style.display='none';
        }

        // Activity Heatmap
        var hmEl=document.getElementById('ext-heatmap');
        if (hasHeatmap) {
          var DAY_NAMES=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
          var gridCount={}; var gridWins={}; var maxCount=0;
          for (var hi=0;hi<allMatches.length;hi++) {
            var hm=allMatches[hi];
            var gc=hm.game_creation;
            if (!gc) continue;
            var dt=new Date(gc);
            var dow=(dt.getDay()+6)%7; // Mon=0..Sun=6
            var hr=dt.getHours();
            var key=dow+'_'+hr;
            gridCount[key]=(gridCount[key]||0)+1;
            if (hm.win) gridWins[key]=(gridWins[key]||0)+1;
            if(gridCount[key]>maxCount) maxCount=gridCount[key];
          }
          var hmHtml='<div class="ext-title">Activity &amp; Win Rate Heatmap <span style="font-size:10px;color:var(--text-muted);font-weight:400">green=good WR · red=bad WR · gold=even</span></div><div class="heatmap-grid">';
          // Hour labels row
          hmHtml+='<div></div>';
          for (var hh=0;hh<24;hh++) hmHtml+='<div class="heatmap-hour-label">'+(hh%3===0?hh:'')+'</div>';
          // Day rows
          for (var dd=0;dd<7;dd++) {
            hmHtml+='<div class="heatmap-day">'+DAY_NAMES[dd]+'</div>';
            for (var hh=0;hh<24;hh++) {
              var cnt=gridCount[dd+'_'+hh]||0;
              var wins=gridWins[dd+'_'+hh]||0;
              var bg,hmTitle;
              if (cnt===0) {
                bg='rgba(255,255,255,0.03)';
                hmTitle=DAY_NAMES[dd]+' '+hh+':00 — no games';
              } else {
                var wr=wins/cnt;
                var intensity=Math.max(0.2,cnt/maxCount);
                var cr,cg,cb;
                if (wr>=0.6) { cr=34;cg=197;cb=94; }
                else if (wr<=0.4) { cr=239;cg=68;cb=68; }
                else { cr=200;cg=155;cb=60; }
                bg='rgba('+cr+','+cg+','+cb+','+intensity.toFixed(2)+')';
                hmTitle=DAY_NAMES[dd]+' '+hh+':00 — '+cnt+' game'+(cnt!==1?'s':'')+' ('+Math.round(wr*100)+'% WR)';
              }
              hmHtml+='<div class="heatmap-cell" style="background:'+bg+';" title="'+hmTitle+'"></div>';
            }
          }
          hmHtml+='</div>';
          hmEl.innerHTML=hmHtml;
          hmEl.style.display='';
        } else {
          hmEl.style.display='none';
        }

        // LP History Chart
        var lpEl=document.getElementById('ext-lp-chart');
        var RANK_VALUES={IRON:0,BRONZE:400,SILVER:800,GOLD:1200,PLATINUM:1600,EMERALD:2000,DIAMOND:2400,MASTER:2800,GRANDMASTER:2800,CHALLENGER:2800};
        var DIVISION_VALUES={IV:0,III:100,II:200,I:300};
        function lpToAbsolute(entry) {
          return (RANK_VALUES[entry.tier]||0)+(DIVISION_VALUES[entry.rank]||0)+(entry.league_points||0);
        }
        function lpLabel(entry) { return entry.tier+' '+entry.rank+' '+(entry.league_points||0)+' LP'; }

        var soloLp=(data.lp_history&&data.lp_history.solo)||[];
        var flexLp=(data.lp_history&&data.lp_history.flex)||[];
        var lpEntries=soloLp.length>1?soloLp:flexLp;
        var lpQueueName=soloLp.length>1?'Solo/Duo':'Flex';

        if (lpEntries.length>1) {
          lpEntries=lpEntries.slice().reverse(); // oldest first
          var absVals=[]; for (var q=0;q<lpEntries.length;q++) absVals.push(lpToAbsolute(lpEntries[q]));
          var minLp=absVals[0],maxLp=absVals[0];
          for (var q=1;q<absVals.length;q++) { if(absVals[q]<minLp)minLp=absVals[q]; if(absVals[q]>maxLp)maxLp=absVals[q]; }
          var lpRange=maxLp-minLp; if(lpRange<20) lpRange=20;

          // SVG line chart
          var LW=600, LH=140, LP_L=65, LP_R=10, LP_T=15, LP_B=20;
          var lpPlotW=LW-LP_L-LP_R, lpPlotH=LH-LP_T-LP_B;
          var lpSvg='<div class="lp-line-chart"><svg viewBox="0 0 '+LW+' '+LH+'" xmlns="http://www.w3.org/2000/svg">';
          lpSvg+='<rect width="'+LW+'" height="'+LH+'" fill="transparent"/>';

          // Tier grid lines
          var TIER_NAMES=['IRON','BRONZE','SILVER','GOLD','PLATINUM','EMERALD','DIAMOND','MASTER'];
          var TIER_COLORS={'IRON':'#8b7355','BRONZE':'#cd7f32','SILVER':'#c0c0c0','GOLD':'#ffd700','PLATINUM':'#00cec9','EMERALD':'#2ecc71','DIAMOND':'#9b59b6','MASTER':'#e74c3c'};
          for (var ti=0;ti<TIER_NAMES.length;ti++) {
            var tierVal=RANK_VALUES[TIER_NAMES[ti]];
            if (tierVal>=minLp-50&&tierVal<=maxLp+50) {
              var ty=LP_T+Math.round(((maxLp-tierVal)/(lpRange||1))*lpPlotH);
              if (ty>=LP_T&&ty<=LH-LP_B) {
                var tc=TIER_COLORS[TIER_NAMES[ti]]||'rgba(255,255,255,0.2)';
                lpSvg+='<line x1="'+LP_L+'" y1="'+ty+'" x2="'+(LW-LP_R)+'" y2="'+ty+'" stroke="'+tc+'" stroke-opacity="0.2" stroke-dasharray="3,3"/>';
                lpSvg+='<text x="'+(LP_L-4)+'" y="'+(ty+3)+'" fill="'+tc+'" font-size="8" text-anchor="end" fill-opacity="0.6">'+TIER_NAMES[ti]+'</text>';
              }
            }
          }

          // Build points
          var lpPts=[];
          for (var q=0;q<absVals.length;q++) {
            var px=LP_L+Math.round(q/(absVals.length-1)*lpPlotW);
            var py=LP_T+Math.round(((maxLp-absVals[q])/(lpRange||1))*lpPlotH);
            lpPts.push({x:px,y:py});
          }

          // Gradient fill under line
          lpSvg+='<defs><linearGradient id="lpGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--gold)" stop-opacity="0.3"/><stop offset="100%" stop-color="var(--gold)" stop-opacity="0.02"/></linearGradient></defs>';
          var fillPath='M'+lpPts[0].x+','+lpPts[0].y;
          for (var q=1;q<lpPts.length;q++) fillPath+=' L'+lpPts[q].x+','+lpPts[q].y;
          fillPath+=' L'+lpPts[lpPts.length-1].x+','+(LH-LP_B)+' L'+lpPts[0].x+','+(LH-LP_B)+' Z';
          lpSvg+='<path d="'+fillPath+'" fill="url(#lpGrad)"/>';

          // Line segments colored by direction
          for (var q=1;q<lpPts.length;q++) {
            var segColor=absVals[q]>=absVals[q-1]?'var(--green)':'var(--red)';
            lpSvg+='<line x1="'+lpPts[q-1].x+'" y1="'+lpPts[q-1].y+'" x2="'+lpPts[q].x+'" y2="'+lpPts[q].y+'" stroke="'+segColor+'" stroke-width="2"/>';
          }

          // Dots
          for (var q=0;q<lpPts.length;q++) {
            var dotColor=q>0?(absVals[q]>=absVals[q-1]?'var(--green)':'var(--red)'):'var(--gold)';
            var dateStr=lpEntries[q].recorded_at?lpEntries[q].recorded_at.substring(0,10):'';
            lpSvg+='<circle cx="'+lpPts[q].x+'" cy="'+lpPts[q].y+'" r="3" fill="'+dotColor+'"><title>'+lpLabel(lpEntries[q])+(dateStr?' ('+dateStr+')':'')+'</title></circle>';
          }

          lpSvg+='</svg></div>';
          var lpLabels='<div class="lp-line-labels"><span>'+lpLabel(lpEntries[0])+'</span><span>'+lpLabel(lpEntries[lpEntries.length-1])+'</span></div>';
          lpEl.innerHTML='<div class="ext-title">LP History — '+esc(lpQueueName)+'</div>'+lpSvg+lpLabels;
          lpEl.style.display='';
        } else {
          lpEl.style.display='none';
        }

        // ── LP Velocity (#new) ──────────────────────────
        var velEl=document.getElementById('ext-lp-velocity');
        if (velEl&&data.lp_velocity) {
          var v=data.lp_velocity;
          var vColor=v.lp_per_day>0?'var(--green)':v.lp_per_day<0?'var(--red)':'var(--text-muted)';
          var trendIcon=v.trend==='climbing'?'↑':v.trend==='falling'?'↓':'→';
          var predHtml=v.days_to_next_div?'<div class="vel-predict">Next division in ~<strong>'+v.days_to_next_div+'d</strong></div>':'';
          velEl.innerHTML='<div class="ext-title">LP Velocity</div>'
            +'<div class="vel-row"><span class="vel-value" style="color:'+vColor+'">'+(v.lp_per_day>0?'+':'')+v.lp_per_day+' LP/day</span>'
            +'<span class="vel-trend" style="color:'+vColor+'">'+trendIcon+' '+v.trend+'</span></div>'
            +predHtml;
          velEl.style.display='';
        } else if (velEl) {
          velEl.style.display='none';
        }

        // ── Personal Enemies (#new) ─────────────────────
        var enemyEl=document.getElementById('ext-personal-enemies');
        if (enemyEl&&data.personal_enemies&&data.personal_enemies.length>0) {
          var eHtml='<div class="ext-title">&#128480; Personal Enemies</div>';
          for (var ei=0;ei<data.personal_enemies.length;ei++) {
            var en=data.personal_enemies[ei];
            var eWr=Math.round(tonumberOrZero(en.win_rate));
            var eClr=eWr<40?'var(--red)':eWr<50?'var(--yellow)':'var(--green)';
            eHtml+='<div class="enemy-row">'
              +'<span class="enemy-champ">'+esc(en.enemy_champion||'?')+'</span>'
              +'<span class="enemy-games muted">'+tonumberOrZero(en.games)+'G</span>'
              +'<span class="enemy-wr" style="color:'+eClr+'">'+eWr+'% WR</span>'
            +'</div>';
          }
          enemyEl.innerHTML=eHtml;
          enemyEl.style.display='';
        } else if (enemyEl) {
          enemyEl.style.display='none';
        }

        // ── Records (#11) ────────────────────────────────
        var recEl=document.getElementById('ext-records');
        if (recEl&&data.records&&data.records.length>0) {
          var rHtml='<div class="ext-title">Personal Records</div>';
          var recLabels={most_kills:'Most Kills',most_assists:'Most Assists',most_cs:'Most CS',most_damage:'Most Damage',most_gold:'Most Gold',best_kda:'Best KDA Score',most_vision:'Best Vision',best_cs_per_min:'Best CS/min',lowest_deaths:'Fewest Deaths',penta_kills:'Pentakills'};
          for (var ri=0;ri<data.records.length;ri++) {
            var rec=data.records[ri];
            var label=recLabels[rec.record_type]||rec.record_type;
            var val=rec.record_type==='best_cs_per_min'?parseFloat(rec.value).toFixed(1):Math.round(rec.value);
            if (rec.record_type==='most_damage'||rec.record_type==='most_gold') val=fmtNumber(rec.value);
            rHtml+='<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:12px;"><span>'+label+'</span><span><strong>'+val+'</strong>'+(rec.champion_name?' <span class="muted">'+esc(rec.champion_name)+'</span>':'')+'</span></div>';
          }
          recEl.innerHTML=rHtml;
          recEl.style.display='';
        } else if (recEl) { recEl.style.display='none'; }

        // ── Season History (#6) ──────────────────────────
        var shEl=document.getElementById('ext-season-history');
        if (shEl&&data.season_history&&data.season_history.length>0) {
          var shHtml='<div class="ext-title">Season History</div>';
          for (var si=0;si<data.season_history.length;si++) {
            var sh=data.season_history[si];
            var qName=sh.queue_type==='RANKED_SOLO_5x5'?'Solo':'Flex';
            var tierClr={'IRON':'#8b7355','BRONZE':'#cd7f32','SILVER':'#c0c0c0','GOLD':'#ffd700','PLATINUM':'#00cec9','EMERALD':'#2ecc71','DIAMOND':'#9b59b6','MASTER':'#e74c3c','GRANDMASTER':'#e74c3c','CHALLENGER':'#f1c40f'};
            var clr=tierClr[sh.peak_tier]||'var(--text)';
            shHtml+='<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:12px;"><span>'+esc(sh.season)+' <span class="muted">'+qName+'</span></span><span style="color:'+clr+'">'+esc(sh.peak_tier||'')+' '+esc(sh.peak_rank||'')+' '+(sh.peak_lp||0)+' LP</span></div>';
          }
          shEl.innerHTML=shHtml;
          shEl.style.display='';
        } else if (shEl) { shEl.style.display='none'; }

        // ── Session Summary (#3) ─────────────────────────
        var sessEl=document.getElementById('ext-session-summary');
        if (sessEl&&data.today) {
          var t=data.today;
          var tGames=tonumberOrZero(t.games);
          var tWins=tonumberOrZero(t.wins);
          var tLosses=tGames-tWins;
          var tWr=tGames>0?Math.round(tWins/tGames*100):0;
          var wrClr=tWr>=50?'var(--green)':'var(--red)';
          var sessHtml='<div class="ext-title">Today\'s Session</div>';
          sessHtml+='<div style="display:flex;gap:16px;align-items:center;">';
          sessHtml+='<div style="font-size:28px;font-weight:700;color:'+wrClr+'">'+tWr+'%</div>';
          sessHtml+='<div><div style="font-size:13px;">'+tGames+' games</div>';
          sessHtml+='<div style="font-size:12px;"><span style="color:var(--green)">'+tWins+'W</span> <span style="color:var(--red)">'+tLosses+'L</span></div>';
          if (t.top_champion) sessHtml+='<div style="font-size:11px;" class="muted">Most played: '+esc(t.top_champion)+'</div>';
          sessHtml+='</div></div>';
          // LP velocity inline
          if (data.lp_velocity&&data.lp_velocity.lp_per_day) {
            var vClr=data.lp_velocity.lp_per_day>0?'var(--green)':'var(--red)';
            sessHtml+='<div style="margin-top:8px;font-size:11px;">LP trend: <strong style="color:'+vClr+'">'+(data.lp_velocity.lp_per_day>0?'+':'')+data.lp_velocity.lp_per_day+' LP/day</strong>';
            if (data.lp_velocity.days_to_next_div) sessHtml+=' (next div ~'+data.lp_velocity.days_to_next_div+'d)';
            sessHtml+='</div>';
          }
          // Daily tip
          if (data.tip) sessHtml+='<div style="margin-top:8px;padding:8px;background:rgba(200,155,60,0.08);border-radius:6px;font-size:11px;color:var(--gold);">'+esc(data.tip)+'</div>';
          sessEl.innerHTML=sessHtml;
          sessEl.style.display='';
        } else if (sessEl) { sessEl.style.display='none'; }

        // Comeback Rate / Throw Rate (computed from allMatches fields)
        var cbEl=document.getElementById('ext-comeback');
        if (cbEl&&allMatches.length>=5) {
          var comebacks=0,throws=0,validGames=0;
          for (var ci=0;ci<allMatches.length;ci++) {
            var cm=allMatches[ci];
            var csAdv=tonumberOrZero(cm.max_cs_advantage);
            var lvlAdv=tonumberOrZero(cm.max_level_lead);
            var won=cm.win?1:0;
            // Only count games where we have lead data
            if (csAdv===0&&lvlAdv===0) continue;
            validGames++;
            var wasAhead=(csAdv>=10||lvlAdv>=2);
            var wasBehind=(csAdv<=-10||lvlAdv<=-2);
            if (wasBehind&&won) comebacks++;
            if (wasAhead&&!won) throws++;
          }
          if (validGames>0) {
            var cbRate=Math.round(comebacks/allMatches.length*100);
            var throwRate=Math.round(throws/allMatches.length*100);
            cbEl.innerHTML='<div class="ext-title">&#9889; Mental Fortitude</div>'+
              '<div class="cb-row">'+
                '<div><div class="cb-label" style="color:var(--purple)">Comeback Rate</div><div class="cb-sub">Won while behind</div></div>'+
                '<div style="text-align:right"><div class="cb-value" style="color:var(--purple)">'+cbRate+'%</div><div class="cb-sub">'+comebacks+' of '+allMatches.length+' games</div></div>'+
              '</div>'+
              '<div class="cb-row">'+
                '<div><div class="cb-label" style="color:var(--red)">Throw Rate</div><div class="cb-sub">Lost while ahead</div></div>'+
                '<div style="text-align:right"><div class="cb-value" style="color:var(--red)">'+throwRate+'%</div><div class="cb-sub">'+throws+' of '+allMatches.length+' games</div></div>'+
              '</div>';
            cbEl.style.display='';
          } else {
            cbEl.style.display='none';
          }
        } else if (cbEl) {
          cbEl.style.display='none';
        }

        // ── Wave 4: Queue Breakdown ──────────────────────
        var qbEl=document.getElementById('ext-queue-breakdown');
        if (qbEl&&data.queue_breakdown&&data.queue_breakdown.length>0) {
          var qbHtml='<div class="ext-title">Queue Breakdown</div>';
          for (var qi=0;qi<data.queue_breakdown.length;qi++) {
            var qb=data.queue_breakdown[qi];
            var qWr=tonumberOrZero(qb.winrate);
            var qClr=qWr>=50?'var(--green)':'var(--red)';
            qbHtml+='<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:12px;">'
              +'<span>'+esc(qb.queue_name||'Unknown')+'</span>'
              +'<span><strong>'+qb.games+'</strong>G '
              +'<span style="color:'+qClr+'">'+qWr+'%</span> '
              +'<span class="muted">'+tonumberOrZero(qb.avg_kills).toFixed(1)+'/'+tonumberOrZero(qb.avg_deaths).toFixed(1)+'/'+tonumberOrZero(qb.avg_assists).toFixed(1)+'</span>'
              +'</span></div>';
          }
          qbEl.innerHTML=qbHtml;
          qbEl.style.display='';
        } else if (qbEl) { qbEl.style.display='none'; }

        // ── Wave 4: Role Distribution ────────────────────
        var rdEl=document.getElementById('ext-role-dist');
        if (rdEl&&data.role_distribution&&data.role_distribution.length>0) {
          var rdHtml='<div class="ext-title">Role Distribution</div><div style="display:flex;gap:6px;flex-wrap:wrap;">';
          var roleIcons={TOP:'⬆',JUNGLE:'🌲',MIDDLE:'🔮',BOTTOM:'🏹',UTILITY:'🛡'};
          for (var ri=0;ri<data.role_distribution.length;ri++) {
            var rd=data.role_distribution[ri];
            var rWr=tonumberOrZero(rd.winrate);
            var rClr=rWr>=50?'var(--green)':'var(--red)';
            var posName=rd.position==='UTILITY'?'SUP':rd.position==='BOTTOM'?'ADC':rd.position==='MIDDLE'?'MID':(rd.position||'?');
            var icon=roleIcons[rd.position]||'';
            rdHtml+='<div style="background:var(--card-bg);padding:6px 10px;border-radius:6px;text-align:center;min-width:60px;">'
              +'<div style="font-size:14px;">'+icon+'</div>'
              +'<div style="font-size:11px;font-weight:600;">'+posName+'</div>'
              +'<div style="font-size:12px;">'+rd.games+'G</div>'
              +'<div style="font-size:11px;color:'+rClr+'">'+rWr+'%</div>'
              +'</div>';
          }
          rdHtml+='</div>';
          rdEl.innerHTML=rdHtml;
          rdEl.style.display='';
        } else if (rdEl) { rdEl.style.display='none'; }

        // ── Wave 4: Damage Profile ───────────────────────
        var dpEl=document.getElementById('ext-damage-profile');
        if (dpEl&&data.damage_profile&&data.damage_profile.avg_damage_dealt) {
          var dp=data.damage_profile;
          var phys=tonumberOrZero(dp.avg_physical_pct);
          var magic=tonumberOrZero(dp.avg_magic_pct);
          var trueDmg=tonumberOrZero(dp.avg_true_pct);
          var dpHtml='<div class="ext-title">Damage Profile</div>';
          dpHtml+='<div style="height:14px;border-radius:7px;overflow:hidden;display:flex;margin-bottom:6px;">';
          dpHtml+='<div style="width:'+phys+'%;background:#e74c3c;" title="Physical '+phys.toFixed(1)+'%"></div>';
          dpHtml+='<div style="width:'+magic+'%;background:#3498db;" title="Magic '+magic.toFixed(1)+'%"></div>';
          dpHtml+='<div style="width:'+trueDmg+'%;background:#f1f1f1;" title="True '+trueDmg.toFixed(1)+'%"></div>';
          dpHtml+='</div>';
          dpHtml+='<div style="display:flex;justify-content:space-between;font-size:11px;">';
          dpHtml+='<span style="color:#e74c3c;">Physical '+phys.toFixed(0)+'%</span>';
          dpHtml+='<span style="color:#3498db;">Magic '+magic.toFixed(0)+'%</span>';
          dpHtml+='<span style="color:#ccc;">True '+trueDmg.toFixed(0)+'%</span>';
          dpHtml+='</div>';
          dpHtml+='<div style="margin-top:6px;font-size:11px;color:var(--text-muted);">Avg dealt: '+fmtNumber(tonumberOrZero(dp.avg_damage_dealt))+' · Avg taken: '+fmtNumber(tonumberOrZero(dp.avg_damage_taken))+'</div>';
          dpEl.innerHTML=dpHtml;
          dpEl.style.display='';
        } else if (dpEl) { dpEl.style.display='none'; }

        // ── Wave 4: Duration Analysis ────────────────────
        var daEl=document.getElementById('ext-duration-analysis');
        if (daEl&&data.duration_analysis&&data.duration_analysis.length>0) {
          var daHtml='<div class="ext-title">Win Rate by Game Length</div>';
          for (var di=0;di<data.duration_analysis.length;di++) {
            var da=data.duration_analysis[di];
            var daWr=tonumberOrZero(da.winrate);
            var daClr=daWr>=50?'var(--green)':'var(--red)';
            var barW=Math.max(5,Math.min(100,daWr));
            daHtml+='<div style="display:flex;align-items:center;gap:8px;padding:2px 0;font-size:12px;">'
              +'<span style="width:55px;">'+esc(da.bucket)+'</span>'
              +'<div style="flex:1;height:12px;background:rgba(255,255,255,0.05);border-radius:6px;overflow:hidden;">'
              +'<div style="width:'+barW+'%;height:100%;background:'+daClr+';border-radius:6px;"></div></div>'
              +'<span style="color:'+daClr+';width:35px;text-align:right;">'+daWr+'%</span>'
              +'<span class="muted" style="width:25px;text-align:right;">'+da.games+'</span>'
              +'</div>';
          }
          daEl.innerHTML=daHtml;
          daEl.style.display='';
        } else if (daEl) { daEl.style.display='none'; }

        // ── Wave 4: Best Time to Play ────────────────────
        var btEl=document.getElementById('ext-best-time');
        if (btEl&&data.time_analysis&&data.time_analysis.by_hour&&data.time_analysis.by_hour.length>0) {
          var ta=data.time_analysis;
          var btHtml='<div class="ext-title">Best Time to Play</div>';
          if (ta.best_hour!==null&&ta.best_hour!==undefined) {
            btHtml+='<div style="font-size:12px;margin-bottom:6px;">Best: <strong style="color:var(--green)">'+ta.best_hour+':00</strong>';
            if (ta.worst_hour!==null&&ta.worst_hour!==undefined) btHtml+=' · Worst: <strong style="color:var(--red)">'+ta.worst_hour+':00</strong>';
            btHtml+='</div>';
          }
          // Mini hour chart (24 bars)
          btHtml+='<div style="display:flex;gap:1px;height:40px;align-items:flex-end;">';
          var maxG=1;
          for (var hi=0;hi<ta.by_hour.length;hi++) { if(tonumberOrZero(ta.by_hour[hi].games)>maxG) maxG=tonumberOrZero(ta.by_hour[hi].games); }
          // Create 24 slots
          var hourMap={};
          for (var hi=0;hi<ta.by_hour.length;hi++) hourMap[ta.by_hour[hi].hour]=ta.by_hour[hi];
          for (var hh=0;hh<24;hh++) {
            var hd=hourMap[hh];
            var hGames=hd?tonumberOrZero(hd.games):0;
            var hWr=hd?tonumberOrZero(hd.winrate):50;
            var hH=hGames>0?Math.max(4,Math.round(hGames/maxG*36)):2;
            var hClr=hGames===0?'rgba(255,255,255,0.05)':hWr>=55?'var(--green)':hWr<=45?'var(--red)':'var(--gold)';
            btHtml+='<div style="flex:1;height:'+hH+'px;background:'+hClr+';border-radius:2px;" title="'+hh+':00 — '+hGames+'G'+(hGames>0?' ('+hWr+'% WR)':'')+'"></div>';
          }
          btHtml+='</div>';
          btHtml+='<div style="display:flex;justify-content:space-between;font-size:9px;color:var(--text-muted);margin-top:2px;"><span>0h</span><span>6h</span><span>12h</span><span>18h</span><span>23h</span></div>';
          btEl.innerHTML=btHtml;
          btEl.style.display='';
        } else if (btEl) { btEl.style.display='none'; }

        // ── Wave 4: Surrender Stats ──────────────────────
        var ssEl=document.getElementById('ext-surrender-stats');
        if (ssEl&&data.surrender_stats&&data.surrender_stats.total_games) {
          var ss=data.surrender_stats;
          var ssHtml='<div class="ext-title">Game Outcomes</div>';
          ssHtml+='<div style="display:flex;gap:12px;font-size:12px;flex-wrap:wrap;">';
          ssHtml+='<div><span class="muted">Surrender Rate</span> <strong>'+tonumberOrZero(ss.surrender_rate).toFixed(0)+'%</strong> ('+tonumberOrZero(ss.surrenders)+')</div>';
          ssHtml+='<div><span class="muted">First Blood</span> <strong>'+tonumberOrZero(ss.first_blood_rate).toFixed(0)+'%</strong> ('+tonumberOrZero(ss.first_bloods)+')</div>';
          if (tonumberOrZero(ss.remakes)>0) ssHtml+='<div><span class="muted">Remakes</span> <strong>'+ss.remakes+'</strong></div>';
          ssHtml+='</div>';
          ssEl.innerHTML=ssHtml;
          ssEl.style.display='';
        } else if (ssEl) { ssEl.style.display='none'; }

        // ── Wave 4: Spell Analysis ───────────────────────
        var spEl=document.getElementById('ext-spell-analysis');
        if (spEl&&data.spell_analysis&&data.spell_analysis.length>0) {
          var spHtml='<div class="ext-title">Summoner Spells</div>';
          for (var si=0;si<Math.min(data.spell_analysis.length,5);si++) {
            var sp=data.spell_analysis[si];
            var spWr=tonumberOrZero(sp.winrate);
            var spClr=spWr>=50?'var(--green)':'var(--red)';
            spHtml+='<div style="display:flex;justify-content:space-between;padding:2px 0;font-size:12px;">'
              +'<span>'+esc(sp.spell1_name||'')+' + '+esc(sp.spell2_name||'')+'</span>'
              +'<span><strong>'+sp.games+'</strong>G <span style="color:'+spClr+'">'+spWr+'%</span></span>'
              +'</div>';
          }
          spEl.innerHTML=spHtml;
          spEl.style.display='';
        } else if (spEl) { spEl.style.display='none'; }

        // ── Wave 5: Vision Trend ─────────────────────────
        var vtEl=document.getElementById('ext-vision-trend');
        if (vtEl&&data.vision_trend&&data.vision_trend.length>0) {
          var vt=data.vision_trend;
          var vtHtml='<div class="ext-title">Vision Trend (Last '+vt.length+' Games)</div>';
          // Mini bar chart of vision per minute
          var maxVpm=0.1;
          for (var vi=0;vi<vt.length;vi++) { var vpm=tonumberOrZero(vt[vi].vision_per_min); if(vpm>maxVpm) maxVpm=vpm; }
          vtHtml+='<div style="display:flex;gap:2px;height:30px;align-items:flex-end;">';
          for (var vi=vt.length-1;vi>=0;vi--) {
            var vpm=tonumberOrZero(vt[vi].vision_per_min);
            var vH=Math.max(3,Math.round(vpm/maxVpm*26));
            var vClr=vpm>=1.5?'var(--green)':vpm>=0.8?'var(--gold)':'var(--red)';
            vtHtml+='<div style="flex:1;height:'+vH+'px;background:'+vClr+';border-radius:2px;" title="'+esc(vt[vi].champion_name||'')+' — VS: '+vt[vi].vision_score+' ('+vpm+'/min)"></div>';
          }
          vtHtml+='</div>';
          // Averages
          var avgVs=0,avgWp=0,avgCw=0;
          for (var vi=0;vi<vt.length;vi++) {avgVs+=tonumberOrZero(vt[vi].vision_score);avgWp+=tonumberOrZero(vt[vi].wards_placed);avgCw+=tonumberOrZero(vt[vi].control_wards);}
          avgVs=Math.round(avgVs/vt.length);avgWp=Math.round(avgWp/vt.length*10)/10;avgCw=Math.round(avgCw/vt.length*10)/10;
          vtHtml+='<div style="margin-top:6px;font-size:11px;color:var(--text-muted);">Avg VS: '+avgVs+' · Wards/g: '+avgWp+' · CW/g: '+avgCw+'</div>';
          vtEl.innerHTML=vtHtml;
          vtEl.style.display='';
        } else if (vtEl) { vtEl.style.display='none'; }

        // ── Wave 5: Peer Percentiles ─────────────────────
        var ppEl=document.getElementById('ext-peer-percentiles');
        if (ppEl&&data.peer_percentiles&&data.peer_percentiles.sample_size) {
          var pp=data.peer_percentiles;
          var ppHtml='<div class="ext-title">Peer Comparison <span style="font-size:10px;color:var(--text-muted);font-weight:400">(vs '+pp.sample_size+' players'+(pp.tier?' · '+pp.tier:'')+')</span></div>';
          var metrics=[
            {label:'CS/min',val:pp.cs_per_min},
            {label:'Vision',val:pp.vision},
            {label:'KDA',val:pp.kda},
            {label:'Damage',val:pp.damage},
            {label:'Kill Part.',val:pp.kill_participation}
          ];
          for (var pi=0;pi<metrics.length;pi++) {
            var pm=metrics[pi];
            var pv=tonumberOrZero(pm.val);
            var pClr=pv>=75?'var(--green)':pv>=50?'var(--gold)':'var(--red)';
            ppHtml+='<div style="display:flex;align-items:center;gap:8px;padding:2px 0;font-size:12px;">'
              +'<span style="width:60px;">'+pm.label+'</span>'
              +'<div style="flex:1;height:10px;background:rgba(255,255,255,0.05);border-radius:5px;overflow:hidden;">'
              +'<div style="width:'+pv+'%;height:100%;background:'+pClr+';border-radius:5px;"></div></div>'
              +'<span style="color:'+pClr+';width:35px;text-align:right;font-weight:600;">'+pv+'%</span>'
              +'</div>';
          }
          ppEl.innerHTML=ppHtml;
          ppEl.style.display='';
        } else if (ppEl) { ppEl.style.display='none'; }

        // ── Wave 5: Early Game Stats ─────────────────────
        var egEl=document.getElementById('ext-early-game');
        if (egEl&&data.early_game&&data.early_game.total_games) {
          var eg=data.early_game;
          var egHtml='<div class="ext-title">Early Game Averages <span style="font-size:10px;color:var(--text-muted);font-weight:400">('+eg.total_games+' games)</span></div>';
          egHtml+='<div style="display:flex;flex-wrap:wrap;gap:10px;font-size:12px;">';
          if (tonumberOrZero(eg.avg_cs_at_10)>0) egHtml+='<div><span class="muted">CS@10</span> <strong>'+tonumberOrZero(eg.avg_cs_at_10).toFixed(0)+'</strong></div>';
          if (tonumberOrZero(eg.avg_cs_at_15)>0) egHtml+='<div><span class="muted">CS@15</span> <strong>'+tonumberOrZero(eg.avg_cs_at_15).toFixed(0)+'</strong></div>';
          if (tonumberOrZero(eg.avg_gold_at_10)>0) egHtml+='<div><span class="muted">Gold@10</span> <strong>'+fmtNumber(tonumberOrZero(eg.avg_gold_at_10))+'</strong></div>';
          var gd10=tonumberOrZero(eg.avg_gold_diff_at_10);
          if (gd10!==0) {
            var gdClr=gd10>0?'var(--green)':'var(--red)';
            egHtml+='<div><span class="muted">Gold Diff@10</span> <strong style="color:'+gdClr+'">'+(gd10>0?'+':'')+gd10+'</strong></div>';
          }
          var xd10=tonumberOrZero(eg.avg_xp_diff_at_10);
          if (xd10!==0) {
            var xdClr=xd10>0?'var(--green)':'var(--red)';
            egHtml+='<div><span class="muted">XP Diff@10</span> <strong style="color:'+xdClr+'">'+(xd10>0?'+':'')+xd10+'</strong></div>';
          }
          egHtml+='</div>';
          egEl.innerHTML=egHtml;
          egEl.style.display='';
        } else if (egEl) { egEl.style.display='none'; }

        // ── Wave 6: Objective Stats ──────────────────────
        var objEl=document.getElementById('ext-objectives');
        if (objEl&&data.objective_stats&&data.objective_stats.total_games) {
          var os=data.objective_stats;
          var objHtml='<div class="ext-title">Objective Control</div>';
          objHtml+='<div style="display:flex;flex-wrap:wrap;gap:10px;font-size:12px;">';
          var objItems=[
            {icon:'🐉',label:'Dragons/g',val:tonumberOrZero(os.avg_dragons).toFixed(1)},
            {icon:'👑',label:'Barons/g',val:tonumberOrZero(os.avg_barons).toFixed(1)},
            {icon:'🦀',label:'Heralds/g',val:tonumberOrZero(os.avg_heralds).toFixed(1)},
            {icon:'🏰',label:'Turrets/g',val:tonumberOrZero(os.avg_turrets).toFixed(1)},
            {icon:'🔩',label:'Plates/g',val:tonumberOrZero(os.avg_plates).toFixed(1)}
          ];
          for (var oi=0;oi<objItems.length;oi++) {
            var o=objItems[oi];
            objHtml+='<div style="text-align:center;min-width:55px;"><div style="font-size:16px;">'+o.icon+'</div><div style="font-weight:600;">'+o.val+'</div><div class="muted" style="font-size:10px;">'+o.label+'</div></div>';
          }
          objHtml+='</div>';
          // First blood win conversion
          var fbWins=tonumberOrZero(os.first_blood_wins);
          var fbs=tonumberOrZero(os.first_bloods);
          if (fbs>0) {
            var fbConv=Math.round(fbWins/fbs*100);
            objHtml+='<div style="margin-top:6px;font-size:11px;color:var(--text-muted);">First Blood win rate: <strong style="color:'+(fbConv>=60?'var(--green)':'var(--red)')+'">'+fbConv+'%</strong> ('+fbs+' FBs)</div>';
          }
          objEl.innerHTML=objHtml;
          objEl.style.display='';
        } else if (objEl) { objEl.style.display='none'; }

        // ── Quick Win: Tilt Probability Score ─────────────
        var tiltEl=document.getElementById('ext-tilt-score');
        if (tiltEl&&data.tilt_score&&data.tilt_score.recent_games) {
          var ts=data.tilt_score;
          var score=ts.score||0;
          var tClr=score>=70?'var(--red)':score>=40?'var(--yellow)':'var(--green)';
          var tLabel=score>=80?'On Tilt':score>=60?'Tilting':score>=40?'Neutral':score>=20?'Focused':'Zen';
          var tHtml='<div class="ext-title">Tilt Probability</div>';
          tHtml+='<div style="display:flex;align-items:center;gap:12px;">';
          tHtml+='<div style="font-size:32px;font-weight:700;color:'+tClr+';">'+score+'</div>';
          tHtml+='<div><div style="font-size:13px;font-weight:600;color:'+tClr+';">'+tLabel+'</div>';
          if (ts.streak>0) tHtml+='<div style="font-size:11px;color:var(--red);">'+ts.streak+'L streak</div>';
          tHtml+='<div style="font-size:11px;" class="muted">Last '+ts.recent_games+'g: '+ts.recent_wr+'% WR</div>';
          tHtml+='</div></div>';
          tHtml+='<div class="tilt-meter"><div class="tilt-bar"><div class="tilt-bar-fill" style="width:'+score+'%;background:'+tClr+';"></div></div>';
          tHtml+='<div class="tilt-label"><span>Zen</span><span>Tilt</span></div></div>';
          tiltEl.innerHTML=tHtml;
          tiltEl.style.display='';
        } else if (tiltEl) { tiltEl.style.display='none'; }

        // ── Quick Win: Playstyle Clustering ────────────────
        var psEl=document.getElementById('ext-playstyle');
        if (psEl&&data.playstyle) {
          var ps=data.playstyle;
          var iconMap={eye:'👁',sword:'⚔',wheat:'🌾',shield:'🛡',anchor:'⚓',dice:'🎲',target:'🎯',heart:'❤',star:'⭐',refresh:'🔄'};
          var icon=iconMap[ps.icon]||'🎮';
          psEl.innerHTML='<div class="ext-title">Playstyle</div>'
            +'<div class="playstyle-badge"><span class="playstyle-icon">'+icon+'</span><div><div class="playstyle-name">'+esc(ps.archetype)+'</div><div class="playstyle-desc">'+esc(ps.description)+'</div></div></div>';
          psEl.style.display='';
        } else if (psEl) { psEl.style.display='none'; }
      })
      .catch(function(){ section.classList.remove('visible'); });
  }

  // ── Match rendering helpers ────────────────────────
  function formatPos(pos) {
    if (pos==='UTILITY') return 'SUP'; if (pos==='BOTTOM') return 'ADC';
    if (pos==='MIDDLE') return 'MID'; if (pos==='TOP') return 'TOP';
    if (pos==='JUNGLE') return 'JGL'; return '';
  }

  function itemTooltipHtml(id) {
    var info=itemData[String(id)];
    if (!info) return '<img class="item-icon" src="'+itemImg(id)+'" title="Item '+id+'" />';
    return '<div class="item-tooltip"><img class="item-icon" src="'+itemImg(id)+'" /><div class="tt-content"><div class="tt-name">'+esc(info.name)+'</div><div class="tt-gold">'+fmtNumber(info.gold_total)+' gold</div></div></div>';
  }

  function renderItemsRow(items) {
    var html='<div class="item-row">';
    for (var i=0;i<7;i++) {
      var id=items&&items[i]?items[i]:0;
      if (id>0) html+=itemTooltipHtml(id);
      else html+='<div class="item-empty"></div>';
    }
    return html+'</div>';
  }

  function runeIconsHtml(keystoneId, subStyleId) {
    var html='';
    var ks=runeData[String(keystoneId)];
    var sub=runeData[String(subStyleId)];
    if (!ks&&!sub) return '';
    html='<div class="rune-icons">';
    if (ks&&ks.icon) html+='<img class="rune-keystone" src="'+esc(ks.icon)+'" title="'+esc(ks.name||'')+'" />';
    if (sub&&sub.icon) html+='<img class="rune-tree" src="'+esc(sub.icon)+'" title="'+esc(sub.name||'')+'" />';
    html+='</div>';
    return html;
  }

  function renderPlayerItems(items) {
    var html='';
    if (!items||items.length===0) return html;
    for (var i=0;i<items.length&&i<7;i++) {
      if(items[i]>0) {
        var info=itemData[String(items[i])];
        html+='<img src="'+itemImg(items[i])+'" title="'+(info?esc(info.name):'Item '+items[i])+'" />';
      }
    }
    return html;
  }

  function renderTeamPlayers(players) {
    var html='';
    for (var i=0;i<players.length;i++) {
      var p=players[i], cls=p.is_me?'team-player is-me':'team-player';
      var icon=p.champion_image?'<img class="team-player-icon" src="'+esc(p.champion_image)+'" />':'<div class="team-player-icon" style="background:var(--border);"></div>';
      var posStr=formatPos(p.position);
      var spellsHtml='',s1=spellImg(p.summoner1),s2=spellImg(p.summoner2);
      if (s1||s2) { spellsHtml='<div class="team-player-spells">'+(s1?'<img src="'+s1+'" />':'')+(s2?'<img src="'+s2+'" />':'')+'</div>'; }
      var pRunesHtml=runeIconsHtml(p.perks_keystone, p.perks_sub_style);
      var itemsHtml='<div class="team-player-items">'+renderPlayerItems(p.items)+'</div>';

      // Damage breakdown bar per player
      var pDmgTotal=(p.physical_damage||0)+(p.magic_damage||0)+(p.true_damage||0);
      var dmgBar='';
      if (pDmgTotal>0) {
        dmgBar='<div class="team-dmg-bar"><div class="phys" style="width:'+Math.round((p.physical_damage||0)/pDmgTotal*100)+'%"></div><div class="magic" style="width:'+Math.round((p.magic_damage||0)/pDmgTotal*100)+'%"></div><div class="true-d" style="width:'+Math.round((p.true_damage||0)/pDmgTotal*100)+'%"></div></div>';
      }

      var kpStr=p.kill_participation>0?' <span class="muted" style="font-size:9px;">'+Math.round(p.kill_participation*100)+'%KP</span>':'';

      html+='<div class="'+cls+'"><div class="team-player-champ">'+icon+'<span class="team-player-name">'+esc(p.champion_name||'?')+(posStr?' <span class="muted" style="font-size:10px;">('+posStr+')</span>':'')+ ' <span class="muted" style="font-size:10px;">'+esc(p.summoner_name||'')+'</span></span></div>'+spellsHtml+pRunesHtml+itemsHtml+'<div class="team-player-stats"><span class="stat-kda">'+p.kills+'/'+p.deaths+'/'+p.assists+kpStr+'</span><span class="stat-cs">'+(p.cs||0)+'</span><span class="stat-dmg">'+fmtNumber(p.total_damage)+'</span><span class="stat-gold">'+fmtNumber(p.gold_earned)+'</span></div></div>'+dmgBar;
    }
    return html;
  }

  function renderTeamCompAnalysis(allies, enemies) {
    function teamDmg(players) {
      var phys=0,magic=0,trued=0;
      for (var i=0;i<players.length;i++) {
        phys+=(players[i].physical_damage||0);
        magic+=(players[i].magic_damage||0);
        trued+=(players[i].true_damage||0);
      }
      var total=phys+magic+trued;
      if (total===0) return null;
      return {phys:phys,magic:magic,trued:trued,total:total,
        physPct:Math.round(phys/total*100),magicPct:Math.round(magic/total*100),truePct:Math.round(trued/total*100)};
    }
    function dmgBarHtml(d) {
      if (!d) return '';
      return '<div class="tca-bar-wrap"><div class="tca-bar-label">Physical</div><div class="tca-bar"><div class="phys" style="width:'+d.physPct+'%"></div></div><div class="tca-pct" style="color:#ef4444;">'+d.physPct+'%</div></div>'+
        '<div class="tca-bar-wrap"><div class="tca-bar-label">Magic</div><div class="tca-bar"><div class="magic" style="width:'+d.magicPct+'%"></div></div><div class="tca-pct" style="color:#3b82f6;">'+d.magicPct+'%</div></div>'+
        '<div class="tca-bar-wrap"><div class="tca-bar-label">True</div><div class="tca-bar"><div class="true-d" style="width:'+d.truePct+'%"></div></div><div class="tca-pct" style="color:#e2e8f0;">'+d.truePct+'%</div></div>';
    }
    function dmgType(d) {
      if (!d) return '';
      if (d.physPct>=60) return '<span class="tca-role-tag" style="color:#ef4444;">AD Heavy</span>';
      if (d.magicPct>=60) return '<span class="tca-role-tag" style="color:#3b82f6;">AP Heavy</span>';
      return '<span class="tca-role-tag" style="color:var(--gold);">Mixed</span>';
    }
    var ad=teamDmg(allies||[]), ed=teamDmg(enemies||[]);
    if (!ad&&!ed) return '';
    var html='<div class="team-comp-analysis">';
    html+='<div class="tca-team"><div class="tca-title" style="color:var(--green);">Allied Damage</div>'+dmgBarHtml(ad)+'<div class="tca-roles">'+dmgType(ad)+'</div></div>';
    html+='<div class="tca-team"><div class="tca-title" style="color:var(--red);">Enemy Damage</div>'+dmgBarHtml(ed)+'<div class="tca-roles">'+dmgType(ed)+'</div></div>';
    html+='</div>';
    return html;
  }

  function filterMatches(filter) {
    var champFilter=document.getElementById('champ-filter').value;
    var durFilter=document.getElementById('duration-filter').value;
    var result=[];
    for (var i=0;i<allMatches.length;i++) {
      var m=allMatches[i];
      if (filter!=='all'&&queueCategory(m)!==filter) continue;
      if (champFilter&&m.champion_name!==champFilter) continue;
      if (durFilter) {
        var dur=m.game_duration_raw||0;
        if (durFilter==='short'&&dur>=1500) continue;
        if (durFilter==='mid'&&(dur<1500||dur>2100)) continue;
        if (durFilter==='long'&&dur<=2100) continue;
      }
      result.push(m);
    }
    return result;
  }

  function setActiveTab(filter) {
    var tabs=document.querySelectorAll('.queue-tab');
    for (var i=0;i<tabs.length;i++) tabs[i].classList.toggle('active',tabs[i].getAttribute('data-filter')===filter);
  }

  function renderMatches(matches) {
    var section=document.getElementById('matches-section'), tbody=document.getElementById('matches-list');
    if (allMatches.length===0) { section.style.display='none'; return; }
    section.style.display=''; tbody.innerHTML='';
    if (matches.length===0) { tbody.innerHTML='<tr><td colspan="11" class="muted" style="text-align:center;padding:20px;">No matches in this category</td></tr>'; return; }

    for (var i=0;i<matches.length;i++) {
      var m=matches[i], k=m.kills||0, d=m.deaths||0, a=m.assists||0;
      var kdaVal=d===0?'Perfect':((k+a)/d).toFixed(1);
      var kdaClass=d===0?'kda-perfect':kdaVal>=3?'kda-good':kdaVal>=2?'kda-ok':'kda-bad';
      var pos=m.position||'';
      if (pos==='UTILITY') pos='Support'; else if (pos==='BOTTOM') pos='ADC'; else if (pos==='MIDDLE') pos='Mid'; else if (pos==='TOP') pos='Top'; else if (pos==='JUNGLE') pos='Jungle'; else if (pos==='') pos='—';

      var runesHtml=runeIconsHtml(m.perks_keystone, m.perks_sub_style);
      var champCell=m.champion_image?'<td class="col-champ"><div class="col-champ-wrap"><img class="col-champ-icon" src="'+esc(m.champion_image)+'" /><div>'+esc(m.champion_name||'Unknown')+runesHtml+'</div></div></td>':'<td class="col-champ">'+esc(m.champion_name||'Unknown')+'</td>';

      // Multi-kill badge
      var mkBadge='';
      if (m.penta_kills>0) mkBadge='<span class="match-mk penta">PENTA</span>';
      else if (m.quadra_kills>0) mkBadge='<span class="match-mk quadra">QUADRA</span>';
      else if (m.triple_kills>0) mkBadge='<span class="match-mk triple">TRIPLE</span>';

      // Surrender indicator
      var ffStr=m.game_ended_surrender?'<span class="badge-ff">FF</span>':'';
      // Comeback badge (#15)
      var comebackStr=m._comeback?'<span class="badge-comeback">CB</span>':'';
      // Meta compliance (#16)
      var metaStr='';
      if (m._meta===true) metaStr='<span class="meta-tag meta-std">META</span>';
      else if (m._meta===false) metaStr='<span class="meta-tag meta-off">OFF</span>';

      // KP indicator in KDA cell
      var kpStr=m.kill_participation>0?' <span class="muted" style="font-size:10px;">'+Math.round(m.kill_participation*100)+'%</span>':'';

      // Gold efficiency (#13)
      var gePct=goldEffPct(m);
      var geCls=gePct>=90?'gold-eff-high':gePct<70?'gold-eff-low':'';

      var mScore=m._score||0;
      var tr=document.createElement('tr'); tr.className='match-row';
      // LP change per match (#Wave4)
      var lpChangeStr='';
      if (m.lp_change&&m.lp_change!==0) {
        var lpClr=m.lp_change>0?'var(--green)':'var(--red)';
        lpChangeStr=' <span style="font-size:10px;font-weight:600;color:'+lpClr+'">'+(m.lp_change>0?'+':'')+m.lp_change+'LP</span>';
      }
      // Win Condition Tags
      var wcTags='';
      if (m.win) {
        var dur=m.game_duration_raw||0;
        var kp=m.kill_participation||0;
        if (k>=10&&dur<1500) wcTags+='<span class="wc-tag wc-snowball">Snowball</span>';
        else if (m._comeback) wcTags+='<span class="wc-tag wc-comeback">Comeback</span>';
        if ((m.vision_score||0)>=40&&(m.wards_placed||0)>=15) wcTags+='<span class="wc-tag wc-vision-carry">Vision Carry</span>';
        if (d<=1&&k+a>=10) wcTags+='<span class="wc-tag wc-kda-player">KDA Player</span>';
        if (kp>=0.7&&a>=10) wcTags+='<span class="wc-tag wc-team-fight">Team Fighter</span>';
      } else {
        if (k>=8&&d>=8) wcTags+='<span class="wc-tag wc-stomp">Coinflip</span>';
      }
      tr.innerHTML='<td><span class="badge '+(m.win?'badge-win':'badge-loss')+'">'+(m.win?'W':'L')+'</span>'+lpChangeStr+ffStr+comebackStr+wcTags+' <span class="muted" style="font-size:10px;">'+esc(queueLabel(m))+'</span></td>'+champCell+'<td class="kda '+kdaClass+'">'+k+'/'+d+'/'+a+' <span class="muted">('+kdaVal+')</span>'+kpStr+mkBadge+metaStr+'</td><td><span class="perf-score '+scoreClass(mScore)+'">'+mScore.toFixed(1)+'</span></td><td>'+renderItemsRow(m.items)+'</td><td class="col-cs">'+(m.cs||0)+' <span class="muted">('+(m.cs_per_min||0)+'/m)</span></td><td class="col-dmg">'+fmtNumber(m.total_damage)+'</td><td class="col-gold">'+fmtNumber(m.gold_earned)+(gePct>0?' <span class="gold-eff '+geCls+'">'+gePct+'%</span>':'')+'</td><td class="col-vision">'+(m.vision_score||0)+'</td><td class="col-pos">'+esc(pos)+'</td><td class="col-duration">'+esc(m.game_duration||'—')+'</td>';
      tbody.appendChild(tr);

      var detailTr=document.createElement('tr'); detailTr.className='match-detail-row hidden';
      var detailTd=document.createElement('td'); detailTd.colSpan=11;
      var tlBtnId='tl-btn-'+i;
      var tlContainerId='tl-container-'+i;
      var tcaHtml=renderTeamCompAnalysis(m.allies||[], m.enemies||[]);
      var noteVal=(window._matchNotes&&window._matchNotes[m.match_id])||'';
      var noteHtml='<div style="padding:4px 20px;"><div style="font-size:10px;color:var(--text-muted);margin-bottom:2px;">Match Note:</div><input class="match-note-input" id="note-'+esc(m.match_id)+'" value="'+esc(noteVal)+'" placeholder="Add a note..." onblur="saveMatchNote(\''+esc(m.match_id)+'\')" onkeydown="if(event.key===\'Enter\')this.blur()" /></div>';
      if (noteVal) noteHtml='<div class="match-note">'+esc(noteVal)+'</div>'+noteHtml;
      // Post-Game Quick Actions
      var pgActions='<div class="post-game-actions">'
        +'<button class="pg-btn" onclick="event.stopPropagation();copyMatchResult(\''+esc(m.match_id)+'\',\''+esc(m.champion_name)+'\','+k+','+d+','+a+','+(m.win?1:0)+')">Copy Result</button>'
        +'<button class="pg-btn" onclick="event.stopPropagation();shareMatchUrl(\''+esc(m.match_id)+'\')">Share Link</button>'
        +'</div>';
      detailTd.innerHTML='<div class="match-detail"><div class="team-block"><div class="team-label ally">'+(m.win?'Victory':'Defeat')+' — Allied Team</div>'+renderTeamPlayers(m.allies||[])+'</div><div class="team-block"><div class="team-label enemy">'+(!m.win?'Victory':'Defeat')+' — Enemy Team</div>'+renderTeamPlayers(m.enemies||[])+'</div></div>'+tcaHtml+noteHtml+pgActions+'<div style="padding:8px 20px;border-top:1px solid var(--border);"><button class="tl-btn" id="'+tlBtnId+'">&#9201; Show Timeline</button><div id="'+tlContainerId+'"></div></div>';
      detailTr.appendChild(detailTd); tbody.appendChild(detailTr);

      (function(row,detail,matchId,btnId,containerId,matchData){
        row.addEventListener('click',function(){ detail.classList.toggle('hidden'); });
        setTimeout(function(){
          var btn=document.getElementById(btnId);
          if(btn) btn.addEventListener('click',function(e){
            e.stopPropagation();
            var cont=document.getElementById(containerId);
            if(btn.classList.contains('active')){btn.classList.remove('active');cont.innerHTML='';return;}
            btn.classList.add('active');
            loadTimeline(matchId,cont,matchData);
          });
        },0);
      })(tr,detailTr,m.match_id,tlBtnId,tlContainerId,m);
    }
  }

  // ── Utilities ──────────────────────────────────────
  function fmtNumber(n) { if(!n) return '0'; if(n>=1000) return (n/1000).toFixed(1)+'k'; return String(n); }
  function tonumberOrZero(v) { var n=parseFloat(v); return isNaN(n)?0:n; }
  function showError(msg) { var el=document.getElementById('error-msg'); el.textContent=msg; el.classList.add('visible'); }
  function hideError() { document.getElementById('error-msg').classList.remove('visible'); }
  function showLoading(show) { var el=document.getElementById('loading'); if(show) el.classList.remove('hidden'); else el.classList.add('hidden'); }
  function showToast(msg,type) {
    var container=document.getElementById('toast-container'), el=document.createElement('div');
    el.className='toast toast-'+type; el.innerHTML=msg; container.appendChild(el);
    setTimeout(function(){el.classList.add('fade-out');},4000);
    setTimeout(function(){if(el.parentNode)el.parentNode.removeChild(el);},4500);
  }
  function esc(str) { if(str==null) return ''; return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  // ── Favorites (#18) ────────────────────────────────
  function loadFavorites() {
    fetch('/api/favorites').then(function(r){return r.json();}).then(function(data){
      var favs=data.favorites||[];
      var section=document.getElementById('fav-section');
      var grid=document.getElementById('fav-grid');
      if (favs.length===0) { section.style.display='none'; return; }
      section.style.display='';
      grid.innerHTML='';
      for (var i=0;i<favs.length;i++) {
        var f=favs[i];
        var rankStr='Unranked';
        if (f.solo_tier) rankStr=f.solo_tier+' '+f.solo_rank+' '+(f.solo_lp||0)+' LP';
        var card=document.createElement('div'); card.className='fav-card';
        card.innerHTML='<div class="fav-name">'+esc(f.game_name)+' <span class="muted">#'+esc(f.tag_line)+'</span></div><div class="fav-rank">'+esc(rankStr)+'</div><button class="fav-remove" data-puuid="'+esc(f.puuid)+'" title="Remove">&#10005;</button>';
        card.addEventListener('click',(function(name,tag,plt){return function(e){
          if(e.target.classList.contains('fav-remove'))return;
          document.getElementById('search-input').value=name+'#'+tag;
          if(plt)document.getElementById('region-select').value=plt;
          doSearch();
        };})(f.game_name,f.tag_line,f.platform));
        card.querySelector('.fav-remove').addEventListener('click',function(e){
          e.stopPropagation();
          var puuid=this.getAttribute('data-puuid');
          fetch('/api/favorites?puuid='+encodeURIComponent(puuid),{method:'DELETE'}).then(function(){loadFavorites();});
        });
        grid.appendChild(card);
      }
    }).catch(function(){});
  }

  function toggleFavorite() {
    if (!currentPuuid||!currentPlayerData) return;
    var acc=currentPlayerData.account||{};
    var isFav=document.getElementById('fav-toggle').classList.contains('active');
    if (isFav) {
      fetch('/api/favorites?puuid='+encodeURIComponent(currentPuuid),{method:'DELETE'}).then(function(){
        document.getElementById('fav-toggle').innerHTML='&#9734;';
        document.getElementById('fav-toggle').classList.remove('active');
        currentPlayerData.is_favorite=false;
        loadFavorites();
      });
    } else {
      var platform=document.getElementById('region-select').value;
      fetch('/api/favorites',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        puuid:currentPuuid,game_name:acc.game_name,tag_line:acc.tag_line,platform:platform
      })}).then(function(){
        document.getElementById('fav-toggle').innerHTML='&#9733;';
        document.getElementById('fav-toggle').classList.add('active');
        currentPlayerData.is_favorite=true;
        loadFavorites();
      });
    }
  }

  // ── Goals (#26) ───────────────────────────────────
  function renderGoals(goals) {
    var section=document.getElementById('goals-section');
    if (!currentPuuid) { section.style.display='none'; return; }
    section.style.display='';
    var list=document.getElementById('goal-list');
    if (!goals||goals.length===0) {
      list.innerHTML='<div class="muted" style="font-size:11px;">No goals set. Add one below!</div>';
      return;
    }
    var html='';
    for (var i=0;i<goals.length;i++) {
      var g=goals[i];
      var completed=g.completed===1;
      html+='<div class="goal-item'+(completed?' completed':'')+'"><span class="goal-type">'+esc(g.goal_type)+'</span><span class="goal-target">'+esc(g.target_value)+'</span>';
      if (g.current_value) html+='<span class="goal-progress">'+esc(g.current_value)+'</span>';
      html+='<span class="goal-actions">';
      if (!completed) html+='<button onclick="completeGoal('+g.id+')" title="Complete">&#10003;</button>';
      html+='<button onclick="deleteGoal('+g.id+')" title="Delete">&#10005;</button>';
      html+='</span></div>';
    }
    list.innerHTML=html;
  }

  window.completeGoal=function(id) {
    fetch('/api/goals',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:id})}).then(function(){
      fetch('/api/goals?puuid='+encodeURIComponent(currentPuuid)).then(function(r){return r.json();}).then(function(d){renderGoals(d.goals||[]);});
    });
  };
  window.deleteGoal=function(id) {
    fetch('/api/goals?id='+id,{method:'DELETE'}).then(function(){
      fetch('/api/goals?puuid='+encodeURIComponent(currentPuuid)).then(function(r){return r.json();}).then(function(d){renderGoals(d.goals||[]);});
    });
  };

  function addGoal() {
    if (!currentPuuid) return;
    var goalType=document.getElementById('goal-type-select').value;
    var targetValue=document.getElementById('goal-target-input').value.trim();
    if (!targetValue) return;
    fetch('/api/goals',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      puuid:currentPuuid,goal_type:goalType,target_value:targetValue
    })}).then(function(){
      document.getElementById('goal-target-input').value='';
      fetch('/api/goals?puuid='+encodeURIComponent(currentPuuid)).then(function(r){return r.json();}).then(function(d){renderGoals(d.goals||[]);});
    });
  }

  // ── Match Notes (#27) ─────────────────────────────
  window.saveMatchNote=function(matchId) {
    var input=document.getElementById('note-'+matchId);
    if (!input||!currentPuuid) return;
    var note=input.value.trim();
    fetch('/api/match-notes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      match_id:matchId,puuid:currentPuuid,note:note
    })}).then(function(){
      window._matchNotes=window._matchNotes||{};
      window._matchNotes[matchId]=note;
      showToast('Note saved','success');
    });
  };

  // ── Compare Mode (#19) ────────────────────────────
  var compareData=[];
  function addComparePlayer() {
    var input=document.getElementById('compare-input').value.trim();
    if (!input) return;
    var parts=input.split('#');
    if (parts.length<2) return;
    var name=parts[0].trim(), tag=parts.slice(1).join('#').trim();
    var platform=document.getElementById('region-select').value;
    fetch('/api/search?name='+encodeURIComponent(name)+'&tag='+encodeURIComponent(tag)+'&platform='+encodeURIComponent(platform))
      .then(function(r){ if(!r.ok) throw new Error('Error'); return r.json(); })
      .then(function(data){
        compareData.push(data);
        document.getElementById('compare-input').value='';
        renderCompare();
      })
      .catch(function(){ showToast('Could not find player','error'); });
  }

  function renderCompare() {
    var el=document.getElementById('compare-content');
    var players=[currentPlayerData].concat(compareData).filter(function(d){return d&&d.stats;});
    if (players.length<2) { el.innerHTML='<div class="muted" style="font-size:12px;">Add another player to compare</div>'; return; }

    var metrics=[
      {name:'Win Rate',key:'winrate',suffix:'%',higher:true},
      {name:'KDA',key:'avg_kda',higher:true},
      {name:'Avg Kills',key:'avg_kills',higher:true},
      {name:'Avg Deaths',key:'avg_deaths',higher:false},
      {name:'CS/min',key:'avg_cs_min',higher:true},
      {name:'Avg Damage',key:'avg_damage',higher:true,fmt:true},
      {name:'Vision',key:'avg_vision',higher:true},
      {name:'KP',key:'avg_kill_participation',suffix:'%',higher:true},
      {name:'Solo Kills/g',key:'avg_solo_kills',higher:true},
      {name:'Snowball',key:'snowball_index',higher:true},
    ];

    var html='<table class="compare-table"><thead><tr><th>Metric</th>';
    for (var p=0;p<players.length;p++) {
      var a=players[p].account||{};
      html+='<th class="compare-name">'+esc(a.game_name||'Player '+(p+1))+'</th>';
    }
    html+='</tr></thead><tbody>';

    for (var mi=0;mi<metrics.length;mi++) {
      var m=metrics[mi];
      var vals=[];
      for (var p=0;p<players.length;p++) vals.push(players[p].stats[m.key]||0);
      var bestVal=vals[0]; var bestIdx=0;
      for (var p=1;p<vals.length;p++) {
        if (m.higher?(vals[p]>bestVal):(vals[p]<bestVal)) { bestVal=vals[p]; bestIdx=p; }
      }
      html+='<tr><td>'+m.name+'</td>';
      for (var p=0;p<players.length;p++) {
        var v=vals[p];
        var display=m.fmt?fmtNumber(v):v;
        if(m.suffix)display=v+m.suffix;
        var cls=p===bestIdx?'best':'';
        html+='<td class="'+cls+'">'+display+'</td>';
      }
      html+='</tr>';
    }
    html+='</tbody></table>';
    el.innerHTML=html;
  }

  // ── Push Notifications (#22) ──────────────────────
  var notifEnabled=false;
  function toggleNotifications() {
    if (!('Notification' in window)) { showToast('Browser does not support notifications','error'); return; }
    if (notifEnabled) {
      notifEnabled=false;
      document.getElementById('notif-toggle').classList.remove('active');
      localStorage.removeItem('lc-notif');
      return;
    }
    Notification.requestPermission().then(function(perm){
      if (perm==='granted') {
        notifEnabled=true;
        document.getElementById('notif-toggle').classList.add('active');
        localStorage.setItem('lc-notif','1');
        showToast('Notifications enabled','success');
      }
    });
  }

  function sendBrowserNotif(title,body) {
    if (!notifEnabled||!('Notification' in window)||Notification.permission!=='granted') return;
    new Notification(title,{body:body,icon:'/favicon.ico'});
  }

  // Enhance existing WS handler to also send browser notifications
  var _origHandleWs=handleWsMessage;
  handleWsMessage=function(msg) {
    _origHandleWs(msg);
    if (notifEnabled&&msg.type==='new_match') {
      var result=msg.win?'Victory':'Defeat';
      sendBrowserNotif(msg.player_name+' — '+result, msg.champion_name+' '+msg.kills+'/'+msg.deaths+'/'+msg.assists);
    }
    if (notifEnabled&&msg.type==='rank_change') {
      sendBrowserNotif('Rank Change: '+msg.player_name, msg.old_rank+' → '+msg.new_rank);
    }
  };

  // ── Export CSV (#25) ──────────────────────────────
  function exportCSV() {
    if (!currentPlayerData) return;
    var matches=currentPlayerData.matches||[];
    if (matches.length===0) { showToast('No matches to export','error'); return; }
    var header=['match_id','champion','position','win','kills','deaths','assists','cs','damage','gold','vision','duration_min','queue_id','game_date'];
    var rows=[header.join(',')];
    for (var i=0;i<matches.length;i++) {
      var m=matches[i];
      var date=m.game_creation?new Date(m.game_creation).toISOString().substring(0,10):'';
      var dur=m.game_duration?Math.round(m.game_duration/60):0;
      rows.push([
        m.match_id||'',m.champion_name||'',m.position||'',m.win?1:0,
        m.kills||0,m.deaths||0,m.assists||0,m.cs||0,
        m.total_damage||0,m.gold_earned||0,m.vision_score||0,dur,m.queue_id||0,date
      ].join(','));
    }
    var acc=currentPlayerData.account||{};
    var blob=new Blob([rows.join('\n')],{type:'text/csv'});
    var url=URL.createObjectURL(blob);
    var a=document.createElement('a');
    a.href=url; a.download=(acc.game_name||'matches')+'_matches.csv';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('CSV exported ('+matches.length+' matches)','success');
  }

  // ── Export (#24) ──────────────────────────────────
  function exportProfile() {
    if (!currentPlayerData) return;
    var data=currentPlayerData;
    var acc=data.account||{}, sum=data.summoner||{}, st=data.stats;
    if (!st) { showToast('No data to export','error'); return; }

    // Build a text summary
    var lines=[];
    lines.push('=== '+acc.game_name+'#'+acc.tag_line+' ===');
    lines.push('Level: '+(sum.level||'?'));
    var ranked=data.ranked||[];
    for (var i=0;i<ranked.length;i++) {
      var r=ranked[i];
      var qn=r.queueType==='RANKED_SOLO_5x5'?'Solo/Duo':'Flex';
      lines.push(qn+': '+r.tier+' '+r.rank+' '+(r.leaguePoints||0)+' LP ('+r.wins+'W '+r.losses+'L)');
    }
    lines.push('');
    lines.push('Games: '+st.games+' | WR: '+st.winrate+'% ('+st.wins+'W '+st.losses+'L)');
    lines.push('KDA: '+st.avg_kills+'/'+st.avg_deaths+'/'+st.avg_assists+' ('+st.avg_kda+')');
    lines.push('CS/min: '+st.avg_cs_min+' | Damage: '+st.avg_damage+' | Gold: '+st.avg_gold);
    lines.push('Vision: '+st.avg_vision+' | KP: '+st.avg_kill_participation+'% | DS: '+st.avg_damage_share+'%');
    if (st.pool_depth) lines.push('Pool: '+st.pool_depth+' ('+st.unique_champions+' champions)');
    if (st.top_champions) {
      lines.push('');
      lines.push('Top Champions:');
      for (var i=0;i<Math.min(st.top_champions.length,5);i++) {
        var c=st.top_champions[i];
        lines.push('  '+c.champion_name+': '+c.games+'g '+c.wins+'W '+c.losses+'L ('+Math.round(c.wins/c.games*100)+'% WR)');
      }
    }
    lines.push('');
    lines.push('Generated by League Client Dashboard');

    var text=lines.join('\n');
    var blob=new Blob([text],{type:'text/plain'});
    var url=URL.createObjectURL(blob);
    var a=document.createElement('a');
    a.href=url; a.download=(acc.game_name||'profile')+'_stats.txt';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('Profile exported','success');
  }

  // ── Events ─────────────────────────────────────────
  document.getElementById('btn-search').addEventListener('click', doSearch);
  document.getElementById('search-input').addEventListener('keydown', function(e){ if(e.key==='Enter') doSearch(); });
  document.getElementById('queue-tabs').addEventListener('click', function(e){
    var btn=e.target.closest('.queue-tab'); if(!btn) return;
    var filter=btn.getAttribute('data-filter');
    currentFilter=filter; setActiveTab(filter); renderMatches(filterMatches(filter));
  });
  document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
  document.getElementById('h2h-btn').addEventListener('click', doH2HSearch);
  document.getElementById('h2h-input').addEventListener('keydown', function(e){ if(e.key==='Enter') doH2HSearch(); });
  document.getElementById('stats-tabs').addEventListener('click', function(e){
    var btn=e.target.closest('.stats-tab'); if(!btn) return;
    var panelId=btn.getAttribute('data-panel');
    var tabs=document.querySelectorAll('.stats-tab');
    var panels=document.querySelectorAll('.stats-panel');
    for (var i=0;i<tabs.length;i++) tabs[i].classList.toggle('active',tabs[i]===btn);
    for (var i=0;i<panels.length;i++) panels[i].classList.toggle('active',panels[i].id===panelId);
  });
  // Match filter dropdowns
  document.getElementById('champ-filter').addEventListener('change', function(){ renderMatches(filterMatches(currentFilter)); });
  document.getElementById('duration-filter').addEventListener('change', function(){ renderMatches(filterMatches(currentFilter)); });
  // Favorites
  document.getElementById('fav-toggle').addEventListener('click', toggleFavorite);
  // Goals
  document.getElementById('goal-add-btn').addEventListener('click', addGoal);
  document.getElementById('goal-target-input').addEventListener('keydown', function(e){ if(e.key==='Enter') addGoal(); });
  // Compare
  document.getElementById('compare-add-btn').addEventListener('click', addComparePlayer);
  document.getElementById('compare-input').addEventListener('keydown', function(e){ if(e.key==='Enter') addComparePlayer(); });
  // Export
  document.getElementById('export-btn').addEventListener('click', exportProfile);
  document.getElementById('export-csv-btn').addEventListener('click', exportCSV);
  // Notifications
  document.getElementById('notif-toggle').addEventListener('click', toggleNotifications);

  // Keyboard shortcuts (#7): / to focus search, Escape to clear, r to refresh, f to favorite
  document.addEventListener('keydown', function(e) {
    var tag = document.activeElement ? document.activeElement.tagName : '';
    var isInput = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
    if (e.key === '/' && !isInput) {
      e.preventDefault();
      var si = document.getElementById('search-input');
      if (si) { si.focus(); si.select(); }
    } else if (e.key === 'Escape' && isInput) {
      var si2 = document.getElementById('search-input');
      if (document.activeElement === si2) { si2.value = ''; si2.blur(); }
      else { document.activeElement.blur(); }
    } else if (e.key === 'r' && !isInput && currentPuuid) {
      e.preventDefault();
      doSearch();
    } else if (e.key === 'f' && !isInput && currentPuuid) {
      e.preventDefault();
      var fb = document.getElementById('fav-btn');
      if (fb) fb.click();
    }
  });

  // Live game auto-refresh
  var liveGameInterval=null;
  function startLiveGamePoll() {
    if (liveGameInterval) clearInterval(liveGameInterval);
    liveGameInterval=setInterval(function(){
      if (!currentPuuid) return;
      var el=document.getElementById('search-input');
      if (!el||!el.value.trim()) return;
      var parts=el.value.trim().split('#');
      if (parts.length<2) return;
      var plat=document.getElementById('region-select').value;
      fetch('/api/search?name='+encodeURIComponent(parts[0].trim())+'&tag='+encodeURIComponent(parts.slice(1).join('#').trim())+'&platform='+encodeURIComponent(plat))
        .then(function(r){ if(!r.ok) return null; return r.json(); })
        .then(function(data){
          if (!data) return;
          renderLiveGame(data.live_game);
          if (!data.live_game&&liveGameInterval) { clearInterval(liveGameInterval); liveGameInterval=null; }
        })
        .catch(function(){});
    }, 30000);
  }
  function checkLiveGamePoll(data) {
    if (data&&data.live_game) startLiveGamePoll();
    else if (liveGameInterval) { clearInterval(liveGameInterval); liveGameInterval=null; }
  }

  initTheme();
  loadServerStatus();
  loadRecentSearches();
  loadFavorites();
  document.getElementById('recent-select').addEventListener('change',function(){
    if(this.value){document.getElementById('search-input').value=this.value;this.value='';doSearch();}
  });
  loadDDragonData();
  connect();
  // Restore player from URL params (?player=Name%23Tag&platform=EUW1)
  (function(){
    var p=new URLSearchParams(window.location.search);
    var urlPlayer=p.get('player');
    var urlPlatform=p.get('platform');
    if (urlPlayer&&urlPlayer.indexOf('#')>=0) {
      document.getElementById('search-input').value=urlPlayer;
      if (urlPlatform) document.getElementById('region-select').value=urlPlatform;
      doSearch();
    }
  }());
  // Restore notification state
  if (localStorage.getItem('lc-notif')==='1'&&'Notification' in window&&Notification.permission==='granted') {
    notifEnabled=true;
    document.getElementById('notif-toggle').classList.add('active');
  }
  // Restore region from localStorage
  var savedRegion=localStorage.getItem('lc-region');
  if (savedRegion) document.getElementById('region-select').value=savedRegion;
  document.getElementById('region-select').addEventListener('change', function(){ localStorage.setItem('lc-region',this.value); });

  // ── Quick Win: Search Autocomplete ─────────────────
  (function(){
    var input=document.getElementById('search-input');
    var dropdown=document.getElementById('ac-dropdown');
    var acTimer=null;
    var acIdx=-1;
    var acItems=[];

    input.addEventListener('input',function(){
      clearTimeout(acTimer);
      var q=input.value.trim();
      if (q.length<2||q.indexOf('#')>=0) { dropdown.classList.remove('visible'); return; }
      acTimer=setTimeout(function(){
        fetch('/api/autocomplete?q='+encodeURIComponent(q))
          .then(function(r){return r.json();})
          .then(function(data){
            if (!data||data.length===0) { dropdown.classList.remove('visible'); return; }
            acItems=data; acIdx=-1;
            var html='';
            for (var i=0;i<data.length;i++) {
              var p=data[i];
              html+='<div class="ac-item" data-idx="'+i+'"><span class="ac-name">'+esc(p.game_name)+'<span class="muted">#'+esc(p.tag_line)+'</span></span><span class="ac-meta">'+(p.platform||'')+'</span></div>';
            }
            dropdown.innerHTML=html;
            dropdown.classList.add('visible');
            var items=dropdown.querySelectorAll('.ac-item');
            for (var j=0;j<items.length;j++) {
              (function(idx){
                items[idx].addEventListener('mousedown',function(e){
                  e.preventDefault();
                  var p=acItems[idx];
                  input.value=p.game_name+'#'+p.tag_line;
                  if (p.platform) document.getElementById('region-select').value=p.platform;
                  dropdown.classList.remove('visible');
                  doSearch();
                });
              })(j);
            }
          })
          .catch(function(){});
      }, 250);
    });

    input.addEventListener('keydown',function(e){
      if (!dropdown.classList.contains('visible')) return;
      var items=dropdown.querySelectorAll('.ac-item');
      if (e.key==='ArrowDown') { e.preventDefault(); acIdx=Math.min(acIdx+1,items.length-1); updateAcActive(items); }
      else if (e.key==='ArrowUp') { e.preventDefault(); acIdx=Math.max(acIdx-1,-1); updateAcActive(items); }
      else if (e.key==='Enter'&&acIdx>=0) {
        e.preventDefault();
        var p=acItems[acIdx];
        input.value=p.game_name+'#'+p.tag_line;
        if (p.platform) document.getElementById('region-select').value=p.platform;
        dropdown.classList.remove('visible');
        doSearch();
      }
      else if (e.key==='Escape') { dropdown.classList.remove('visible'); }
    });

    function updateAcActive(items) {
      for (var i=0;i<items.length;i++) items[i].classList.toggle('active',i===acIdx);
    }

    input.addEventListener('blur',function(){ setTimeout(function(){ dropdown.classList.remove('visible'); },200); });
  }());

  // ── Quick Win: My Dashboard ─────────────────────────
  (function(){
    var btn=document.getElementById('my-dash-btn');
    var saved=localStorage.getItem('lc-my-player');
    if (saved) btn.classList.add('saved');

    btn.addEventListener('click',function(){
      if (currentPuuid&&currentPlayerData) {
        var acc=currentPlayerData.account||{};
        var val=acc.game_name+'#'+acc.tag_line;
        var platform=document.getElementById('region-select').value;
        localStorage.setItem('lc-my-player',val);
        localStorage.setItem('lc-my-platform',platform);
        btn.classList.add('saved');
        showToast('Set as My Dashboard','success');
      } else {
        localStorage.removeItem('lc-my-player');
        localStorage.removeItem('lc-my-platform');
        btn.classList.remove('saved');
        showToast('My Dashboard cleared','info');
      }
    });

    // Auto-load on page start (only if no URL params)
    var urlParams=new URLSearchParams(window.location.search);
    if (!urlParams.get('player')&&saved) {
      setTimeout(function(){
        document.getElementById('search-input').value=saved;
        var plat=localStorage.getItem('lc-my-platform');
        if (plat) document.getElementById('region-select').value=plat;
        doSearch();
      }, 100);
    }
  }());

  // ── Quick Win: Post-Game Quick Actions ──────────────
  window.copyMatchResult=function(matchId, champ, k, d, a, win) {
    var text=(win?'Victory':'Defeat')+' — '+champ+' '+k+'/'+d+'/'+a;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function(){ showToast('Copied to clipboard','success'); });
    }
  };
  window.shareMatchUrl=function(matchId) {
    var url=window.location.origin+'?match='+matchId;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(url).then(function(){ showToast('Link copied','success'); });
    }
  };

  // ── Quick Win: Compact Match Cards Toggle ───────────
  var matchView='table';
  (function(){
    var btns=document.querySelectorAll('.view-toggle-btn');
    for (var i=0;i<btns.length;i++) {
      btns[i].addEventListener('click',function(){
        matchView=this.getAttribute('data-view');
        for (var j=0;j<btns.length;j++) btns[j].classList.toggle('active',btns[j].getAttribute('data-view')===matchView);
        var tableEl=document.querySelector('#matches-section table');
        var cardsEl=document.getElementById('match-cards-grid');
        if (matchView==='cards') {
          if (tableEl) tableEl.style.display='none';
          renderMatchCards(filterMatches(currentFilter));
          cardsEl.style.display='';
        } else {
          if (tableEl) tableEl.style.display='';
          cardsEl.style.display='none';
        }
      });
    }
  }());

  function renderMatchCards(matches) {
    var grid=document.getElementById('match-cards-grid');
    grid.innerHTML='';
    if (!matches||matches.length===0) { grid.innerHTML='<div class="muted" style="padding:20px;text-align:center;">No matches</div>'; return; }
    for (var i=0;i<matches.length;i++) {
      var m=matches[i], k=m.kills||0, d=m.deaths||0, a=m.assists||0;
      var kdaVal=d===0?'Perfect':((k+a)/d).toFixed(1);
      var pos=m.position||'';
      if (pos==='UTILITY') pos='SUP'; else if (pos==='BOTTOM') pos='ADC'; else if (pos==='MIDDLE') pos='MID'; else if (pos==='TOP') pos='TOP'; else if (pos==='JUNGLE') pos='JGL';
      var card=document.createElement('div');
      card.className='match-card-compact '+(m.win?'win':'loss');
      var champImg=m.champion_image?'<img class="mcc-champ" src="'+esc(m.champion_image)+'" />':'';
      var lpStr='';
      if (m.lp_change&&m.lp_change!==0) {
        var lpClr=m.lp_change>0?'var(--green)':'var(--red)';
        lpStr='<span style="font-size:10px;color:'+lpClr+'">'+(m.lp_change>0?'+':'')+m.lp_change+' LP</span>';
      }
      card.innerHTML='<div class="mcc-top">'+champImg+'<div><div class="mcc-kda">'+k+'/'+d+'/'+a+' <span class="muted">('+kdaVal+')</span></div><div class="mcc-meta">'+esc(m.champion_name||'')+(pos?' · '+pos:'')+'</div></div></div>'
        +'<div style="display:flex;justify-content:space-between;font-size:11px;"><span class="muted">'+esc(queueLabel(m))+'</span><span>'+(m.cs||0)+' CS</span></div>'
        +'<div style="display:flex;justify-content:space-between;font-size:10px;margin-top:2px;"><span class="muted">'+esc(m.game_duration||'')+'</span>'+lpStr+'</div>';
      grid.appendChild(card);
    }
  }
}());

  // ── Multi-Search (#10) ─────────────────────────────
  var multiSearchVisible=false;
  function toggleMultiSearch() {
    multiSearchVisible=!multiSearchVisible;
    document.getElementById('multi-search-container').style.display=multiSearchVisible?'block':'none';
    if (multiSearchVisible) document.getElementById('multi-search-input').focus();
  }
  function doMultiSearch() {
    var input=document.getElementById('multi-search-input').value.trim();
    if (!input) return;
    var lines=input.split('\n').filter(function(l){return l.trim().length>0;});
    var players=lines.map(function(l){return l.trim();}).join(',');
    var platform=document.getElementById('region-select').value;
    var resultsEl=document.getElementById('multi-search-results');
    resultsEl.innerHTML='<div class="muted">Scouting '+lines.length+' players...</div>';
    fetch('/api/multi-search?players='+encodeURIComponent(players)+'&platform='+encodeURIComponent(platform))
      .then(function(r){return r.json();})
      .then(function(data){
        if (!data.players||data.players.length===0) { resultsEl.innerHTML='<div class="muted">No results</div>'; return; }
        var html='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px;">';
        for (var i=0;i<data.players.length;i++) {
          var p=data.players[i];
          if (p.error) { html+='<div class="recent-card"><strong>'+esc(p.name)+'#'+esc(p.tag)+'</strong><div class="muted">'+esc(p.error)+'</div></div>'; continue; }
          var tierClr={'IRON':'#8b7355','BRONZE':'#cd7f32','SILVER':'#c0c0c0','GOLD':'#ffd700','PLATINUM':'#00cec9','EMERALD':'#2ecc71','DIAMOND':'#9b59b6','MASTER':'#e74c3c','GRANDMASTER':'#e74c3c','CHALLENGER':'#f1c40f'};
          var clr=tierClr[p.tier]||'var(--text-muted)';
          var streakHtml='';
          if (p.streak&&Math.abs(p.streak)>=2) { var sClr=p.streak>0?'var(--green)':'var(--red)'; streakHtml='<span style="color:'+sClr+';font-size:11px;">'+(p.streak>0?p.streak+'W':Math.abs(p.streak)+'L')+' streak</span>'; }
          html+='<div class="recent-card" style="cursor:pointer;" onclick="document.getElementById(\'search-input\').value=\''+esc(p.name)+'#'+esc(p.tag)+'\';doSearch();">';
          html+='<div style="font-weight:600;font-size:13px;">'+esc(p.name)+'<span class="muted">#'+esc(p.tag)+'</span></div>';
          html+='<div style="color:'+clr+';font-size:12px;">'+(p.tier?p.tier+' '+p.rank+' '+(p.lp||0)+' LP':'Unranked')+'</div>';
          if (p.winrate!==undefined&&p.winrate!==null) html+='<div style="font-size:11px;">WR: <strong style="color:'+(p.winrate>=50?'var(--green)':'var(--red)')+'">'+p.winrate+'%</strong>'+(p.recent_wr?' <span class="muted">Recent: '+p.recent_wr+'%</span>':'')+'</div>';
          if (p.main_champions&&p.main_champions.length>0) html+='<div class="muted" style="font-size:10px;">'+p.main_champions.join(', ')+'</div>';
          if (streakHtml) html+='<div>'+streakHtml+'</div>';
          html+='</div>';
        }
        html+='</div>';
        resultsEl.innerHTML=html;
      })
      .catch(function(err){ resultsEl.innerHTML='<div style="color:var(--red)">'+esc(err.message)+'</div>'; });
  }

  // ── Keyboard shortcut: M for multi-search ──────────
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.tagName==='SELECT') return;
    if (e.key==='m'||e.key==='M') { e.preventDefault(); toggleMultiSearch(); }
  });

  // ── Pre-Game Briefing (#1) ─────────────────────────
  function loadBriefing() {
    if (!currentPuuid) return;
    var platform=document.getElementById('region-select').value;
    fetch('/api/live-game/'+currentPuuid+'/briefing?platform='+encodeURIComponent(platform))
      .then(function(r){if(!r.ok) return null; return r.json();})
      .then(function(data){
        if (!data||!data.opponents) return;
        var banner=document.getElementById('live-game-banner');
        var briefEl=document.getElementById('live-briefing');
        if (!briefEl) {
          briefEl=document.createElement('div');
          briefEl.id='live-briefing';
          briefEl.style.cssText='margin-top:12px;padding:12px;background:rgba(200,155,60,0.05);border:1px solid var(--border);border-radius:8px;';
          banner.appendChild(briefEl);
        }
        var html='<div class="ext-title">Pre-Game Briefing</div>';
        for (var i=0;i<data.opponents.length;i++) {
          var o=data.opponents[i];
          html+='<div style="padding:6px 0;border-bottom:1px solid var(--border);font-size:12px;">';
          html+='<strong>'+esc(o.champion_name)+'</strong> <span class="muted">'+esc(o.summoner_name)+'</span>';
          if (o.tier) html+=' <span style="font-size:11px;">'+esc(o.tier)+' '+esc(o.rank||'')+'</span>';
          if (o.champion_wr!==undefined&&o.champion_wr!==null) html+=' <span style="color:'+(o.champion_wr>=50?'var(--green)':'var(--red)')+'">'+o.champion_wr+'% on champ ('+o.champion_games+'g)</span>';
          if (o.weaknesses&&o.weaknesses.length>0) html+='<div style="color:var(--red);font-size:11px;margin-top:2px;">Weak: '+o.weaknesses.join(' | ')+'</div>';
          if (o.strengths&&o.strengths.length>0) html+='<div style="color:var(--green);font-size:11px;">Strong: '+o.strengths.join(' | ')+'</div>';
          html+='</div>';
        }
        briefEl.innerHTML=html;
      })
      .catch(function(){});
  }

  // Auto-load briefing when live game is detected
  var _origRenderLiveGame=renderLiveGame;
  renderLiveGame=function(lg) {
    _origRenderLiveGame(lg);
    if (lg) setTimeout(loadBriefing, 500);
  };

  // (Quick Win code is inside the IIFE above)
</script>
{{end}}
